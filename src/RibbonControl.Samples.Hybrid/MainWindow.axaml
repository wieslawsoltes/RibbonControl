<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RibbonControl.Samples.Hybrid.ViewModels"
        xmlns:ribbon="https://github.com/wieslawsoltes/ribboncontrol"
        x:Class="RibbonControl.Samples.Hybrid.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1360"
        Height="820"
        Title="RibbonControl - Hybrid Word-Like Sample">
  <Window.Resources>
    <ResourceDictionary>
    <x:String x:Key="Ribbon.Sample.Icon.Paste">M4.5 4h1.59c.2.58.76 1 1.41 1h3c.65 0 1.2-.42 1.41-1h1.59c.28 0 .5.22.5.5v1a.5.5 0 0 0 1 0v-1c0-.83-.67-1.5-1.5-1.5h-1.59c-.2-.58-.76-1-1.41-1h-3c-.65 0-1.2.42-1.41 1H4.5C3.67 3 3 3.67 3 4.5v12c0 .83.67 1.5 1.5 1.5h3a.5.5 0 0 0 0-1h-3a.5.5 0 0 1-.5-.5v-12c0-.28.22-.5.5-.5Zm3 0a.5.5 0 0 1 0-1h3a.5.5 0 0 1 0 1h-3Zm3 3C9.67 7 9 7.67 9 8.5v8c0 .83.67 1.5 1.5 1.5h5c.83 0 1.5-.67 1.5-1.5v-8c0-.83-.67-1.5-1.5-1.5h-5ZM10 8.5c0-.28.22-.5.5-.5h5c.28 0 .5.22.5.5v8a.5.5 0 0 1-.5.5h-5a.5.5 0 0 1-.5-.5v-8Z</x:String>
    <x:String x:Key="Ribbon.Sample.Icon.Cut">M1.91 7.38A8.5 8.5 0 0 1 3.7 4.3a.5.5 0 0 1 .54-.13l1.92.68a1 1 0 0 0 1.32-.76l.36-2a.5.5 0 0 1 .4-.4 8.53 8.53 0 0 1 3.55 0c.2.04.35.2.38.4l.37 2a1 1 0 0 0 1.32.76l1.92-.68a.5.5 0 0 1 .54.13 8.5 8.5 0 0 1 1.78 3.08c.06.2 0 .4-.15.54l-1.56 1.32a1 1 0 0 0 0 1.52l1.56 1.32a.5.5 0 0 1 .15.54 8.5 8.5 0 0 1-1.78 3.08.5.5 0 0 1-.54.13l-1.92-.68a1 1 0 0 0-1.32.76l-.37 2a.5.5 0 0 1-.38.4 8.53 8.53 0 0 1-3.56 0 .5.5 0 0 1-.39-.4l-.36-2a1 1 0 0 0-1.32-.76l-1.92.68a.5.5 0 0 1-.54-.13 8.5 8.5 0 0 1-1.78-3.08.5.5 0 0 1 .15-.54l1.56-1.32a1 1 0 0 0 0-1.52L2.06 7.92a.5.5 0 0 1-.15-.54Zm1.06 0 1.3 1.1a2 2 0 0 1 0 3.04l-1.3 1.1c.3.79.72 1.51 1.25 2.16l1.6-.58a2 2 0 0 1 2.63 1.53l.3 1.67a7.56 7.56 0 0 0 2.5 0l.3-1.67a2 2 0 0 1 2.64-1.53l1.6.58a7.5 7.5 0 0 0 1.24-2.16l-1.3-1.1a2 2 0 0 1 0-3.04l1.3-1.1a7.5 7.5 0 0 0-1.25-2.16l-1.6.58a2 2 0 0 1-2.63-1.53l-.3-1.67a7.55 7.55 0 0 0-2.5 0l-.3 1.67A2 2 0 0 1 5.81 5.8l-1.6-.58a7.5 7.5 0 0 0-1.24 2.16ZM7.5 10a2.5 2.5 0 1 1 5 0 2.5 2.5 0 0 1-5 0Zm1 0a1.5 1.5 0 1 0 3 0 1.5 1.5 0 0 0-3 0Z</x:String>
    <x:String x:Key="Ribbon.Sample.Icon.QuickTemplates">M16.52 9c.26 0 .48-.2.48-.46V8.5A6.5 6.5 0 0 0 10.5 2h-.04a.47.47 0 0 0-.46.48V8.5c0 .28.22.5.5.5h6.02ZM11 3.02A5.5 5.5 0 0 1 15.98 8H11V3.02ZM8 9V5.1A5 5 0 0 0 9 15v1a6 6 0 0 1-.5-11.98c.28-.02.5.2.5.48V9a1 1 0 0 0 1 1h4.5c.28 0 .5.22.48.5a6 6 0 0 1-.06.5H10a2 2 0 0 1-2-2Zm9 1a1 1 0 0 0-1 1v7a1 1 0 1 0 2 0v-7a1 1 0 0 0-1-1Zm-3 2a1 1 0 0 0-1 1v5a1 1 0 1 0 2 0v-5a1 1 0 0 0-1-1Zm-4 3a1 1 0 1 1 2 0v3a1 1 0 1 1-2 0v-3Z</x:String>
    <x:String x:Key="Ribbon.Sample.Icon.Emoji">🙂</x:String>
    <ResourceDictionary.ThemeDictionaries>
      <ResourceDictionary x:Key="Dark">
        <x:String x:Key="Ribbon.Sample.Icon.Emoji">🌙</x:String>
      </ResourceDictionary>
      <ResourceDictionary x:Key="Light">
        <x:String x:Key="Ribbon.Sample.Icon.Emoji">🙂</x:String>
      </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>
    <ControlTheme x:Key="Ribbon.Sample.IconPresenterTheme"
                  TargetType="ribbon:RibbonIconPresenter"
                  BasedOn="{StaticResource {x:Type ribbon:RibbonIconPresenter}}">
      <Setter Property="OverlayWidth" Value="9" />
      <Setter Property="OverlayHeight" Value="9" />
      <Setter Property="OverlayMargin" Value="0" />
      <Setter Property="OverlayCountMargin" Value="0" />
    </ControlTheme>
    </ResourceDictionary>
  </Window.Resources>
  <Window.Styles>
    <Style Selector="ribbon|RibbonIconPresenter">
      <Setter Property="Theme" Value="{StaticResource Ribbon.Sample.IconPresenterTheme}" />
    </Style>
  </Window.Styles>
  <DockPanel>
    <ribbon:Ribbon x:Name="MainRibbon"
                   DockPanel.Dock="Top"
                   TabsSource="{CompiledBinding DynamicTabs}"
                   TabMergeMode="Merge"
                   CommandCatalog="{CompiledBinding CommandCatalog}"
                   StateStore="{CompiledBinding StateStore}"
                   StateOwnershipMode="{CompiledBinding StateOwnershipMode, Mode=TwoWay}"
                   QuickAccessItems="{CompiledBinding QuickAccessItems}"
                   QuickAccessPlacement="{CompiledBinding QuickAccessPlacement, Mode=TwoWay}"
                   ActiveContextGroupIds="{CompiledBinding ActiveContextGroupIds}"
                   SelectedTabId="{CompiledBinding SelectedTabId, Mode=TwoWay}"
                   IsMinimized="{CompiledBinding IsMinimized, Mode=TwoWay}"
                   IsKeyTipMode="{CompiledBinding IsKeyTipMode, Mode=TwoWay}"
                   EnableAdaptiveLayout="True"
                   AdaptiveLayoutHorizontalPadding="24">
      <ribbon:Ribbon.TopBarStartContent>
        <StackPanel Classes="ribbon-topbar-shell">
          <Button Classes="ribbon-topbar-launcher"
                  ToolTip.Tip="App launcher">
            <PathIcon Data="{x:Static ribbon:FluentIconData.AppsList20Regular}"
                      Width="16"
                      Height="16" />
          </Button>
          <Border Classes="ribbon-topbar-app-badge">
            <TextBlock Classes="ribbon-topbar-app-badge-text" Text="W" />
          </Border>
          <TextBlock Classes="ribbon-topbar-title" Text="Document 6" />
          <PathIcon Classes="ribbon-topbar-status"
                    Data="{x:Static ribbon:FluentIconData.CheckmarkCircle20Regular}" />
        </StackPanel>
      </ribbon:Ribbon.TopBarStartContent>

      <ribbon:Ribbon.TopBarCenterContent>
        <TextBox Classes="ribbon-topbar-search" />
      </ribbon:Ribbon.TopBarCenterContent>

      <ribbon:Ribbon.HeaderEndContent>
        <StackPanel Orientation="Horizontal" Spacing="6">
          <Button Classes="ribbon-header-action">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <PathIcon Data="{x:Static ribbon:FluentIconData.Comment20Regular}" Width="14" Height="14" />
              <TextBlock Text="Comments" />
            </StackPanel>
          </Button>
          <Button Classes="ribbon-header-action">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <PathIcon Data="{x:Static ribbon:FluentIconData.Pulse20Regular}" Width="14" Height="14" />
              <TextBlock Text="Catch up" />
            </StackPanel>
          </Button>
          <ComboBox Classes="ribbon-header-mode" Width="120" SelectedIndex="0">
            <ComboBoxItem>Editing</ComboBoxItem>
            <ComboBoxItem>Reviewing</ComboBoxItem>
            <ComboBoxItem>Viewing</ComboBoxItem>
          </ComboBox>
          <Button Classes="ribbon-header-share">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <PathIcon Data="{x:Static ribbon:FluentIconData.Share20Regular}" Width="14" Height="14" />
              <TextBlock Text="Share" />
            </StackPanel>
          </Button>
        </StackPanel>
      </ribbon:Ribbon.HeaderEndContent>

      <ribbon:Ribbon.Backstage>
        <ribbon:RibbonBackstage IsOpen="{CompiledBinding IsBackstageOpen, Mode=TwoWay}"
                                ItemsSource="{CompiledBinding BackstageItems}"
                                NavigationPaneWidth="360"
                                Content="Hybrid backstage: static XAML shell with dynamic menu contributions from the ViewModel.">
          <ribbon:RibbonBackstage.HeaderContent>
            <Border Background="#E8F3EB"
                    CornerRadius="6"
                    Padding="10,8">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <PathIcon Data="{x:Static ribbon:FluentIconData.CheckmarkCircle20Regular}"
                          Width="18"
                          Height="18"
                          Foreground="#0F8B4C" />
                <TextBlock Text="Autosaved online to Documents"
                           FontWeight="SemiBold" />
              </StackPanel>
            </Border>
          </ribbon:RibbonBackstage.HeaderContent>
          <ribbon:RibbonBackstage.FooterContent>
            <TextBlock Text="Hybrid sample keeps this chrome in XAML and item state in ViewModel collections."
                       FontSize="11"
                       Opacity="0.72" />
          </ribbon:RibbonBackstage.FooterContent>
        </ribbon:RibbonBackstage>
      </ribbon:Ribbon.Backstage>

      <ribbon:RibbonTab Id="home" Header="Home" Order="0">
        <ribbon:RibbonGroup Id="history"
                            Header="Undo"
                            Order="-1"
                            ItemsLayoutMode="Stacked"
                            StackedRows="2">
          <ribbon:RibbonItem Id="undo"
                             Label="Undo"
                             Size="Small"
                             DisplayMode="IconOnly"
                             IconPathData="{x:Static ribbon:FluentIconData.ArrowUndo20Regular}"
                             CommandId="undo"
                             KeyTip="Z"
                             ScreenTip="Undo last action" />
          <ribbon:RibbonItem Id="redo"
                             Label="Redo"
                             Size="Small"
                             DisplayMode="IconOnly"
                             IconPathData="{x:Static ribbon:FluentIconData.ArrowSync20Regular}"
                             CommandId="redo"
                             KeyTip="Y"
                             ScreenTip="Redo last action" />
        </ribbon:RibbonGroup>
        <ribbon:RibbonGroup Id="clipboard"
                            Header="Clipboard"
                            ItemsLayoutMode="Docked"
                            DockedCenterLayoutMode="Vertical"
                            Order="0">
          <ribbon:RibbonItem Id="paste"
                             Label="Paste"
                             Primitive="PasteSplitButton"
                             LayoutDock="Left"
                             IconPathData="{x:Static ribbon:FluentIconData.ClipboardPaste20Regular}"
                             IconMinWidth="20"
                             IconMinHeight="20"
                             IconMaxWidth="28"
                             IconMaxHeight="28"
                             CommandId="paste"
                             KeyTip="V"
                             ScreenTip="Paste from clipboard">
            <ribbon:RibbonItem.MenuItems>
              <ribbon:RibbonMenuItem Id="paste-default"
                                     Label="Paste"
                                     Description="Keep source formatting"
                                     IconPathData="{x:Static ribbon:FluentIconData.ClipboardPaste20Regular}"
                                     CommandId="paste"
                                     InputGestureText="Cmd+V"
                                     Order="0" />
              <ribbon:RibbonMenuItem Id="paste-text-only"
                                     Label="Paste Text Only"
                                     Description="Keep text and discard formatting"
                                     IconPathData="{x:Static ribbon:FluentIconData.Copy20Regular}"
                                     CommandId="paste-text-only"
                                     InputGestureText="Cmd+Shift+V"
                                     Order="1" />
              <ribbon:RibbonMenuItem Id="paste-merge"
                                     Label="Paste With Merge Formatting"
                                     Description="Match destination formatting"
                                     IconPathData="{x:Static ribbon:FluentIconData.ArrowSync20Regular}"
                                     CommandId="paste-merge-formatting"
                                     InputGestureText="Option+V"
                                     Order="2" />
            </ribbon:RibbonItem.MenuItems>
          </ribbon:RibbonItem>
          <ribbon:RibbonItem Id="copy"
                             Label="Copy"
                             LayoutDock="Center"
                             IconPathData="{x:Static ribbon:FluentIconData.Copy20Regular}"
                             CommandId="copy"
                             KeyTip="C"
                             ScreenTip="Copy selection" />
        </ribbon:RibbonGroup>
        <ribbon:RibbonGroup Id="font"
                            Header="Font"
                            HeaderPlacement="Top"
                            ItemsLayoutMode="Docked"
                            DockedCenterLayoutMode="Horizontal"
                            StackedRows="2"
                            Order="1">
          <ribbon:RibbonItem Id="font-family"
                             Label="Font"
                             Primitive="ComboBox"
                             Size="Large"
                             LayoutDock="Top"
                             Order="0"
                             SelectedMenuItemId="font-family-aptos"
                             KeyTip="FF"
                             ScreenTip="Choose font family">
            <ribbon:RibbonItem.MenuItems>
              <ribbon:RibbonMenuItem Id="font-family-aptos"
                                     Label="Aptos (Body)"
                                     CommandId="font-family-aptos"
                                     IsSelected="True"
                                     Order="0" />
              <ribbon:RibbonMenuItem Id="font-family-calibri"
                                     Label="Calibri"
                                     CommandId="font-family-calibri"
                                     Order="1" />
              <ribbon:RibbonMenuItem Id="font-family-segoe"
                                     Label="Segoe UI"
                                     CommandId="font-family-segoe"
                                     Order="2" />
            </ribbon:RibbonItem.MenuItems>
          </ribbon:RibbonItem>
          <ribbon:RibbonItem Id="font-size"
                             Label="Size"
                             Primitive="ComboBox"
                             Size="Small"
                             LayoutDock="Top"
                             Order="1"
                             SelectedMenuItemId="font-size-12"
                             KeyTip="FS"
                             ScreenTip="Choose font size">
            <ribbon:RibbonItem.MenuItems>
              <ribbon:RibbonMenuItem Id="font-size-10" Label="10" CommandId="font-size-10" Order="0" />
              <ribbon:RibbonMenuItem Id="font-size-11" Label="11" CommandId="font-size-11" Order="1" />
              <ribbon:RibbonMenuItem Id="font-size-12" Label="12" CommandId="font-size-12" IsSelected="True" Order="2" />
              <ribbon:RibbonMenuItem Id="font-size-14" Label="14" CommandId="font-size-14" Order="3" />
            </ribbon:RibbonItem.MenuItems>
          </ribbon:RibbonItem>
          <ribbon:RibbonItem Id="font-grow" Label="A+" Primitive="ToggleButton" Size="Small" LayoutDock="Top" CommandId="font-grow" Order="2" KeyTip="FG" ScreenTip="Grow font size" />
          <ribbon:RibbonItem Id="font-shrink" Label="A-" Primitive="ToggleButton" Size="Small" LayoutDock="Top" CommandId="font-shrink" Order="3" KeyTip="FK" ScreenTip="Shrink font size" />
          <ribbon:RibbonItem Id="bold" Label="B" Primitive="ToggleButton" Size="Small" LayoutDock="Bottom" IsChecked="True" CommandId="bold" Order="10" KeyTip="B" ScreenTip="Apply bold formatting" />
          <ribbon:RibbonItem Id="italic" Label="I" Primitive="ToggleButton" Size="Small" LayoutDock="Bottom" CommandId="italic" Order="11" KeyTip="I" ScreenTip="Apply italic formatting" />
          <ribbon:RibbonItem Id="underline" Label="U" Primitive="ToggleButton" Size="Small" LayoutDock="Bottom" CommandId="underline" Order="12" KeyTip="U" ScreenTip="Underline text" />
          <ribbon:RibbonItem Id="strikethrough" Label="ab" Primitive="ToggleButton" Size="Small" LayoutDock="Bottom" CommandId="strikethrough" Order="13" KeyTip="ST" ScreenTip="Apply strikethrough" />
          <ribbon:RibbonItem Id="superscript" Label="x²" Primitive="ToggleButton" Size="Small" LayoutDock="Bottom" CommandId="superscript" Order="14" KeyTip="SP" ScreenTip="Superscript text" />
        </ribbon:RibbonGroup>
      </ribbon:RibbonTab>

      <ribbon:RibbonTab Id="insert" Header="Insert" Order="1">
        <ribbon:RibbonGroup Id="illustrations" Header="Illustrations" Order="0">
          <ribbon:RibbonItem Id="picture"
                             Label="Picture"
                             IconPathData="{x:Static ribbon:FluentIconData.Image20Regular}"
                             CommandId="picture"
                             KeyTip="P"
                             ScreenTip="Insert a picture" />
          <ribbon:RibbonItem Id="hybrid-static-templates"
                             Label="Static Templates"
                             Primitive="MenuButton"
                             IconResourceKey="Ribbon.Sample.Icon.QuickTemplates"
                             IconPathData="{x:Static ribbon:FluentIconData.ChartMultiple20Regular}"
                             PopupTitle="Static Templates"
                             PopupMinWidth="260"
                             PopupMaxHeight="320"
                             CommandId="hybrid-static-template"
                             KeyTip="ST"
                             ScreenTip="Static XAML popup menu sample">
            <ribbon:RibbonItem.MenuItems>
              <ribbon:RibbonMenuItem Id="hybrid-static-template-letter"
                                     Label="Letter"
                                     IconPathData="{x:Static ribbon:FluentIconData.Document20Regular}"
                                     CommandId="hybrid-static-template-letter"
                                     Order="0" />
              <ribbon:RibbonMenuItem Id="hybrid-static-template-report"
                                     Label="Report"
                                     IconPathData="{x:Static ribbon:FluentIconData.Copy20Regular}"
                                     CommandId="hybrid-static-template-report"
                                     Order="1" />
              <ribbon:RibbonMenuItem Id="hybrid-static-template-notes"
                                     Label="Notes"
                                     IconEmoji="📝"
                                     IconPathData="{x:Static ribbon:FluentIconData.Wrench20Regular}"
                                     ShowChevron="True"
                                     Order="2">
                <ribbon:RibbonMenuItem.SubMenuItems>
                  <ribbon:RibbonMenuItem Id="hybrid-static-template-notes-meeting"
                                         Label="Meeting Notes"
                                         IconPathData="{x:Static ribbon:FluentIconData.Document20Regular}"
                                         CommandId="hybrid-static-template-notes"
                                         Order="0" />
                  <ribbon:RibbonMenuItem Id="hybrid-static-template-notes-project"
                                         Label="Project Notes"
                                         IconPathData="{x:Static ribbon:FluentIconData.Copy20Regular}"
                                         CommandId="hybrid-static-template-notes"
                                         Order="1" />
                </ribbon:RibbonMenuItem.SubMenuItems>
              </ribbon:RibbonMenuItem>
            </ribbon:RibbonItem.MenuItems>
          </ribbon:RibbonItem>
          <ribbon:RibbonItem Id="chart"
                             Label="Chart"
                             IconPathData="{x:Static ribbon:FluentIconData.ChartMultiple20Regular}"
                             CommandId="chart"
                             KeyTip="H"
                             ScreenTip="Insert a chart" />
        </ribbon:RibbonGroup>
      </ribbon:RibbonTab>

      <ribbon:RibbonTab Id="layout" Header="Layout" Order="2">
        <ribbon:RibbonGroup Id="page-setup" Header="Page Setup" Order="0">
          <ribbon:RibbonItem Id="margins"
                             Label="Margins"
                             IconPathData="{x:Static ribbon:FluentIconData.Settings20Regular}"
                             CommandId="margins"
                             KeyTip="MG"
                             ScreenTip="Set page margins" />
          <ribbon:RibbonItem Id="orientation"
                             Label="Orientation"
                             IconPathData="{x:Static ribbon:FluentIconData.ChartMultiple20Regular}"
                             CommandId="orientation"
                             KeyTip="OR"
                             ScreenTip="Set page orientation" />
          <ribbon:RibbonItem Id="size"
                             Label="Size"
                             IconPathData="{x:Static ribbon:FluentIconData.Copy20Regular}"
                             CommandId="size"
                             KeyTip="SZ"
                             ScreenTip="Set paper size" />
        </ribbon:RibbonGroup>
      </ribbon:RibbonTab>
    </ribbon:Ribbon>

    <Grid RowDefinitions="*,Auto">
      <Grid ColumnDefinitions="220,*,320">
        <Border Grid.Column="0"
                Background="#F2F4F8"
                BorderBrush="#D5DBE6"
                BorderThickness="0,1,1,0"
                Padding="12">
          <StackPanel Spacing="10">
            <TextBlock Text="Navigation"
                       FontSize="13"
                       FontWeight="SemiBold" />
            <ListBox>
              <ListBoxItem>Document 1</ListBoxItem>
              <ListBoxItem>Outline</ListBoxItem>
              <ListBoxItem>Headings</ListBoxItem>
              <ListBoxItem>Pages</ListBoxItem>
            </ListBox>
          </StackPanel>
        </Border>

        <Border Grid.Column="1"
                Background="#ECEFF4"
                BorderBrush="#D5DBE6"
                BorderThickness="0,1,0,0"
                Padding="24">
          <Grid RowDefinitions="Auto,*">
            <Border Background="#F8FAFD"
                    BorderBrush="#D5DBE6"
                    BorderThickness="1"
                    CornerRadius="2"
                    Padding="8,4">
              <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                           Text="Word-like Document Surface"
                           FontSize="12"
                           FontWeight="SemiBold" />
                <TextBlock DockPanel.Dock="Right"
                           Text="Page 1 of 1"
                           FontSize="11"
                           Opacity="0.7" />
              </DockPanel>
            </Border>

            <Border Grid.Row="1"
                    Margin="0,12,0,0"
                    Background="White"
                    BorderBrush="#C9D2E2"
                    BorderThickness="1"
                    CornerRadius="2"
                    HorizontalAlignment="Center"
                    Width="800"
                    Padding="48">
              <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                            VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="12">
                  <TextBlock Text="RibbonControl Default Generic Theme Preview"
                             FontSize="26"
                             FontWeight="SemiBold" />
                  <TextBlock Text="This hybrid sample combines static XAML ribbon structure with dynamic VM-based contributions in one live ribbon."
                             TextWrapping="Wrap"
                             FontSize="13" />
                  <TextBlock Text="Use the controls in the right pane to toggle add-ins and contextual tabs, then validate merge and parity behavior."
                             TextWrapping="Wrap"
                             FontSize="13" />
                </StackPanel>
              </ScrollViewer>
            </Border>
          </Grid>
        </Border>

        <Border Grid.Column="2"
                Background="#F7F8FA"
                BorderBrush="#D5DBE6"
                BorderThickness="1,1,0,0"
                Padding="14">
          <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="12">
              <TextBlock Text="Inspector / Actions"
                         FontSize="13"
                         FontWeight="SemiBold" />

              <WrapPanel ItemHeight="32" ItemWidth="150">
                <Button Content="Toggle Picture Tools" Command="{CompiledBinding TogglePictureToolsCommand}" />
                <Button Content="Toggle Add-ins Tab" Command="{CompiledBinding ToggleAddInsTabCommand}" />
                <Button Content="Toggle Minimized" Command="{CompiledBinding ToggleMinimizedCommand}" />
                <Button Content="Toggle KeyTip Mode" Command="{CompiledBinding ToggleKeyTipModeCommand}" />
                <Button Content="Toggle QAT Placement" Command="{CompiledBinding ToggleQuickAccessPlacementCommand}" />
              </WrapPanel>

              <WrapPanel ItemHeight="32" ItemWidth="150">
                <Button Content="Seed State Store" Command="{CompiledBinding SeedStateStoreCommand}" />
                <Button Content="Load State" Command="{CompiledBinding #MainRibbon.LoadStateCommand}" />
                <Button Content="Save State" Command="{CompiledBinding #MainRibbon.SaveStateCommand}" />
                <Button Content="Reset State" Command="{CompiledBinding #MainRibbon.ResetStateCommand}" />
                <Button Content="Reset Customization" Command="{CompiledBinding #MainRibbon.ResetCustomizationCommand}" />
              </WrapPanel>

              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Ownership" VerticalAlignment="Center" />
                <ComboBox Width="140"
                          ItemsSource="{CompiledBinding StateOwnershipModes}"
                          SelectedItem="{CompiledBinding StateOwnershipMode, Mode=TwoWay}" />
              </StackPanel>

              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="QAT Placement" VerticalAlignment="Center" />
                <ComboBox Width="120"
                          ItemsSource="{CompiledBinding QuickAccessPlacements}"
                          SelectedItem="{CompiledBinding QuickAccessPlacement, Mode=TwoWay}" />
              </StackPanel>

              <TextBlock Text="{CompiledBinding Status}"
                         FontSize="13"
                         FontWeight="SemiBold" />
              <TextBlock Text="{CompiledBinding SelectedTabId, StringFormat='Selected Tab: {0}'}" FontSize="12" Opacity="0.75" />
              <TextBlock Text="{CompiledBinding IsBackstageOpen, StringFormat='Backstage Open: {0}'}" FontSize="12" Opacity="0.75" />
              <TextBlock Text="{CompiledBinding IsMinimized, StringFormat='Is Minimized: {0}'}" FontSize="12" Opacity="0.75" />
              <TextBlock Text="{CompiledBinding IsKeyTipMode, StringFormat='Is KeyTip Mode: {0}'}" FontSize="12" Opacity="0.75" />
              <TextBlock Text="{CompiledBinding QuickAccessPlacement, StringFormat='QAT Placement: {0}'}" FontSize="12" Opacity="0.75" />
              <TextBlock Text="{CompiledBinding StateOwnershipMode, StringFormat='Ownership Mode: {0}'}" FontSize="12" Opacity="0.75" />
              <TextBlock Text="Press Alt to enter key-tip mode."
                         FontSize="12"
                         Opacity="0.65" />
            </StackPanel>
          </ScrollViewer>
        </Border>
      </Grid>

      <Border Grid.Row="1"
              Background="#EEF1F6"
