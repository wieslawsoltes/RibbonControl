<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:RibbonControl.Core.Controls">
  <Style Selector="controls|Ribbon">
    <Setter Property="FontFamily" Value="Segoe UI" />
    <Setter Property="Foreground" Value="{DynamicResource RibbonOfficeTextBrush}" />
  </Style>

  <Style Selector="controls|Ribbon /template/ controls|RibbonBackstage">
    <Setter Property="Theme" Value="{StaticResource OfficeRibbonBackstageTheme}" />
  </Style>

  <Style Selector="controls|RibbonBackstage /template/ Border.office-ribbon-backstage-root">
    <Setter Property="CornerRadius" Value="0,0,10,10" />
    <Setter Property="BorderBrush" Value="{DynamicResource RibbonOfficeBorderBrush}" />
    <Setter Property="BorderThickness" Value="0,0,1,1" />
  </Style>

  <Style Selector="controls|RibbonBackstage /template/ Border.office-ribbon-backstage-nav-host">
    <Setter Property="Background" Value="{DynamicResource RibbonOfficeMenuSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource RibbonOfficeBorderBrush}" />
    <Setter Property="BorderThickness" Value="0,0,1,0" />
  </Style>

  <Style Selector="controls|RibbonBackstage /template/ ContentPresenter.office-ribbon-backstage-header-host">
    <Setter Property="Margin" Value="18,14,16,10" />
  </Style>

  <Style Selector="controls|RibbonBackstage /template/ ContentPresenter.office-ribbon-backstage-footer-host">
    <Setter Property="Margin" Value="16,10,16,14" />
  </Style>

  <Style Selector="controls|RibbonBackstage /template/ Border.office-ribbon-backstage-detail-host">
    <Setter Property="Padding" Value="24,18,24,22" />
  </Style>

  <Style Selector="controls|RibbonBackstage /template/ ListBox.office-ribbon-backstage-nav-list">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="10,0,10,0" />
  </Style>

  <Style Selector="controls|RibbonBackstage /template/ ListBox.office-ribbon-backstage-nav-list > ListBoxItem">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Margin" Value="1,1" />
    <Setter Property="Padding" Value="0" />
  </Style>

  <Style Selector="controls|RibbonBackstage /template/ ListBox.office-ribbon-backstage-nav-list > ListBoxItem:pointerover">
    <Setter Property="Background" Value="{DynamicResource RibbonOfficeCommandHoverBrush}" />
  </Style>

  <Style Selector="controls|RibbonBackstage /template/ ListBox.office-ribbon-backstage-nav-list > ListBoxItem:selected">
    <Setter Property="Background" Value="#E9EDF4" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>

  <Style Selector="controls|RibbonBackstage /template/ Border.office-ribbon-backstage-item">
    <Setter Property="MinHeight" Value="50" />
  </Style>

  <Style Selector="controls|RibbonBackstage /template/ TextBlock.office-ribbon-backstage-label">
    <Setter Property="FontSize" Value="19" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="Foreground" Value="{DynamicResource RibbonOfficeTextBrush}" />
  </Style>

  <Style Selector="controls|RibbonBackstage /template/ TextBlock.office-ribbon-backstage-description">
    <Setter Property="FontSize" Value="11" />
    <Setter Property="Opacity" Value="0.74" />
    <Setter Property="Foreground" Value="{DynamicResource RibbonOfficeMutedTextBrush}" />
  </Style>

  <Style Selector="controls|RibbonBackstage /template/ TextBlock.office-ribbon-backstage-gesture">
    <Setter Property="FontSize" Value="11" />
    <Setter Property="Opacity" Value="0.74" />
    <Setter Property="Foreground" Value="{DynamicResource RibbonOfficeMutedTextBrush}" />
  </Style>

  <Style Selector="controls|RibbonBackstage /template/ PathIcon.office-ribbon-backstage-chevron">
    <Setter Property="Foreground" Value="{DynamicResource RibbonOfficeMutedTextBrush}" />
  </Style>

  <Style Selector="controls|RibbonBackstage /template/ Separator.office-ribbon-backstage-separator">
    <Setter Property="Background" Value="{DynamicResource RibbonOfficeGroupSeparatorBrush}" />
    <Setter Property="Height" Value="1" />
    <Setter Property="Margin" Value="14,8" />
  </Style>

  <Style Selector="Button.office-ribbon-command">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource RibbonOfficeTextBrush}" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="3" />
    <Setter Property="Padding" Value="4,3" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>

  <Style Selector="ToggleButton.office-ribbon-command">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource RibbonOfficeTextBrush}" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="3" />
    <Setter Property="Padding" Value="4,3" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>

  <Style Selector="ToggleButton.office-ribbon-toggle">
    <Setter Property="Background" Value="{DynamicResource RibbonOfficeCommandSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="3" />
  </Style>

  <Style Selector="ToggleButton.office-ribbon-toggle:pointerover">
    <Setter Property="Background" Value="{DynamicResource RibbonOfficeCommandHoverBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource RibbonOfficeAccentBrush}" />
  </Style>

  <Style Selector="ToggleButton.office-ribbon-toggle:checked">
    <Setter Property="Background" Value="{DynamicResource RibbonOfficeCommandPressedBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource RibbonOfficeAccentBrush}" />
  </Style>

  <Style Selector="ToggleButton.office-ribbon-toggle-icon-only">
    <Setter Property="MinHeight" Value="36" />
    <Setter Property="MinWidth" Value="36" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="CornerRadius" Value="5" />
  </Style>

  <Style Selector="ToggleButton.office-ribbon-toggle-icon-only-small">
    <Setter Property="MinHeight" Value="30" />
    <Setter Property="MinWidth" Value="30" />
  </Style>

  <Style Selector="ToggleButton.office-ribbon-toggle-group-option">
    <Setter Property="Background" Value="{DynamicResource RibbonOfficeCommandSurfaceBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource RibbonOfficeTextBrush}" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="HorizontalContentAlignment" Value="Left" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>

  <Style Selector="ToggleButton.office-ribbon-toggle-group-option:pointerover">
    <Setter Property="Background" Value="{DynamicResource RibbonOfficeCommandHoverBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource RibbonOfficeAccentBrush}" />
  </Style>

  <Style Selector="ToggleButton.office-ribbon-toggle-group-option:checked">
    <Setter Property="Background" Value="{DynamicResource RibbonOfficeCommandPressedBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource RibbonOfficeAccentBrush}" />
  </Style>

  <Style Selector="ToggleButton.office-ribbon-toggle-group-option-large">
    <Setter Property="MinHeight" Value="32" />
    <Setter Property="MinWidth" Value="114" />
  </Style>

  <Style Selector="ToggleButton.office-ribbon-toggle-group-option-small">
    <Setter Property="MinHeight" Value="28" />
    <Setter Property="MinWidth" Value="98" />
  </Style>

  <Style Selector="RadioButton.office-ribbon-toggle-group-option">
    <Setter Property="Background" Value="{DynamicResource RibbonOfficeCommandSurfaceBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource RibbonOfficeTextBrush}" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="HorizontalContentAlignment" Value="Left" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="{TemplateBinding CornerRadius}">
          <ContentPresenter Margin="{TemplateBinding Padding}"
                            HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                            Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}" />
        </Border>
      </ControlTemplate>
    </Setter>
  </Style>

  <Style Selector="RadioButton.office-ribbon-toggle-group-option:pointerover">
    <Setter Property="Background" Value="{DynamicResource RibbonOfficeCommandHoverBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource RibbonOfficeAccentBrush}" />
  </Style>

  <Style Selector="RadioButton.office-ribbon-toggle-group-option:checked">
    <Setter Property="Background" Value="{DynamicResource RibbonOfficeCommandPressedBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource RibbonOfficeAccentBrush}" />
  </Style>

  <Style Selector="RadioButton.office-ribbon-toggle-group-option-large">
    <Setter Property="MinHeight" Value="32" />
    <Setter Property="MinWidth" Value="114" />
  </Style>

  <Style Selector="RadioButton.office-ribbon-toggle-group-option-small">
    <Setter Property="MinHeight" Value="28" />
    <Setter Property="MinWidth" Value="98" />
  </Style>

  <Style Selector="ComboBox.office-ribbon-combo">
    <Setter Property="Background" Value="{DynamicResource RibbonOfficeCommandSurfaceBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource RibbonOfficeTextBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource RibbonOfficeCommandBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="3" />
    <Setter Property="Padding" Value="6,2" />
    <Setter Property="MinHeight" Value="30" />
  </Style>

  <Style Selector="ComboBox.office-ribbon-combo:pointerover">
    <Setter Property="BorderBrush" Value="{DynamicResource RibbonOfficeAccentBrush}" />
  </Style>

  <Style Selector="ComboBox.office-ribbon-combo:focus-within">
    <Setter Property="BorderBrush" Value="{DynamicResource RibbonOfficeAccentBrush}" />
  </Style>

  <Style Selector="ComboBox.office-ribbon-combo-large">
    <Setter Property="MinWidth" Value="176" />
  </Style>

  <Style Selector="ComboBox.office-ribbon-combo-small">
    <Setter Property="MinWidth" Value="84" />
  </Style>

  <Style Selector="Button.office-ribbon-large">
    <Setter Property="MinHeight" Value="66" />
    <Setter Property="MinWidth" Value="84" />
    <Setter Property="Padding" Value="7,7" />
  </Style>

  <Style Selector="ToggleButton.office-ribbon-menu">
    <Setter Property="MinHeight" Value="66" />
    <Setter Property="MinWidth" Value="84" />
    <Setter Property="Padding" Value="7,7" />
  </Style>

  <Style Selector="Button.office-ribbon-small">
    <Setter Property="MinHeight" Value="26" />
    <Setter Property="MinWidth" Value="42" />
    <Setter Property="Padding" Value="4,2" />
  </Style>

  <Style Selector="Button.office-ribbon-icon-only">
    <Setter Property="MinHeight" Value="36" />
    <Setter Property="MinWidth" Value="36" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="CornerRadius" Value="5" />
  </Style>

  <Style Selector="Button.office-ribbon-icon-only-small">
    <Setter Property="MinHeight" Value="28" />
    <Setter Property="MinWidth" Value="28" />
  </Style>

  <Style Selector="ToggleButton.office-ribbon-dropdown-toggle">
    <Setter Property="Padding" Value="2" />
    <Setter Property="CornerRadius" Value="2" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <Style Selector="Button.office-ribbon-split-main">
    <Setter Property="CornerRadius" Value="3,0,0,3" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <Style Selector="Button.office-ribbon-split-main-small">
    <Setter Property="MinHeight" Value="28" />
    <Setter Property="MinWidth" Value="38" />
    <Setter Property="Padding" Value="3,2" />
  </Style>

  <Style Selector="Button.office-ribbon-split-main-icon-only">
    <Setter Property="Padding" Value="0" />
  </Style>

  <Style Selector="Border.office-ribbon-splitter-host">
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="1,0,0,0" />
    <Setter Property="Margin" Value="-1,0,0,0" />
    <Setter Property="VerticalAlignment" Value="Stretch" />
  </Style>

  <Style Selector="Button.office-ribbon-split-secondary">
    <Setter Property="CornerRadius" Value="0,3,3,0" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0,1,1,1" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="MinWidth" Value="24" />
    <Setter Property="VerticalAlignment" Value="Stretch" />
  </Style>

  <Style Selector="ToggleButton.office-ribbon-split-secondary">
    <Setter Property="CornerRadius" Value="0,3,3,0" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0,1,1,1" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="MinWidth" Value="24" />
    <Setter Property="VerticalAlignment" Value="Stretch" />
  </Style>

  <Style Selector="Button.office-ribbon-split-secondary PathIcon">
    <Setter Property="Foreground" Value="{DynamicResource RibbonOfficeMutedTextBrush}" />
  </Style>

  <Style Selector="Button.office-ribbon-split-secondary controls|RibbonIconPresenter">
    <Setter Property="Foreground" Value="{DynamicResource RibbonOfficeMutedTextBrush}" />
  </Style>

  <Style Selector="ToggleButton.office-ribbon-split-secondary PathIcon">
    <Setter Property="Foreground" Value="{DynamicResource RibbonOfficeMutedTextBrush}" />
  </Style>

  <Style Selector="ToggleButton.office-ribbon-split-secondary controls|RibbonIconPresenter">
    <Setter Property="Foreground" Value="{DynamicResource RibbonOfficeMutedTextBrush}" />
  </Style>

  <Style Selector="Button.office-ribbon-stacked-split-top">
    <Setter Property="CornerRadius" Value="3,3,0,0" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="1,1,1,0" />
    <Setter Property="MinHeight" Value="44" />
  </Style>

  <Style Selector="Button.office-ribbon-stacked-split-bottom">
    <Setter Property="CornerRadius" Value="0,0,3,3" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="MinHeight" Value="24" />
    <Setter Property="Padding" Value="6,2" />
  </Style>

  <Style Selector="ToggleButton.office-ribbon-stacked-split-bottom">
    <Setter Property="CornerRadius" Value="0,0,3,3" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="MinHeight" Value="24" />
    <Setter Property="Padding" Value="6,2" />
  </Style>

  <Style Selector="Button.office-ribbon-stacked-split-bottom-main">
    <Setter Property="CornerRadius" Value="0,0,0,3" />
    <Setter Property="BorderThickness" Value="1,1,0,1" />
  </Style>

  <Style Selector="ToggleButton.office-ribbon-stacked-split-bottom-toggle">
    <Setter Property="CornerRadius" Value="0,0,3,3" />
    <Setter Property="BorderThickness" Value="0,1,1,1" />
    <Setter Property="Padding" Value="0" />
  </Style>

  <Style Selector="controls|Ribbon ComboBox">
    <Setter Property="MinHeight" Value="28" />
    <Setter Property="Background" Value="{DynamicResource RibbonOfficeCommandSurfaceBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource RibbonOfficeTextBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource RibbonOfficeCommandBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="3" />
    <Setter Property="Padding" Value="6,2" />
  </Style>

  <Style Selector="controls|Ribbon ComboBox:pointerover">
    <Setter Property="BorderBrush" Value="{DynamicResource RibbonOfficeAccentBrush}" />
  </Style>

  <Style Selector="controls|Ribbon ComboBox:focus-within">
    <Setter Property="BorderBrush" Value="{DynamicResource RibbonOfficeAccentBrush}" />
  </Style>

  <Style Selector="Button.office-ribbon-command:pointerover">
    <Setter Property="Background" Value="{DynamicResource RibbonOfficeCommandHoverBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource RibbonOfficeCommandBorderBrush}" />
  </Style>

  <Style Selector="ToggleButton.office-ribbon-command:pointerover">
    <Setter Property="Background" Value="{DynamicResource RibbonOfficeCommandHoverBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource RibbonOfficeCommandBorderBrush}" />
  </Style>

  <Style Selector="Button.office-ribbon-command:pressed">
    <Setter Property="Background" Value="{DynamicResource RibbonOfficeCommandPressedBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource RibbonOfficeAccentBrush}" />
  </Style>

  <Style Selector="ToggleButton.office-ribbon-command:pressed">
    <Setter Property="Background" Value="{DynamicResource RibbonOfficeCommandPressedBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource RibbonOfficeAccentBrush}" />
  </Style>

  <Style Selector="ToggleButton.office-ribbon-command:checked">
    <Setter Property="Background" Value="{DynamicResource RibbonOfficeCommandPressedBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource RibbonOfficeAccentBrush}" />
  </Style>

  <Style Selector="Button.office-ribbon-command:disabled">
    <Setter Property="Opacity" Value="1" />
    <Setter Property="Foreground" Value="{DynamicResource RibbonOfficeCommandDisabledTextBrush}" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="ToggleButton.office-ribbon-command:disabled">
    <Setter Property="Opacity" Value="1" />
    <Setter Property="Foreground" Value="{DynamicResource RibbonOfficeCommandDisabledTextBrush}" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="Button.office-ribbon-command:disabled PathIcon">
    <Setter Property="Foreground" Value="{DynamicResource RibbonOfficeCommandDisabledTextBrush}" />
  </Style>

  <Style Selector="Button.office-ribbon-command:disabled controls|RibbonIconPresenter">
    <Setter Property="Foreground" Value="{DynamicResource RibbonOfficeCommandDisabledTextBrush}" />
  </Style>

  <Style Selector="ToggleButton.office-ribbon-command:disabled PathIcon">
    <Setter Property="Foreground" Value="{DynamicResource RibbonOfficeCommandDisabledTextBrush}" />
  </Style>

  <Style Selector="ToggleButton.office-ribbon-command:disabled controls|RibbonIconPresenter">
    <Setter Property="Foreground" Value="{DynamicResource RibbonOfficeCommandDisabledTextBrush}" />
  </Style>

  <Style Selector="Button.office-ribbon-file, controls|Ribbon /template/ Button#PART_BackstageButtonTop, controls|Ribbon /template/ Button#PART_BackstageButtonBottom">
    <Setter Property="Background" Value="{DynamicResource RibbonOfficeFileTabBrush}" />
    <Setter Property="Foreground" Value="White" />
    <Setter Property="BorderBrush" Value="{DynamicResource RibbonOfficeFileTabBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="2" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Padding" Value="12,4" />
  </Style>

  <Style Selector="Button.office-ribbon-file:pointerover, controls|Ribbon /template/ Button#PART_BackstageButtonTop:pointerover, controls|Ribbon /template/ Button#PART_BackstageButtonBottom:pointerover">
    <Setter Property="Opacity" Value="0.94" />
  </Style>

  <Style Selector="Button.office-ribbon-file:pressed, controls|Ribbon /template/ Button#PART_BackstageButtonTop:pressed, controls|Ribbon /template/ Button#PART_BackstageButtonBottom:pressed">
    <Setter Property="Opacity" Value="0.82" />
  </Style>

  <Style Selector="controls|Ribbon /template/ DockPanel#PART_TopBar">
    <Setter Property="MinHeight" Value="44" />
  </Style>

  <Style Selector="StackPanel.ribbon-topbar-shell">
    <Setter Property="Orientation" Value="Horizontal" />
    <Setter Property="Spacing" Value="10" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="Button.ribbon-topbar-launcher">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="Padding" Value="6" />
    <Setter Property="MinWidth" Value="32" />
    <Setter Property="MinHeight" Value="32" />
  </Style>

  <Style Selector="Button.ribbon-topbar-launcher:pointerover">
    <Setter Property="Background" Value="{DynamicResource RibbonOfficeCommandHoverBrush}" />
  </Style>

  <Style Selector="Border.ribbon-topbar-app-badge">
    <Setter Property="Background" Value="{DynamicResource RibbonOfficeAccentBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource RibbonOfficeAccentBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Padding" Value="5,3" />
    <Setter Property="MinWidth" Value="30" />
  </Style>

  <Style Selector="TextBlock.ribbon-topbar-app-badge-text">
    <Setter Property="Foreground" Value="White" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="TextBlock.ribbon-topbar-title">
    <Setter Property="FontSize" Value="15" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="PathIcon.ribbon-topbar-status">
    <Setter Property="Foreground" Value="#0FA958" />
    <Setter Property="Width" Value="16" />
    <Setter Property="Height" Value="16" />
  </Style>

  <Style Selector="TextBox.ribbon-topbar-search">
    <Setter Property="MinHeight" Value="36" />
    <Setter Property="MinWidth" Value="520" />
    <Setter Property="MaxWidth" Value="720" />
    <Setter Property="Background" Value="{DynamicResource RibbonOfficeCommandSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource RibbonOfficeBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="7" />
    <Setter Property="Padding" Value="12,0" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="Watermark" Value="Search for tools, help, and more (Option + Q)" />
  </Style>

  <Style Selector="Button.ribbon-header-action">
    <Setter Property="Background" Value="#F5F6F8" />
    <Setter Property="BorderBrush" Value="{DynamicResource RibbonOfficeBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="Padding" Value="10,4" />
    <Setter Property="MinWidth" Value="84" />
  </Style>

  <Style Selector="Button.ribbon-header-action:pointerover">
    <Setter Property="Background" Value="{DynamicResource RibbonOfficeCommandHoverBrush}" />
  </Style>

  <Style Selector="Button.ribbon-header-share">
    <Setter Property="Background" Value="{DynamicResource RibbonOfficeAccentBrush}" />
    <Setter Property="Foreground" Value="White" />
    <Setter Property="BorderBrush" Value="{DynamicResource RibbonOfficeAccentBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="Padding" Value="12,4" />
    <Setter Property="MinWidth" Value="76" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="Button.ribbon-header-share:pointerover">
    <Setter Property="Opacity" Value="0.94" />
  </Style>

  <Style Selector="ComboBox.ribbon-header-mode">
    <Setter Property="MinHeight" Value="30" />
  </Style>

  <Style Selector="Border.office-ribbon-group">
    <Setter Property="BorderBrush" Value="{DynamicResource RibbonOfficeGroupSeparatorBrush}" />
    <Setter Property="BorderThickness" Value="0,0,1,0" />
    <Setter Property="Padding" Value="12,6,12,5" />
    <Setter Property="Margin" Value="0,1,0,1" />
  </Style>

  <Style Selector="ToggleButton.office-ribbon-group-collapsed">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{DynamicResource RibbonOfficeGroupSeparatorBrush}" />
    <Setter Property="BorderThickness" Value="0,0,1,0" />
    <Setter Property="CornerRadius" Value="2" />
    <Setter Property="Padding" Value="6" />
    <Setter Property="Margin" Value="0,1,0,1" />
  </Style>

  <Style Selector="ToggleButton.office-ribbon-group-collapsed:pointerover">
    <Setter Property="Background" Value="{DynamicResource RibbonOfficeCommandHoverBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource RibbonOfficeAccentBrush}" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <Style Selector="ToggleButton.office-ribbon-group-collapsed:checked">
    <Setter Property="Background" Value="{DynamicResource RibbonOfficeCommandPressedBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource RibbonOfficeAccentBrush}" />
