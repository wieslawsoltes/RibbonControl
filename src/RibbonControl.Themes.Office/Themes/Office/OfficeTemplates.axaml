<ResourceDictionary xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:RibbonControl.Core.Controls"
        xmlns:icons="using:RibbonControl.Core.Icons"
        xmlns:models="using:RibbonControl.Core.Models">
<DataTemplate x:Key="OfficeRibbonTabHeaderTemplate" DataType="models:RibbonTab">
      <StackPanel Spacing="2"
                  Margin="6,2,6,1">
        <Border Height="2"
                CornerRadius="1"
                IsVisible="{CompiledBinding IsContextual}"
                Background="{CompiledBinding ContextGroupAccentColor, TargetNullValue={DynamicResource RibbonOfficeAccentBrush}}" />
        <TextBlock Text="{CompiledBinding Header}"
                   Tag="{CompiledBinding Id, StringFormat='tab:{0}'}"
                   AutomationProperties.Name="{CompiledBinding Header}"
                   AutomationProperties.AutomationId="{CompiledBinding Id, StringFormat='Ribbon.Tab.{0}'}"
                   Margin="1,1,1,1"
                   FontSize="12"
                   Foreground="{CompiledBinding ContextGroupAccentColor, TargetNullValue={DynamicResource RibbonOfficeTextBrush}}" />
      </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="OfficeRibbonBackstageNavigationItemTemplate" DataType="models:RibbonBackstageItem">
      <Grid IsVisible="{CompiledBinding IsVisible}">
        <Separator Classes="office-ribbon-backstage-separator"
                   IsVisible="{CompiledBinding IsSeparator}" />
        <Border Classes="office-ribbon-backstage-item"
                IsVisible="{CompiledBinding IsActionItem}"
                IsEnabled="{CompiledBinding IsEnabled}"
                Padding="14,8">
          <Grid ColumnDefinitions="Auto,*,Auto,Auto"
                ColumnSpacing="12">
            <controls:RibbonIconPresenter Grid.Column="0"
                        Icon="{CompiledBinding Icon}"
                        IconResourceKey="{CompiledBinding IconResourceKey}"
                        IconPathData="{CompiledBinding IconPathData}"
                        IconEmoji="{CompiledBinding IconEmoji}"
                        IconStretch="{CompiledBinding IconStretch}"
                        IconStretchDirection="{CompiledBinding IconStretchDirection}"
                        IconWidth="{CompiledBinding IconWidth}"
                        IconHeight="{CompiledBinding IconHeight}"
                        IconMinWidth="{CompiledBinding IconMinWidth}"
                        IconMinHeight="{CompiledBinding IconMinHeight}"
                        IconMaxWidth="{CompiledBinding IconMaxWidth}"
                        IconMaxHeight="{CompiledBinding IconMaxHeight}"
                        Width="22"
                        Height="22"
                        IsVisible="{CompiledBinding HasIcon}" />
            <StackPanel Grid.Column="1"
                        Spacing="2"
                        VerticalAlignment="Center">
              <TextBlock Classes="office-ribbon-backstage-label"
                         Text="{CompiledBinding Label}" />
              <TextBlock Classes="office-ribbon-backstage-description"
                         Text="{CompiledBinding Description}"
                         IsVisible="{CompiledBinding HasDescription}" />
            </StackPanel>
            <TextBlock Grid.Column="2"
                       Classes="office-ribbon-backstage-gesture"
                       Text="{CompiledBinding InputGestureText}"
                       VerticalAlignment="Center"
                       IsVisible="{CompiledBinding HasInputGestureText}" />
            <PathIcon Grid.Column="3"
                      Classes="office-ribbon-backstage-chevron"
                      Data="{x:Static icons:FluentIconData.ChevronRight20Regular}"
                      Width="14"
                      Height="14"
                      VerticalAlignment="Center"
                      IsVisible="{CompiledBinding ShowsChevronGlyph}" />
          </Grid>
        </Border>
      </Grid>
    </DataTemplate>

    <DataTemplate x:Key="OfficeRibbonMenuItemTemplate" DataType="models:RibbonMenuItem">
      <Grid Classes="office-ribbon-menu-item-host">
        <Separator Classes="office-ribbon-separator office-ribbon-menu-separator"
                   IsVisible="{CompiledBinding IsSeparator}" />
        <Button Classes="office-ribbon-command office-ribbon-menu-item office-ribbon-popup-command"
                HorizontalContentAlignment="Stretch"
                IsVisible="{CompiledBinding IsCommand}"
                Command="{CompiledBinding Command}"
                CommandParameter="{CompiledBinding CommandParameter}"
                Tag="{CompiledBinding Id}"
                ToolTip.Tip="{CompiledBinding ScreenTip}"
                AutomationProperties.Name="{CompiledBinding Label}"
                AutomationProperties.AutomationId="{CompiledBinding Id, StringFormat='Ribbon.MenuItem.{0}'}">
          <Grid>
            <ContentPresenter Content="{CompiledBinding Content}"
                              IsVisible="{CompiledBinding HasContent}" />
            <Grid Classes="office-ribbon-menu-item-layout"
                  ColumnDefinitions="22,*,Auto,Auto"
                  IsVisible="{CompiledBinding HasNoContent}">
              <controls:RibbonIconPresenter Grid.Column="0"
                        Classes="office-ribbon-menu-item-icon"
                        Icon="{CompiledBinding Icon}"
                        IconResourceKey="{CompiledBinding IconResourceKey}"
                        IconPathData="{CompiledBinding IconPathData}"
                        IconEmoji="{CompiledBinding IconEmoji}"
                        IconStretch="{CompiledBinding IconStretch}"
                        IconStretchDirection="{CompiledBinding IconStretchDirection}"
                        IconWidth="{CompiledBinding IconWidth}"
                        IconHeight="{CompiledBinding IconHeight}"
                        IconMinWidth="{CompiledBinding IconMinWidth}"
                        IconMinHeight="{CompiledBinding IconMinHeight}"
                        IconMaxWidth="{CompiledBinding IconMaxWidth}"
                        IconMaxHeight="{CompiledBinding IconMaxHeight}"
                        Overlay="{CompiledBinding Overlay}"
                        OverlayResourceKey="{CompiledBinding OverlayResourceKey}"
                        OverlayPathData="{CompiledBinding OverlayPathData}"
                        OverlayEmoji="{CompiledBinding OverlayEmoji}"
                        OverlayCount="{CompiledBinding OverlayCount}"
                        OverlayCountText="{CompiledBinding OverlayCountText}"
                        ShowOverlayCountWhenZero="{CompiledBinding ShowOverlayCountWhenZero}"
                        OverlayHorizontalAlignment="{CompiledBinding OverlayHorizontalAlignment}"
                        OverlayVerticalAlignment="{CompiledBinding OverlayVerticalAlignment}"
                        OverlayMargin="{CompiledBinding OverlayMargin}"
                        OverlayCountHorizontalAlignment="{CompiledBinding OverlayCountHorizontalAlignment}"
                        OverlayCountVerticalAlignment="{CompiledBinding OverlayCountVerticalAlignment}"
                        OverlayCountMargin="{CompiledBinding OverlayCountMargin}" />
              <StackPanel Grid.Column="1"
                          Classes="office-ribbon-menu-item-text">
                <TextBlock Classes="office-ribbon-menu-item-label"
                           Text="{CompiledBinding Label}" />
                <TextBlock Classes="office-ribbon-menu-item-description"
                           Text="{CompiledBinding Description}"
                           IsVisible="{CompiledBinding HasDescription}" />
              </StackPanel>
              <TextBlock Grid.Column="2"
                         Classes="office-ribbon-menu-item-gesture"
                         Text="{CompiledBinding InputGestureText}"
                         IsVisible="{CompiledBinding HasInputGestureText}" />
              <Border Grid.Column="3"
                      Classes="office-ribbon-menu-item-chevron-host"
                      IsVisible="{CompiledBinding ShowsChevronGlyph}">
                <PathIcon Classes="office-ribbon-menu-item-chevron"
                          Data="{x:Static icons:FluentIconData.ChevronRight20Regular}"
                          VerticalAlignment="Center" />
              </Border>
            </Grid>
          </Grid>
        </Button>

        <ToggleButton x:Name="PART_OfficeSubMenuToggle"
                      Classes="office-ribbon-command office-ribbon-menu-item office-ribbon-popup-command"
                      HorizontalContentAlignment="Stretch"
                      IsVisible="{CompiledBinding HasSubMenuItems}"
                      IsChecked="{CompiledBinding IsSubMenuOpen, Mode=TwoWay}"
                      Tag="{CompiledBinding Id, StringFormat='submenu:{0}'}"
                      ToolTip.Tip="{CompiledBinding ScreenTip}"
                      AutomationProperties.Name="{CompiledBinding Label}"
                      AutomationProperties.AutomationId="{CompiledBinding Id, StringFormat='Ribbon.MenuItem.SubMenu.{0}'}">
          <Grid>
            <ContentPresenter Content="{CompiledBinding Content}"
                              IsVisible="{CompiledBinding HasContent}" />
            <Grid Classes="office-ribbon-menu-item-layout"
                  ColumnDefinitions="22,*,Auto,Auto"
                  IsVisible="{CompiledBinding HasNoContent}">
              <controls:RibbonIconPresenter Grid.Column="0"
                        Classes="office-ribbon-menu-item-icon"
                        Icon="{CompiledBinding Icon}"
                        IconResourceKey="{CompiledBinding IconResourceKey}"
                        IconPathData="{CompiledBinding IconPathData}"
                        IconEmoji="{CompiledBinding IconEmoji}"
                        IconStretch="{CompiledBinding IconStretch}"
                        IconStretchDirection="{CompiledBinding IconStretchDirection}"
                        IconWidth="{CompiledBinding IconWidth}"
                        IconHeight="{CompiledBinding IconHeight}"
                        IconMinWidth="{CompiledBinding IconMinWidth}"
                        IconMinHeight="{CompiledBinding IconMinHeight}"
                        IconMaxWidth="{CompiledBinding IconMaxWidth}"
                        IconMaxHeight="{CompiledBinding IconMaxHeight}"
                        Overlay="{CompiledBinding Overlay}"
                        OverlayResourceKey="{CompiledBinding OverlayResourceKey}"
                        OverlayPathData="{CompiledBinding OverlayPathData}"
                        OverlayEmoji="{CompiledBinding OverlayEmoji}"
                        OverlayCount="{CompiledBinding OverlayCount}"
                        OverlayCountText="{CompiledBinding OverlayCountText}"
                        ShowOverlayCountWhenZero="{CompiledBinding ShowOverlayCountWhenZero}"
                        OverlayHorizontalAlignment="{CompiledBinding OverlayHorizontalAlignment}"
                        OverlayVerticalAlignment="{CompiledBinding OverlayVerticalAlignment}"
                        OverlayMargin="{CompiledBinding OverlayMargin}"
                        OverlayCountHorizontalAlignment="{CompiledBinding OverlayCountHorizontalAlignment}"
                        OverlayCountVerticalAlignment="{CompiledBinding OverlayCountVerticalAlignment}"
                        OverlayCountMargin="{CompiledBinding OverlayCountMargin}" />
              <StackPanel Grid.Column="1"
                          Classes="office-ribbon-menu-item-text">
                <TextBlock Classes="office-ribbon-menu-item-label"
                           Text="{CompiledBinding Label}" />
                <TextBlock Classes="office-ribbon-menu-item-description"
                           Text="{CompiledBinding Description}"
                           IsVisible="{CompiledBinding HasDescription}" />
              </StackPanel>
              <TextBlock Grid.Column="2"
                         Classes="office-ribbon-menu-item-gesture"
                         Text="{CompiledBinding InputGestureText}"
                         IsVisible="{CompiledBinding HasInputGestureText}" />
              <Border Grid.Column="3"
                      Classes="office-ribbon-menu-item-chevron-host">
                <PathIcon Classes="office-ribbon-menu-item-chevron"
                          Data="{x:Static icons:FluentIconData.ChevronRight20Regular}"
                          VerticalAlignment="Center" />
              </Border>
            </Grid>
          </Grid>
        </ToggleButton>

        <Popup IsOpen="{CompiledBinding IsSubMenuOpen, Mode=TwoWay}"
               IsLightDismissEnabled="True"
               Placement="RightEdgeAlignedTop"
               PlacementTarget="{Binding #PART_OfficeSubMenuToggle}">
          <Border Classes="office-ribbon-popup-surface office-ribbon-menu-popup office-ribbon-submenu-popup"
                  Background="{DynamicResource RibbonOfficeMenuSurfaceBrush}"
                  BorderBrush="{DynamicResource RibbonOfficePopupBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="3"
                  MaxHeight="460">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
              <ItemsControl ItemsSource="{CompiledBinding SubMenuItems}"
                            ItemTemplate="{StaticResource OfficeRibbonMenuItemTemplate}" />
            </ScrollViewer>
          </Border>
        </Popup>
      </Grid>
    </DataTemplate>

    <DataTemplate x:Key="OfficeRibbonGalleryItemTemplate" DataType="models:RibbonMenuItem">
      <ToggleButton Classes="office-ribbon-command office-ribbon-gallery-item"
                    MinWidth="108"
                    Margin="2"
                    Padding="6,4"
                    IsChecked="{CompiledBinding IsSelected, Mode=TwoWay}"
                    Command="{CompiledBinding Command}"
                    CommandParameter="{CompiledBinding CommandParameter}"
                    Tag="{CompiledBinding Id, StringFormat='gallery:{0}'}"
                    ToolTip.Tip="{CompiledBinding ScreenTip}"
                    AutomationProperties.Name="{CompiledBinding Label}"
                    AutomationProperties.AutomationId="{CompiledBinding Id, StringFormat='Ribbon.GalleryItem.{0}'}">
        <Grid>
          <ContentPresenter Content="{CompiledBinding Content}"
                            IsVisible="{CompiledBinding HasContent}" />
          <StackPanel Orientation="Vertical"
                      HorizontalAlignment="Center"
                      Spacing="4"
                      IsVisible="{CompiledBinding HasNoContent}">
            <controls:RibbonIconPresenter Icon="{CompiledBinding Icon}"
                        IconResourceKey="{CompiledBinding IconResourceKey}"
                        IconPathData="{CompiledBinding IconPathData}"
                        IconEmoji="{CompiledBinding IconEmoji}"
                        IconStretch="{CompiledBinding IconStretch}"
                        IconStretchDirection="{CompiledBinding IconStretchDirection}"
                        IconWidth="{CompiledBinding IconWidth}"
                        IconHeight="{CompiledBinding IconHeight}"
                        IconMinWidth="{CompiledBinding IconMinWidth}"
                        IconMinHeight="{CompiledBinding IconMinHeight}"
                        IconMaxWidth="{CompiledBinding IconMaxWidth}"
                        IconMaxHeight="{CompiledBinding IconMaxHeight}"
                        Overlay="{CompiledBinding Overlay}"
                        OverlayResourceKey="{CompiledBinding OverlayResourceKey}"
                        OverlayPathData="{CompiledBinding OverlayPathData}"
                        OverlayEmoji="{CompiledBinding OverlayEmoji}"
                        OverlayCount="{CompiledBinding OverlayCount}"
                        OverlayCountText="{CompiledBinding OverlayCountText}"
                        ShowOverlayCountWhenZero="{CompiledBinding ShowOverlayCountWhenZero}"
                        OverlayHorizontalAlignment="{CompiledBinding OverlayHorizontalAlignment}"
                        OverlayVerticalAlignment="{CompiledBinding OverlayVerticalAlignment}"
                        OverlayMargin="{CompiledBinding OverlayMargin}"
                        OverlayCountHorizontalAlignment="{CompiledBinding OverlayCountHorizontalAlignment}"
                        OverlayCountVerticalAlignment="{CompiledBinding OverlayCountVerticalAlignment}"
                        OverlayCountMargin="{CompiledBinding OverlayCountMargin}"
                      Width="16"
                      Height="16" />
            <TextBlock Text="{CompiledBinding Label}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       FontSize="11" />
          </StackPanel>
        </Grid>
      </ToggleButton>
    </DataTemplate>

    <DataTemplate x:Key="OfficeRibbonGalleryPreviewItemTemplate" DataType="models:RibbonMenuItem">
      <ToggleButton Classes="office-ribbon-command office-ribbon-gallery-preview-item"
                    IsChecked="{CompiledBinding IsSelected, Mode=TwoWay}"
                    Command="{CompiledBinding Command}"
                    CommandParameter="{CompiledBinding CommandParameter}"
                    Tag="{CompiledBinding Id, StringFormat='gallery-preview:{0}'}"
                    ToolTip.Tip="{CompiledBinding ScreenTip}"
                    AutomationProperties.Name="{CompiledBinding Label}"
                    AutomationProperties.AutomationId="{CompiledBinding Id, StringFormat='Ribbon.GalleryPreviewItem.{0}'}">
        <Grid>
          <ContentPresenter Content="{CompiledBinding Content}"
                            IsVisible="{CompiledBinding HasContent}" />
          <StackPanel Orientation="Vertical"
                      HorizontalAlignment="Center"
                      Spacing="4"
                      IsVisible="{CompiledBinding HasNoContent}">
            <controls:RibbonIconPresenter Icon="{CompiledBinding Icon}"
                        IconResourceKey="{CompiledBinding IconResourceKey}"
                        IconPathData="{CompiledBinding IconPathData}"
                        IconEmoji="{CompiledBinding IconEmoji}"
                        IconStretch="{CompiledBinding IconStretch}"
                        IconStretchDirection="{CompiledBinding IconStretchDirection}"
                        IconWidth="{CompiledBinding IconWidth}"
                        IconHeight="{CompiledBinding IconHeight}"
                        IconMinWidth="{CompiledBinding IconMinWidth}"
                        IconMinHeight="{CompiledBinding IconMinHeight}"
                        IconMaxWidth="{CompiledBinding IconMaxWidth}"
                        IconMaxHeight="{CompiledBinding IconMaxHeight}"
                        Overlay="{CompiledBinding Overlay}"
                        OverlayResourceKey="{CompiledBinding OverlayResourceKey}"
                        OverlayPathData="{CompiledBinding OverlayPathData}"
                        OverlayEmoji="{CompiledBinding OverlayEmoji}"
                        OverlayCount="{CompiledBinding OverlayCount}"
                        OverlayCountText="{CompiledBinding OverlayCountText}"
                        ShowOverlayCountWhenZero="{CompiledBinding ShowOverlayCountWhenZero}"
                        OverlayHorizontalAlignment="{CompiledBinding OverlayHorizontalAlignment}"
                        OverlayVerticalAlignment="{CompiledBinding OverlayVerticalAlignment}"
                        OverlayMargin="{CompiledBinding OverlayMargin}"
                        OverlayCountHorizontalAlignment="{CompiledBinding OverlayCountHorizontalAlignment}"
                        OverlayCountVerticalAlignment="{CompiledBinding OverlayCountVerticalAlignment}"
                        OverlayCountMargin="{CompiledBinding OverlayCountMargin}"
                      Width="16"
                      Height="16" />
            <TextBlock Text="{CompiledBinding Label}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       FontSize="11" />
          </StackPanel>
        </Grid>
      </ToggleButton>
    </DataTemplate>

    <DataTemplate x:Key="OfficeRibbonToggleGroupOptionLargeTemplate" DataType="models:RibbonMenuItem">
      <ToggleButton Classes="office-ribbon-command office-ribbon-toggle-group-option office-ribbon-toggle-group-option-large ribbon-command"
                    MinWidth="114"
                    Margin="2"
                    Padding="9,5"
                    HorizontalContentAlignment="Left"
                    IsChecked="{CompiledBinding IsSelected, Mode=TwoWay}"
                    Command="{CompiledBinding Command}"
                    CommandParameter="{CompiledBinding CommandParameter}"
                    Tag="{CompiledBinding Id, StringFormat='toggle-group-option:{0}'}"
                    ToolTip.Tip="{CompiledBinding ScreenTip}"
                    AutomationProperties.Name="{CompiledBinding Label}"
                    AutomationProperties.AutomationId="{CompiledBinding Id, StringFormat='Ribbon.ToggleGroupOption.{0}'}">
        <Grid>
          <ContentPresenter Content="{CompiledBinding Content}"
                            IsVisible="{CompiledBinding HasContent}" />
          <StackPanel Orientation="Horizontal"
                      Spacing="7"
                      VerticalAlignment="Center"
                      IsVisible="{CompiledBinding HasNoContent}">
            <controls:RibbonIconPresenter Icon="{CompiledBinding Icon}"
                        IconResourceKey="{CompiledBinding IconResourceKey}"
                        IconPathData="{CompiledBinding IconPathData}"
                        IconEmoji="{CompiledBinding IconEmoji}"
                        IconStretch="{CompiledBinding IconStretch}"
                        IconStretchDirection="{CompiledBinding IconStretchDirection}"
                        IconWidth="{CompiledBinding IconWidth}"
                        IconHeight="{CompiledBinding IconHeight}"
                        IconMinWidth="{CompiledBinding IconMinWidth}"
                        IconMinHeight="{CompiledBinding IconMinHeight}"
                        IconMaxWidth="{CompiledBinding IconMaxWidth}"
                        IconMaxHeight="{CompiledBinding IconMaxHeight}"
                        Overlay="{CompiledBinding Overlay}"
                        OverlayResourceKey="{CompiledBinding OverlayResourceKey}"
                        OverlayPathData="{CompiledBinding OverlayPathData}"
                        OverlayEmoji="{CompiledBinding OverlayEmoji}"
                        OverlayCount="{CompiledBinding OverlayCount}"
                        OverlayCountText="{CompiledBinding OverlayCountText}"
                        ShowOverlayCountWhenZero="{CompiledBinding ShowOverlayCountWhenZero}"
                        OverlayHorizontalAlignment="{CompiledBinding OverlayHorizontalAlignment}"
                        OverlayVerticalAlignment="{CompiledBinding OverlayVerticalAlignment}"
                        OverlayMargin="{CompiledBinding OverlayMargin}"
                        OverlayCountHorizontalAlignment="{CompiledBinding OverlayCountHorizontalAlignment}"
                        OverlayCountVerticalAlignment="{CompiledBinding OverlayCountVerticalAlignment}"
                        OverlayCountMargin="{CompiledBinding OverlayCountMargin}"
                      Width="16"
                      Height="16"
                      IsVisible="{CompiledBinding HasIcon}" />
            <TextBlock Text="{CompiledBinding Label}"
                       VerticalAlignment="Center"
                       FontSize="11.5" />
          </StackPanel>
        </Grid>
      </ToggleButton>
    </DataTemplate>

    <DataTemplate x:Key="OfficeRibbonToggleGroupOptionSmallTemplate" DataType="models:RibbonMenuItem">
      <ToggleButton Classes="office-ribbon-command office-ribbon-toggle-group-option office-ribbon-toggle-group-option-small ribbon-command"
                    MinWidth="98"
                    Margin="2"
                    Padding="7,4"
                    HorizontalContentAlignment="Left"
                    IsChecked="{CompiledBinding IsSelected, Mode=TwoWay}"
                    Command="{CompiledBinding Command}"
                    CommandParameter="{CompiledBinding CommandParameter}"
                    Tag="{CompiledBinding Id, StringFormat='toggle-group-option-small:{0}'}"
                    ToolTip.Tip="{CompiledBinding ScreenTip}"
                    AutomationProperties.Name="{CompiledBinding Label}"
                    AutomationProperties.AutomationId="{CompiledBinding Id, StringFormat='Ribbon.ToggleGroupOption.Small.{0}'}">
        <Grid>
          <ContentPresenter Content="{CompiledBinding Content}"
                            IsVisible="{CompiledBinding HasContent}" />
          <StackPanel Orientation="Horizontal"
                      Spacing="6"
                      VerticalAlignment="Center"
                      IsVisible="{CompiledBinding HasNoContent}">
            <controls:RibbonIconPresenter Icon="{CompiledBinding Icon}"
                        IconResourceKey="{CompiledBinding IconResourceKey}"
                        IconPathData="{CompiledBinding IconPathData}"
                        IconEmoji="{CompiledBinding IconEmoji}"
                        IconStretch="{CompiledBinding IconStretch}"
                        IconStretchDirection="{CompiledBinding IconStretchDirection}"
                        IconWidth="{CompiledBinding IconWidth}"
                        IconHeight="{CompiledBinding IconHeight}"
                        IconMinWidth="{CompiledBinding IconMinWidth}"
                        IconMinHeight="{CompiledBinding IconMinHeight}"
                        IconMaxWidth="{CompiledBinding IconMaxWidth}"
                        IconMaxHeight="{CompiledBinding IconMaxHeight}"
                        Overlay="{CompiledBinding Overlay}"
                        OverlayResourceKey="{CompiledBinding OverlayResourceKey}"
                        OverlayPathData="{CompiledBinding OverlayPathData}"
                        OverlayEmoji="{CompiledBinding OverlayEmoji}"
                        OverlayCount="{CompiledBinding OverlayCount}"
                        OverlayCountText="{CompiledBinding OverlayCountText}"
                        ShowOverlayCountWhenZero="{CompiledBinding ShowOverlayCountWhenZero}"
                        OverlayHorizontalAlignment="{CompiledBinding OverlayHorizontalAlignment}"
                        OverlayVerticalAlignment="{CompiledBinding OverlayVerticalAlignment}"
                        OverlayMargin="{CompiledBinding OverlayMargin}"
                        OverlayCountHorizontalAlignment="{CompiledBinding OverlayCountHorizontalAlignment}"
                        OverlayCountVerticalAlignment="{CompiledBinding OverlayCountVerticalAlignment}"
                        OverlayCountMargin="{CompiledBinding OverlayCountMargin}"
                      Width="14"
                      Height="14"
                      IsVisible="{CompiledBinding HasIcon}" />
            <TextBlock Text="{CompiledBinding Label}"
                       VerticalAlignment="Center"
                       FontSize="10.5" />
          </StackPanel>
        </Grid>
      </ToggleButton>
    </DataTemplate>

