                    AutomationProperties.Name="{CompiledBinding Label}"
                    AutomationProperties.AutomationId="{CompiledBinding Id, StringFormat='Ribbon.Item.SplitMain.{0}'}">
              <StackPanel Orientation="Vertical"
                          HorizontalAlignment="Center"
                          Spacing="4">
                <controls:RibbonIconPresenter Icon="{CompiledBinding Icon}"
