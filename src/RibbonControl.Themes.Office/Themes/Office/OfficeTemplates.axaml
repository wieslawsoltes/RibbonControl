                        IconHeight="{CompiledBinding IconHeight}"
                        IconMinWidth="{CompiledBinding IconMinWidth}"
                        IconMinHeight="{CompiledBinding IconMinHeight}"
                        IconMaxWidth="{CompiledBinding IconMaxWidth}"
                        IconMaxHeight="{CompiledBinding IconMaxHeight}"
                        Overlay="{CompiledBinding Overlay}"
                        OverlayResourceKey="{CompiledBinding OverlayResourceKey}"
                        OverlayPathData="{CompiledBinding OverlayPathData}"
                        OverlayEmoji="{CompiledBinding OverlayEmoji}"
                        OverlayCount="{CompiledBinding OverlayCount}"
                        OverlayCountText="{CompiledBinding OverlayCountText}"
                        ShowOverlayCountWhenZero="{CompiledBinding ShowOverlayCountWhenZero}"
                        OverlayHorizontalAlignment="{CompiledBinding OverlayHorizontalAlignment}"
                        OverlayVerticalAlignment="{CompiledBinding OverlayVerticalAlignment}"
                        OverlayMargin="{CompiledBinding OverlayMargin}"
                        OverlayCountHorizontalAlignment="{CompiledBinding OverlayCountHorizontalAlignment}"
                        OverlayCountVerticalAlignment="{CompiledBinding OverlayCountVerticalAlignment}"
                        OverlayCountMargin="{CompiledBinding OverlayCountMargin}"
                      Width="32"
                      Height="32"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center" />
          </Button>
          <Grid Grid.Row="1">
            <Button Classes="office-ribbon-command office-ribbon-stacked-split-bottom ribbon-command"
                    MinWidth="82"
                    IsVisible="{CompiledBinding IsStackedSplitBottomCommandOnlyVisible}"
                    Command="{CompiledBinding SecondaryCommand}"
                    CommandParameter="{CompiledBinding SecondaryCommandParameter}"
                    Tag="{CompiledBinding Id, StringFormat='split-stacked-bottom-command:{0}'}"
                    ToolTip.Tip="{CompiledBinding ScreenTip}"
                    AutomationProperties.Name="{CompiledBinding Label, StringFormat='{}{0} Secondary Action'}"
                    AutomationProperties.AutomationId="{CompiledBinding Id, StringFormat='Ribbon.Item.StackedSplitBottomCommand.{0}'}">
              <TextBlock Text="{CompiledBinding Label}"
                         HorizontalAlignment="Center"
                         TextAlignment="Center"
                         FontSize="11" />
            </Button>
            <ToggleButton Classes="office-ribbon-command office-ribbon-stacked-split-bottom office-ribbon-dropdown-toggle ribbon-command"
                          MinWidth="82"
                          IsVisible="{CompiledBinding IsStackedSplitBottomDropDownOnlyVisible}"
                          IsChecked="{CompiledBinding IsDropDownOpen, Mode=TwoWay}"
                          Tag="{CompiledBinding Id, StringFormat='split-stacked-bottom-toggle:{0}'}"
                          ToolTip.Tip="{CompiledBinding ScreenTip}"
                          AutomationProperties.Name="{CompiledBinding Label, StringFormat='{}{0} Options'}"
                          AutomationProperties.AutomationId="{CompiledBinding Id, StringFormat='Ribbon.Item.StackedSplitBottomToggle.{0}'}">
              <DockPanel LastChildFill="False">
                <TextBlock Text="{CompiledBinding Label}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           FontSize="11" />
                <PathIcon Data="{x:Static icons:FluentIconData.ChevronDown20Regular}"
                          Margin="4,0,0,0"
                          Width="10"
                          Height="10"
                          VerticalAlignment="Center"
                          Foreground="{DynamicResource RibbonOfficeMutedTextBrush}" />
              </DockPanel>
            </ToggleButton>
            <Grid IsVisible="{CompiledBinding IsStackedSplitBottomSplitVisible}"
                  ColumnDefinitions="*,Auto">
              <Button Classes="office-ribbon-command office-ribbon-stacked-split-bottom office-ribbon-stacked-split-bottom-main ribbon-command"
                      Grid.Column="0"
                      Command="{CompiledBinding SecondaryCommand}"
                      CommandParameter="{CompiledBinding SecondaryCommandParameter}"
                      Tag="{CompiledBinding Id, StringFormat='split-stacked-bottom-main:{0}'}"
                      ToolTip.Tip="{CompiledBinding ScreenTip}"
                      AutomationProperties.Name="{CompiledBinding Label, StringFormat='{}{0} Secondary Action'}"
                      AutomationProperties.AutomationId="{CompiledBinding Id, StringFormat='Ribbon.Item.StackedSplitBottomMain.{0}'}">
                <TextBlock Text="{CompiledBinding Label}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           FontSize="11" />
              </Button>
              <ToggleButton Classes="office-ribbon-command office-ribbon-stacked-split-bottom office-ribbon-stacked-split-bottom-toggle office-ribbon-dropdown-toggle ribbon-command"
                            Grid.Column="1"
                            MinWidth="24"
                            IsChecked="{CompiledBinding IsDropDownOpen, Mode=TwoWay}"
                            Tag="{CompiledBinding Id, StringFormat='split-stacked-bottom-arrow:{0}'}"
                            ToolTip.Tip="{CompiledBinding ScreenTip}"
                            AutomationProperties.Name="{CompiledBinding Label, StringFormat='{}{0} Options'}"
                            AutomationProperties.AutomationId="{CompiledBinding Id, StringFormat='Ribbon.Item.StackedSplitBottomArrow.{0}'}">
                <PathIcon Data="{x:Static icons:FluentIconData.ChevronDown20Regular}"
                          Width="10"
                          Height="10"
                          Foreground="{DynamicResource RibbonOfficeMutedTextBrush}" />
              </ToggleButton>
            </Grid>
            <ToggleButton Classes="office-ribbon-command office-ribbon-stacked-split-bottom office-ribbon-dropdown-toggle ribbon-command"
                          MinWidth="82"
                          IsVisible="{CompiledBinding IsStackedSplitBottomFallbackVisible}"
                          IsEnabled="False"
                          ToolTip.Tip="{CompiledBinding ScreenTip}"
                          AutomationProperties.Name="{CompiledBinding Label, StringFormat='{}{0} Options'}"
                          AutomationProperties.AutomationId="{CompiledBinding Id, StringFormat='Ribbon.Item.StackedSplitBottomFallback.{0}'}">
              <DockPanel LastChildFill="False">
                <TextBlock Text="{CompiledBinding Label}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           FontSize="11" />
                <PathIcon Data="{x:Static icons:FluentIconData.ChevronDown20Regular}"
                          Margin="4,0,0,0"
                          Width="10"
                          Height="10"
                          VerticalAlignment="Center"
                          Foreground="{DynamicResource RibbonOfficeMutedTextBrush}" />
              </DockPanel>
            </ToggleButton>
          </Grid>
          <Popup IsOpen="{CompiledBinding IsStackedSplitDropDownOpen, Mode=TwoWay}"
                 IsLightDismissEnabled="True"
                 Placement="Bottom"
                 PlacementTarget="{Binding #PART_OfficeStackedSplitHost}">
            <Border Classes="office-ribbon-popup-surface office-ribbon-menu-popup"
                    Background="{DynamicResource RibbonOfficeMenuSurfaceBrush}"
                    BorderBrush="{DynamicResource RibbonOfficePopupBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="3"
                    MinWidth="{CompiledBinding PopupMinWidth}">
              <StackPanel Spacing="4">
                <TextBlock Text="{CompiledBinding PopupTitle}"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource RibbonOfficeTextBrush}"
                           IsVisible="{CompiledBinding HasPopupTitle}" />
                <ContentPresenter Content="{CompiledBinding PopupContent}"
                                  IsVisible="{CompiledBinding HasPopupContent}" />
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              MaxHeight="{CompiledBinding PopupMaxHeight}"
                              IsVisible="{CompiledBinding HasPopupMenuItems}">
                  <ItemsControl ItemsSource="{CompiledBinding PopupMenuItems}"
                                ItemTemplate="{StaticResource OfficeRibbonMenuItemTemplate}" />
                </ScrollViewer>
                <ContentPresenter Content="{CompiledBinding PopupFooterContent}"
                                  IsVisible="{CompiledBinding HasPopupFooterContent}" />
              </StackPanel>
            </Border>
          </Popup>
        </Grid>

        <Grid Grid.Row="3"
              IsVisible="{CompiledBinding IsMenuButtonPrimitive}">
          <ToggleButton x:Name="PART_OfficeMenuDropDownToggle"
                        Classes="office-ribbon-command office-ribbon-menu office-ribbon-dropdown-toggle ribbon-command ribbon-command-large"
                        MinWidth="82"
                        Padding="6,7"
                        IsChecked="{CompiledBinding IsDropDownOpen, Mode=TwoWay}"
                        Tag="{CompiledBinding Id}"
                        ToolTip.Tip="{CompiledBinding ScreenTip}"
                        AutomationProperties.Name="{CompiledBinding Label}"
                        AutomationProperties.AutomationId="{CompiledBinding Id, StringFormat='Ribbon.Item.Menu.{0}'}">
            <StackPanel Orientation="Vertical"
                        HorizontalAlignment="Center"
                        Spacing="2">
              <controls:RibbonIconPresenter Icon="{CompiledBinding Icon}"
                        IconResourceKey="{CompiledBinding IconResourceKey}"
                        IconPathData="{CompiledBinding IconPathData}"
                        IconEmoji="{CompiledBinding IconEmoji}"
                        IconStretch="{CompiledBinding IconStretch}"
                        IconStretchDirection="{CompiledBinding IconStretchDirection}"
                        IconWidth="{CompiledBinding IconWidth}"
                        IconHeight="{CompiledBinding IconHeight}"
                        IconMinWidth="{CompiledBinding IconMinWidth}"
                        IconMinHeight="{CompiledBinding IconMinHeight}"
                        IconMaxWidth="{CompiledBinding IconMaxWidth}"
                        IconMaxHeight="{CompiledBinding IconMaxHeight}"
                        Overlay="{CompiledBinding Overlay}"
                        OverlayResourceKey="{CompiledBinding OverlayResourceKey}"
                        OverlayPathData="{CompiledBinding OverlayPathData}"
                        OverlayEmoji="{CompiledBinding OverlayEmoji}"
                        OverlayCount="{CompiledBinding OverlayCount}"
                        OverlayCountText="{CompiledBinding OverlayCountText}"
                        ShowOverlayCountWhenZero="{CompiledBinding ShowOverlayCountWhenZero}"
                        OverlayHorizontalAlignment="{CompiledBinding OverlayHorizontalAlignment}"
                        OverlayVerticalAlignment="{CompiledBinding OverlayVerticalAlignment}"
                        OverlayMargin="{CompiledBinding OverlayMargin}"
                        OverlayCountHorizontalAlignment="{CompiledBinding OverlayCountHorizontalAlignment}"
                        OverlayCountVerticalAlignment="{CompiledBinding OverlayCountVerticalAlignment}"
                        OverlayCountMargin="{CompiledBinding OverlayCountMargin}"
                        Width="16"
                        Height="16" />
              <TextBlock Text="{CompiledBinding Label}"
                         HorizontalAlignment="Center"
                         TextAlignment="Center"
                         FontSize="11" />
              <PathIcon Data="{x:Static icons:FluentIconData.ChevronDown20Regular}"
                        Width="10"
                        Height="10"
                        HorizontalAlignment="Center"
                        Foreground="{DynamicResource RibbonOfficeMutedTextBrush}" />
            </StackPanel>
          </ToggleButton>
          <Popup IsOpen="{CompiledBinding IsMenuDropDownOpen, Mode=TwoWay}"
                 IsLightDismissEnabled="True"
                 Placement="Bottom"
                 PlacementTarget="{Binding #PART_OfficeMenuDropDownToggle}">
            <Border Classes="office-ribbon-popup-surface office-ribbon-menu-popup"
                    Background="{DynamicResource RibbonOfficeMenuSurfaceBrush}"
                    BorderBrush="{DynamicResource RibbonOfficePopupBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="3"
                    MinWidth="{CompiledBinding PopupMinWidth}">
              <StackPanel Spacing="4">
                <TextBlock Text="{CompiledBinding PopupTitle}"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource RibbonOfficeTextBrush}"
                           IsVisible="{CompiledBinding HasPopupTitle}" />
                <ContentPresenter Content="{CompiledBinding PopupContent}"
                                  IsVisible="{CompiledBinding HasPopupContent}" />
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              MaxHeight="{CompiledBinding PopupMaxHeight}"
                              IsVisible="{CompiledBinding HasPopupMenuItems}">
                  <ItemsControl ItemsSource="{CompiledBinding PopupMenuItems}"
                                ItemTemplate="{StaticResource OfficeRibbonMenuItemTemplate}" />
                </ScrollViewer>
                <ContentPresenter Content="{CompiledBinding PopupFooterContent}"
                                  IsVisible="{CompiledBinding HasPopupFooterContent}" />
              </StackPanel>
            </Border>
          </Popup>
        </Grid>

        <Border Grid.Row="4"
                Classes="office-ribbon-gallery"
                IsVisible="{CompiledBinding IsGalleryPrimitive}"
                MinWidth="172"
                Padding="0"
                Tag="{CompiledBinding Id}"
                ToolTip.Tip="{CompiledBinding ScreenTip}"
                AutomationProperties.Name="{CompiledBinding Label}"
                AutomationProperties.AutomationId="{CompiledBinding Id, StringFormat='Ribbon.Item.Gallery.{0}'}">
          <Grid ColumnDefinitions="*,Auto">
            <ItemsControl Grid.Column="0"
                          Margin="5,4,0,4"
                          ItemsSource="{CompiledBinding RibbonPreviewMenuItems}"
                          ItemTemplate="{StaticResource OfficeRibbonGalleryPreviewItemTemplate}"
                          IsVisible="{CompiledBinding HasRibbonPreviewMenuItems}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
            </ItemsControl>
            <ToggleButton x:Name="PART_OfficeGalleryDropDownToggle"
                            Grid.Column="1"
                            Classes="office-ribbon-command office-ribbon-gallery-split-toggle office-ribbon-dropdown-toggle"
                            IsChecked="{CompiledBinding IsDropDownOpen, Mode=TwoWay}">
                <PathIcon Data="{x:Static icons:FluentIconData.ChevronDown20Regular}"
                          Width="10"
                          Height="10"
                          Foreground="{DynamicResource RibbonOfficeMutedTextBrush}" />
            </ToggleButton>
            <Popup IsOpen="{CompiledBinding IsGalleryDropDownOpen, Mode=TwoWay}"
                   IsLightDismissEnabled="True"
                   Placement="Bottom"
                   PlacementTarget="{Binding #PART_OfficeGalleryDropDownToggle}">
              <Border Classes="office-ribbon-popup-surface office-ribbon-gallery-popup"
                      Background="{DynamicResource RibbonOfficeMenuSurfaceBrush}"
                      BorderBrush="{DynamicResource RibbonOfficePopupBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="3"
                      Padding="6"
                      MinWidth="{CompiledBinding PopupMinWidth}">
                <StackPanel Spacing="4">
                  <TextBlock Text="{CompiledBinding PopupTitle}"
                             FontSize="15"
                             FontWeight="SemiBold"
                             Foreground="{DynamicResource RibbonOfficeTextBrush}"
                             IsVisible="{CompiledBinding HasPopupTitle}" />
                  <TextBlock Text="{CompiledBinding Description}"
                             FontSize="10"
                             Foreground="{DynamicResource RibbonOfficeMutedTextBrush}"
                             IsVisible="{CompiledBinding HasDescription}" />
                  <ContentPresenter Content="{CompiledBinding PopupContent}"
                                    IsVisible="{CompiledBinding HasPopupContent}" />
                  <ScrollViewer VerticalScrollBarVisibility="Auto"
                                MaxHeight="{CompiledBinding PopupMaxHeight}"
                                IsVisible="{CompiledBinding ShowPopupMenuCategories}">
                    <ItemsControl ItemsSource="{CompiledBinding PopupMenuCategories}"
                                  ItemTemplate="{StaticResource OfficeRibbonGalleryCategoryTemplate}" />
                  </ScrollViewer>
                  <ScrollViewer VerticalScrollBarVisibility="Auto"
                                MaxHeight="{CompiledBinding PopupMaxHeight}"
                                IsVisible="{CompiledBinding ShowFlatCategorizedPopupMenuItems}">
                    <ItemsControl ItemsSource="{CompiledBinding CategorizedPopupMenuItems}"
                                  ItemTemplate="{StaticResource OfficeRibbonGalleryItemTemplate}">
                      <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                          <WrapPanel />
                        </ItemsPanelTemplate>
                      </ItemsControl.ItemsPanel>
                    </ItemsControl>
                  </ScrollViewer>
                  <Separator Classes="office-ribbon-separator"
                             IsVisible="{CompiledBinding ShowUncategorizedPopupMenuItems}" />
                  <ScrollViewer VerticalScrollBarVisibility="Auto"
                                MaxHeight="{CompiledBinding PopupMaxHeight}"
                                IsVisible="{CompiledBinding ShowUncategorizedPopupMenuItems}">
                    <ItemsControl ItemsSource="{CompiledBinding UncategorizedPopupMenuItems}"
                                  ItemTemplate="{StaticResource OfficeRibbonMenuItemTemplate}" />
                  </ScrollViewer>
                  <ScrollViewer VerticalScrollBarVisibility="Auto"
                                MaxHeight="{CompiledBinding PopupMaxHeight}"
                                IsVisible="{CompiledBinding ShowLegacyPopupMenuItems}">
                    <ItemsControl ItemsSource="{CompiledBinding PopupMenuItems}"
                                  ItemTemplate="{StaticResource OfficeRibbonMenuItemTemplate}" />
                  </ScrollViewer>
                  <ContentPresenter Content="{CompiledBinding PopupFooterContent}"
                                    IsVisible="{CompiledBinding HasPopupFooterContent}" />
                </StackPanel>
              </Border>
            </Popup>
          </Grid>
        </Border>

        <ToggleButton Classes="office-ribbon-command office-ribbon-toggle office-ribbon-toggle-large ribbon-command"
                      Grid.Row="5"
                      MinWidth="82"
                      MinHeight="62"
                      Padding="6,6"
                      IsVisible="{CompiledBinding IsEffectiveLargeToggleButtonPrimitive}"
                      IsChecked="{CompiledBinding IsChecked, Mode=TwoWay}"
                      Command="{CompiledBinding Command}"
                      CommandParameter="{CompiledBinding CommandParameter}"
                      Tag="{CompiledBinding Id, StringFormat='toggle:{0}'}"
                      ToolTip.Tip="{CompiledBinding ScreenTip}"
                      AutomationProperties.Name="{CompiledBinding Label}"
                      AutomationProperties.AutomationId="{CompiledBinding Id, StringFormat='Ribbon.Item.Toggle.{0}'}">
          <StackPanel Orientation="Vertical"
                      HorizontalAlignment="Center"
                      Spacing="4">
            <controls:RibbonIconPresenter Icon="{CompiledBinding Icon}"
                        IconResourceKey="{CompiledBinding IconResourceKey}"
                        IconPathData="{CompiledBinding IconPathData}"
                        IconEmoji="{CompiledBinding IconEmoji}"
                        IconStretch="{CompiledBinding IconStretch}"
                        IconStretchDirection="{CompiledBinding IconStretchDirection}"
                        IconWidth="{CompiledBinding IconWidth}"
                        IconHeight="{CompiledBinding IconHeight}"
                        IconMinWidth="{CompiledBinding IconMinWidth}"
                        IconMinHeight="{CompiledBinding IconMinHeight}"
                        IconMaxWidth="{CompiledBinding IconMaxWidth}"
                        IconMaxHeight="{CompiledBinding IconMaxHeight}"
                        Overlay="{CompiledBinding Overlay}"
                        OverlayResourceKey="{CompiledBinding OverlayResourceKey}"
                        OverlayPathData="{CompiledBinding OverlayPathData}"
                        OverlayEmoji="{CompiledBinding OverlayEmoji}"
                        OverlayCount="{CompiledBinding OverlayCount}"
                        OverlayCountText="{CompiledBinding OverlayCountText}"
                        ShowOverlayCountWhenZero="{CompiledBinding ShowOverlayCountWhenZero}"
                        OverlayHorizontalAlignment="{CompiledBinding OverlayHorizontalAlignment}"
                        OverlayVerticalAlignment="{CompiledBinding OverlayVerticalAlignment}"
                        OverlayMargin="{CompiledBinding OverlayMargin}"
                        OverlayCountHorizontalAlignment="{CompiledBinding OverlayCountHorizontalAlignment}"
                        OverlayCountVerticalAlignment="{CompiledBinding OverlayCountVerticalAlignment}"
                        OverlayCountMargin="{CompiledBinding OverlayCountMargin}"
                      Width="16"
                      Height="16"
                      IsVisible="{CompiledBinding HasIcon}" />
            <TextBlock Text="{CompiledBinding Label}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       FontSize="11" />
          </StackPanel>
        </ToggleButton>

        <ToggleButton Classes="office-ribbon-command office-ribbon-toggle office-ribbon-toggle-small ribbon-command"
                      Grid.Row="6"
                      MinWidth="44"
                      MinHeight="26"
                      Padding="4,2"
                      IsVisible="{CompiledBinding IsEffectiveSmallToggleButtonPrimitive}"
                      IsChecked="{CompiledBinding IsChecked, Mode=TwoWay}"
                      Command="{CompiledBinding Command}"
                      CommandParameter="{CompiledBinding CommandParameter}"
                      Tag="{CompiledBinding Id, StringFormat='toggle-small:{0}'}"
                      ToolTip.Tip="{CompiledBinding ScreenTip}"
                      AutomationProperties.Name="{CompiledBinding Label}"
                      AutomationProperties.AutomationId="{CompiledBinding Id, StringFormat='Ribbon.Item.Toggle.Small.{0}'}">
          <StackPanel Orientation="Horizontal"
                      Spacing="5"
                      VerticalAlignment="Center"
                      HorizontalAlignment="Center">
            <controls:RibbonIconPresenter Icon="{CompiledBinding Icon}"
                        IconResourceKey="{CompiledBinding IconResourceKey}"
                        IconPathData="{CompiledBinding IconPathData}"
                        IconEmoji="{CompiledBinding IconEmoji}"
                        IconStretch="{CompiledBinding IconStretch}"
                        IconStretchDirection="{CompiledBinding IconStretchDirection}"
                        IconWidth="{CompiledBinding IconWidth}"
                        IconHeight="{CompiledBinding IconHeight}"
                        IconMinWidth="{CompiledBinding IconMinWidth}"
                        IconMinHeight="{CompiledBinding IconMinHeight}"
                        IconMaxWidth="{CompiledBinding IconMaxWidth}"
                        IconMaxHeight="{CompiledBinding IconMaxHeight}"
                        Overlay="{CompiledBinding Overlay}"
                        OverlayResourceKey="{CompiledBinding OverlayResourceKey}"
                        OverlayPathData="{CompiledBinding OverlayPathData}"
                        OverlayEmoji="{CompiledBinding OverlayEmoji}"
                        OverlayCount="{CompiledBinding OverlayCount}"
                        OverlayCountText="{CompiledBinding OverlayCountText}"
                        ShowOverlayCountWhenZero="{CompiledBinding ShowOverlayCountWhenZero}"
                        OverlayHorizontalAlignment="{CompiledBinding OverlayHorizontalAlignment}"
                        OverlayVerticalAlignment="{CompiledBinding OverlayVerticalAlignment}"
                        OverlayMargin="{CompiledBinding OverlayMargin}"
                        OverlayCountHorizontalAlignment="{CompiledBinding OverlayCountHorizontalAlignment}"
                        OverlayCountVerticalAlignment="{CompiledBinding OverlayCountVerticalAlignment}"
                        OverlayCountMargin="{CompiledBinding OverlayCountMargin}"
                      Width="14"
                      Height="14"
                      IsVisible="{CompiledBinding HasIcon}" />
            <TextBlock Text="{CompiledBinding Label}"
                       FontSize="11" />
          </StackPanel>
        </ToggleButton>

        <ToggleButton Classes="office-ribbon-command office-ribbon-toggle office-ribbon-toggle-icon-only ribbon-command"
                      Grid.Row="12"
                      MinWidth="36"
                      MinHeight="36"
                      Padding="0"
                      IsVisible="{CompiledBinding IsEffectiveLargeIconOnlyToggleButtonPrimitive}"
                      IsChecked="{CompiledBinding IsChecked, Mode=TwoWay}"
                      Command="{CompiledBinding Command}"
                      CommandParameter="{CompiledBinding CommandParameter}"
                      Tag="{CompiledBinding Id, StringFormat='toggle-icononly:{0}'}"
                      ToolTip.Tip="{CompiledBinding ScreenTip}"
                      AutomationProperties.Name="{CompiledBinding Label}"
                      AutomationProperties.AutomationId="{CompiledBinding Id, StringFormat='Ribbon.Item.Toggle.IconOnly.{0}'}">
          <controls:RibbonIconPresenter Icon="{CompiledBinding Icon}"
                        IconResourceKey="{CompiledBinding IconResourceKey}"
                        IconPathData="{CompiledBinding IconPathData}"
                        IconEmoji="{CompiledBinding IconEmoji}"
                        IconStretch="{CompiledBinding IconStretch}"
                        IconStretchDirection="{CompiledBinding IconStretchDirection}"
                        IconWidth="{CompiledBinding IconWidth}"
                        IconHeight="{CompiledBinding IconHeight}"
                        IconMinWidth="{CompiledBinding IconMinWidth}"
                        IconMinHeight="{CompiledBinding IconMinHeight}"
                        IconMaxWidth="{CompiledBinding IconMaxWidth}"
                        IconMaxHeight="{CompiledBinding IconMaxHeight}"
                        Overlay="{CompiledBinding Overlay}"
                        OverlayResourceKey="{CompiledBinding OverlayResourceKey}"
                        OverlayPathData="{CompiledBinding OverlayPathData}"
                        OverlayEmoji="{CompiledBinding OverlayEmoji}"
                        OverlayCount="{CompiledBinding OverlayCount}"
                        OverlayCountText="{CompiledBinding OverlayCountText}"
                        ShowOverlayCountWhenZero="{CompiledBinding ShowOverlayCountWhenZero}"
                        OverlayHorizontalAlignment="{CompiledBinding OverlayHorizontalAlignment}"
                        OverlayVerticalAlignment="{CompiledBinding OverlayVerticalAlignment}"
                        OverlayMargin="{CompiledBinding OverlayMargin}"
                        OverlayCountHorizontalAlignment="{CompiledBinding OverlayCountHorizontalAlignment}"
                        OverlayCountVerticalAlignment="{CompiledBinding OverlayCountVerticalAlignment}"
                        OverlayCountMargin="{CompiledBinding OverlayCountMargin}"
                    Width="16"
                    Height="16"
                    IsVisible="{CompiledBinding HasIcon}" />
        </ToggleButton>

        <ToggleButton Classes="office-ribbon-command office-ribbon-toggle office-ribbon-toggle-icon-only office-ribbon-toggle-icon-only-small ribbon-command"
                      Grid.Row="13"
                      MinWidth="28"
                      MinHeight="28"
                      Padding="0"
                      IsVisible="{CompiledBinding IsEffectiveSmallIconOnlyToggleButtonPrimitive}"
                      IsChecked="{CompiledBinding IsChecked, Mode=TwoWay}"
                      Command="{CompiledBinding Command}"
                      CommandParameter="{CompiledBinding CommandParameter}"
                      Tag="{CompiledBinding Id, StringFormat='toggle-icononly-small:{0}'}"
                      ToolTip.Tip="{CompiledBinding ScreenTip}"
                      AutomationProperties.Name="{CompiledBinding Label}"
                      AutomationProperties.AutomationId="{CompiledBinding Id, StringFormat='Ribbon.Item.Toggle.IconOnly.Small.{0}'}">
          <controls:RibbonIconPresenter Icon="{CompiledBinding Icon}"
                        IconResourceKey="{CompiledBinding IconResourceKey}"
                        IconPathData="{CompiledBinding IconPathData}"
                        IconEmoji="{CompiledBinding IconEmoji}"
                        IconStretch="{CompiledBinding IconStretch}"
                        IconStretchDirection="{CompiledBinding IconStretchDirection}"
                        IconWidth="{CompiledBinding IconWidth}"
                        IconHeight="{CompiledBinding IconHeight}"
                        IconMinWidth="{CompiledBinding IconMinWidth}"
                        IconMinHeight="{CompiledBinding IconMinHeight}"
                        IconMaxWidth="{CompiledBinding IconMaxWidth}"
                        IconMaxHeight="{CompiledBinding IconMaxHeight}"
                        Overlay="{CompiledBinding Overlay}"
                        OverlayResourceKey="{CompiledBinding OverlayResourceKey}"
                        OverlayPathData="{CompiledBinding OverlayPathData}"
                        OverlayEmoji="{CompiledBinding OverlayEmoji}"
                        OverlayCount="{CompiledBinding OverlayCount}"
                        OverlayCountText="{CompiledBinding OverlayCountText}"
                        ShowOverlayCountWhenZero="{CompiledBinding ShowOverlayCountWhenZero}"
                        OverlayHorizontalAlignment="{CompiledBinding OverlayHorizontalAlignment}"
                        OverlayVerticalAlignment="{CompiledBinding OverlayVerticalAlignment}"
                        OverlayMargin="{CompiledBinding OverlayMargin}"
                        OverlayCountHorizontalAlignment="{CompiledBinding OverlayCountHorizontalAlignment}"
                        OverlayCountVerticalAlignment="{CompiledBinding OverlayCountVerticalAlignment}"
                        OverlayCountMargin="{CompiledBinding OverlayCountMargin}"
                    Width="14"
                    Height="14"
                    IsVisible="{CompiledBinding HasIcon}" />
        </ToggleButton>

        <ComboBox Classes="office-ribbon-combo office-ribbon-combo-large"
                  Grid.Row="7"
                  MinWidth="176"
                  IsVisible="{CompiledBinding IsEffectiveLargeComboBoxPrimitive}"
                  ItemsSource="{CompiledBinding ComboBoxMenuItems}"
                  ItemTemplate="{StaticResource OfficeRibbonComboBoxMenuItemTemplate}"
                  SelectedItem="{CompiledBinding SelectedComboBoxMenuItem, Mode=TwoWay}"
                  Tag="{CompiledBinding Id, StringFormat='combo:{0}'}"
                  ToolTip.Tip="{CompiledBinding ScreenTip}"
                  AutomationProperties.Name="{CompiledBinding Label}"
                  AutomationProperties.AutomationId="{CompiledBinding Id, StringFormat='Ribbon.Item.ComboBox.{0}'}" />

        <ComboBox Classes="office-ribbon-combo office-ribbon-combo-small"
                  Grid.Row="8"
                  MinWidth="84"
                  IsVisible="{CompiledBinding IsEffectiveSmallComboBoxPrimitive}"
                  ItemsSource="{CompiledBinding ComboBoxMenuItems}"
                  ItemTemplate="{StaticResource OfficeRibbonComboBoxMenuItemTemplate}"
                  SelectedItem="{CompiledBinding SelectedComboBoxMenuItem, Mode=TwoWay}"
                  Tag="{CompiledBinding Id, StringFormat='combo-small:{0}'}"
                  ToolTip.Tip="{CompiledBinding ScreenTip}"
                  AutomationProperties.Name="{CompiledBinding Label}"
                  AutomationProperties.AutomationId="{CompiledBinding Id, StringFormat='Ribbon.Item.ComboBox.Small.{0}'}" />

        <Border Grid.Row="14"
                Padding="2"
                IsVisible="{CompiledBinding IsEffectiveLargeToggleGroupPrimitive}"
                Tag="{CompiledBinding Id, StringFormat='toggle-group-large:{0}'}"
                ToolTip.Tip="{CompiledBinding ScreenTip}"
                AutomationProperties.Name="{CompiledBinding Label}"
                AutomationProperties.AutomationId="{CompiledBinding Id, StringFormat='Ribbon.Item.ToggleGroup.{0}'}">
          <Grid>
            <ItemsControl ItemsSource="{CompiledBinding ToggleGroupMenuItems}"
                          ItemTemplate="{StaticResource OfficeRibbonToggleGroupOptionLargeTemplate}"
                          Tag="{CompiledBinding Id, StringFormat='group:{0}'}"
                          IsVisible="{CompiledBinding IsToggleGroupMultipleSelectionMode}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <UniformGrid Columns="{Binding $parent[ItemsControl].DataContext.ToggleGroupColumns}" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
            </ItemsControl>
            <ItemsControl ItemsSource="{CompiledBinding ToggleGroupMenuItems}"
                          ItemTemplate="{StaticResource OfficeRibbonToggleGroupSingleOptionLargeTemplate}"
                          Tag="{CompiledBinding Id, StringFormat='group-single:{0}'}"
                          IsVisible="{CompiledBinding IsToggleGroupSingleSelectionMode}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <UniformGrid Columns="{Binding $parent[ItemsControl].DataContext.ToggleGroupColumns}" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
            </ItemsControl>
          </Grid>
        </Border>

        <Border Grid.Row="15"
                Padding="2"
                IsVisible="{CompiledBinding IsEffectiveSmallToggleGroupPrimitive}"
                Tag="{CompiledBinding Id, StringFormat='toggle-group-small:{0}'}"
                ToolTip.Tip="{CompiledBinding ScreenTip}"
                AutomationProperties.Name="{CompiledBinding Label}"
                AutomationProperties.AutomationId="{CompiledBinding Id, StringFormat='Ribbon.Item.ToggleGroup.Small.{0}'}">
          <Grid>
            <ItemsControl ItemsSource="{CompiledBinding ToggleGroupMenuItems}"
                          ItemTemplate="{StaticResource OfficeRibbonToggleGroupOptionSmallTemplate}"
                          Tag="{CompiledBinding Id, StringFormat='group:{0}'}"
                          IsVisible="{CompiledBinding IsToggleGroupMultipleSelectionMode}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <UniformGrid Columns="{Binding $parent[ItemsControl].DataContext.ToggleGroupColumns}" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
            </ItemsControl>
            <ItemsControl ItemsSource="{CompiledBinding ToggleGroupMenuItems}"
                          ItemTemplate="{StaticResource OfficeRibbonToggleGroupSingleOptionSmallTemplate}"
                          Tag="{CompiledBinding Id, StringFormat='group-single:{0}'}"
                          IsVisible="{CompiledBinding IsToggleGroupSingleSelectionMode}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <UniformGrid Columns="{Binding $parent[ItemsControl].DataContext.ToggleGroupColumns}" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
            </ItemsControl>
          </Grid>
        </Border>

        <Border Grid.Row="9"
                IsVisible="{CompiledBinding IsCustomPrimitive}"
                Padding="2"
                Tag="{CompiledBinding Id, StringFormat='custom:{0}'}"
                AutomationProperties.Name="{CompiledBinding Label}"
                AutomationProperties.AutomationId="{CompiledBinding Id, StringFormat='Ribbon.Item.Custom.{0}'}">
          <ContentPresenter Content="{CompiledBinding Content}" />
        </Border>
      </Grid>
    </DataTemplate>

    <DataTemplate x:Key="OfficeRibbonQuickAccessItemTemplate" DataType="models:RibbonItem">
      <Button Classes="office-ribbon-command office-ribbon-qat-item"
              MinWidth="28"
              MinHeight="28"
              Padding="4"
              Margin="1"
              Command="{CompiledBinding Command}"
              CommandParameter="{CompiledBinding CommandParameter}"
              Tag="{CompiledBinding Id, StringFormat='qat:{0}'}"
              ToolTip.Tip="{CompiledBinding ScreenTip}"
              AutomationProperties.Name="{CompiledBinding Label}"
              AutomationProperties.AutomationId="{CompiledBinding Id, StringFormat='Ribbon.QatItem.{0}'}">
        <controls:RibbonIconPresenter Icon="{CompiledBinding Icon}"
                        IconResourceKey="{CompiledBinding IconResourceKey}"
                        IconPathData="{CompiledBinding IconPathData}"
                        IconEmoji="{CompiledBinding IconEmoji}"
                        IconStretch="{CompiledBinding IconStretch}"
                        IconStretchDirection="{CompiledBinding IconStretchDirection}"
                        IconWidth="{CompiledBinding IconWidth}"
                        IconHeight="{CompiledBinding IconHeight}"
                        IconMinWidth="{CompiledBinding IconMinWidth}"
                        IconMinHeight="{CompiledBinding IconMinHeight}"
                        IconMaxWidth="{CompiledBinding IconMaxWidth}"
                        IconMaxHeight="{CompiledBinding IconMaxHeight}"
                        Overlay="{CompiledBinding Overlay}"
                        OverlayResourceKey="{CompiledBinding OverlayResourceKey}"
                        OverlayPathData="{CompiledBinding OverlayPathData}"
                        OverlayEmoji="{CompiledBinding OverlayEmoji}"
                        OverlayCount="{CompiledBinding OverlayCount}"
                        OverlayCountText="{CompiledBinding OverlayCountText}"
                        ShowOverlayCountWhenZero="{CompiledBinding ShowOverlayCountWhenZero}"
                        OverlayHorizontalAlignment="{CompiledBinding OverlayHorizontalAlignment}"
                        OverlayVerticalAlignment="{CompiledBinding OverlayVerticalAlignment}"
                        OverlayMargin="{CompiledBinding OverlayMargin}"
                        OverlayCountHorizontalAlignment="{CompiledBinding OverlayCountHorizontalAlignment}"
                        OverlayCountVerticalAlignment="{CompiledBinding OverlayCountVerticalAlignment}"
                        OverlayCountMargin="{CompiledBinding OverlayCountMargin}"
                  Width="14"
                  Height="14" />
      </Button>
    </DataTemplate>

    <DataTemplate x:Key="OfficeRibbonGroupTemplate" DataType="models:RibbonGroup">
      <Grid>
        <Border Classes="office-ribbon-group"
                Margin="0,1,0,1"
                Padding="6,4,6,4"
                BorderBrush="{DynamicResource RibbonOfficeGroupSeparatorBrush}"
                BorderThickness="0,0,1,0"
                IsVisible="{CompiledBinding IsInlineMode}">
          <Grid RowDefinitions="Auto,*,Auto"
                ColumnDefinitions="Auto,*,Auto"
                RowSpacing="2"
                ColumnSpacing="2">
            <TextBlock Grid.Row="0"
                       Grid.Column="1"
                       Text="{CompiledBinding Header}"
                       HorizontalAlignment="Center"
                       FontSize="10"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource RibbonOfficeMutedTextBrush}"
                       IsVisible="{CompiledBinding IsHeaderTop}" />
            <TextBlock Grid.Row="2"
                       Grid.Column="1"
                       Text="{CompiledBinding Header}"
                       HorizontalAlignment="Center"
                       FontSize="10"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource RibbonOfficeMutedTextBrush}"
                       IsVisible="{CompiledBinding IsHeaderBottom}" />
            <LayoutTransformControl Grid.Row="1"
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    IsVisible="{CompiledBinding IsHeaderLeft}">
              <LayoutTransformControl.LayoutTransform>
                <RotateTransform Angle="-90" />
              </LayoutTransformControl.LayoutTransform>
              <TextBlock Text="{CompiledBinding Header}"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         FontSize="10"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource RibbonOfficeMutedTextBrush}" />
            </LayoutTransformControl>
            <LayoutTransformControl Grid.Row="1"
                                    Grid.Column="2"
                                    VerticalAlignment="Center"
                                    IsVisible="{CompiledBinding IsHeaderRight}">
              <LayoutTransformControl.LayoutTransform>
                <RotateTransform Angle="90" />
              </LayoutTransformControl.LayoutTransform>
              <TextBlock Text="{CompiledBinding Header}"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         FontSize="10"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource RibbonOfficeMutedTextBrush}" />
            </LayoutTransformControl>
            <ItemsControl Grid.Row="1"
                          Grid.Column="1"
                          VerticalAlignment="Center"
                          IsVisible="{CompiledBinding IsItemsWrapLayout}"
                          ItemsSource="{CompiledBinding MergedItems}"
                          ItemTemplate="{StaticResource OfficeRibbonItemTemplate}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
            </ItemsControl>
            <ItemsControl Grid.Row="1"
                          Grid.Column="1"
                          VerticalAlignment="Center"
                          IsVisible="{CompiledBinding IsItemsHorizontalLayout}"
                          ItemsSource="{CompiledBinding MergedItems}"
                          ItemTemplate="{StaticResource OfficeRibbonItemTemplate}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
            </ItemsControl>
            <ItemsControl Grid.Row="1"
                          Grid.Column="1"
                          VerticalAlignment="Center"
                          IsVisible="{CompiledBinding IsItemsVerticalLayout}"
                          ItemsSource="{CompiledBinding MergedItems}"
                          ItemTemplate="{StaticResource OfficeRibbonItemTemplate}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Orientation="Vertical" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
            </ItemsControl>
            <ItemsControl Grid.Row="1"
                          Grid.Column="1"
                          VerticalAlignment="Center"
                          IsVisible="{CompiledBinding IsItemsStackedLayout}"
                          ItemsSource="{CompiledBinding MergedItems}"
                          ItemTemplate="{StaticResource OfficeRibbonItemTemplate}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <controls:RibbonStackedWrapPanel MaxRows="{CompiledBinding StackedRows}"
                                                   HorizontalSpacing="2"
                                                   VerticalSpacing="2" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
            </ItemsControl>
            <DockPanel Grid.Row="1"
                       Grid.Column="1"
                       VerticalAlignment="Center"
                       LastChildFill="True"
                       IsVisible="{CompiledBinding IsItemsDockedLayout}">
              <ItemsControl DockPanel.Dock="Top"
                            IsVisible="{CompiledBinding HasDockedTopItems}"
                            ItemsSource="{CompiledBinding DockedTopItems}"
                            ItemTemplate="{StaticResource OfficeRibbonItemTemplate}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
              </ItemsControl>
              <ItemsControl DockPanel.Dock="Bottom"
                            IsVisible="{CompiledBinding HasDockedBottomItems}"
                            ItemsSource="{CompiledBinding DockedBottomItems}"
                            ItemTemplate="{StaticResource OfficeRibbonItemTemplate}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
              </ItemsControl>
              <ItemsControl DockPanel.Dock="Left"
                            IsVisible="{CompiledBinding HasDockedLeftItems}"
                            ItemsSource="{CompiledBinding DockedLeftItems}"
                            ItemTemplate="{StaticResource OfficeRibbonItemTemplate}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Vertical" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
              </ItemsControl>
              <ItemsControl DockPanel.Dock="Right"
                            IsVisible="{CompiledBinding HasDockedRightItems}"
                            ItemsSource="{CompiledBinding DockedRightItems}"
                            ItemTemplate="{StaticResource OfficeRibbonItemTemplate}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Vertical" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
              </ItemsControl>
              <Grid IsVisible="{CompiledBinding HasDockedCenterItems}">
                <ItemsControl IsVisible="{CompiledBinding IsDockedCenterWrapLayout}"
                              ItemsSource="{CompiledBinding DockedCenterItems}"
                              ItemTemplate="{StaticResource OfficeRibbonItemTemplate}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <WrapPanel />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                </ItemsControl>
                <ItemsControl IsVisible="{CompiledBinding IsDockedCenterHorizontalLayout}"
                              ItemsSource="{CompiledBinding DockedCenterItems}"
                              ItemTemplate="{StaticResource OfficeRibbonItemTemplate}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                </ItemsControl>
                <ItemsControl IsVisible="{CompiledBinding IsDockedCenterVerticalLayout}"
                              ItemsSource="{CompiledBinding DockedCenterItems}"
                              ItemTemplate="{StaticResource OfficeRibbonItemTemplate}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <StackPanel Orientation="Vertical" />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                </ItemsControl>
                <ItemsControl IsVisible="{CompiledBinding IsDockedCenterStackedLayout}"
                              ItemsSource="{CompiledBinding DockedCenterItems}"
                              ItemTemplate="{StaticResource OfficeRibbonItemTemplate}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <controls:RibbonStackedWrapPanel MaxRows="{CompiledBinding StackedRows}"
                                                       HorizontalSpacing="2"
                                                       VerticalSpacing="2" />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                </ItemsControl>
              </Grid>
            </DockPanel>
          </Grid>
        </Border>

        <ToggleButton x:Name="PART_OfficeCollapsedGroupToggle"
                      Classes="office-ribbon-command office-ribbon-group-collapsed"
                      MinWidth="72"
                      MinHeight="82"
                      Padding="6"
                      IsVisible="{CompiledBinding IsCollapsedMode}"
                      IsChecked="{CompiledBinding IsDropDownOpen, Mode=TwoWay}"
                      Tag="{CompiledBinding Id, StringFormat='group:{0}'}"
                      ToolTip.Tip="{CompiledBinding Header}"
                      AutomationProperties.Name="{CompiledBinding Header}"
                      AutomationProperties.AutomationId="{CompiledBinding Id, StringFormat='Ribbon.Group.Collapsed.{0}'}">
          <StackPanel Spacing="4"
                      HorizontalAlignment="Center">
            <controls:RibbonIconPresenter Icon="{CompiledBinding CollapsedIcon}"
                        IconResourceKey="{CompiledBinding CollapsedIconResourceKey}"
                        IconPathData="{CompiledBinding CollapsedIconPathData}"
                        IconEmoji="{CompiledBinding CollapsedIconEmoji}"
                        IconStretch="{CompiledBinding IconStretch}"
                        IconStretchDirection="{CompiledBinding IconStretchDirection}"
                        IconWidth="{CompiledBinding IconWidth}"
                        IconHeight="{CompiledBinding IconHeight}"
                        IconMinWidth="{CompiledBinding IconMinWidth}"
                        IconMinHeight="{CompiledBinding IconMinHeight}"
                        IconMaxWidth="{CompiledBinding IconMaxWidth}"
                        IconMaxHeight="{CompiledBinding IconMaxHeight}"
                        Overlay="{CompiledBinding Overlay}"
                        OverlayResourceKey="{CompiledBinding OverlayResourceKey}"
                        OverlayPathData="{CompiledBinding OverlayPathData}"
                        OverlayEmoji="{CompiledBinding OverlayEmoji}"
                        OverlayCount="{CompiledBinding OverlayCount}"
                        OverlayCountText="{CompiledBinding OverlayCountText}"
                        ShowOverlayCountWhenZero="{CompiledBinding ShowOverlayCountWhenZero}"
                        OverlayHorizontalAlignment="{CompiledBinding OverlayHorizontalAlignment}"
                        OverlayVerticalAlignment="{CompiledBinding OverlayVerticalAlignment}"
                        OverlayMargin="{CompiledBinding OverlayMargin}"
                        OverlayCountHorizontalAlignment="{CompiledBinding OverlayCountHorizontalAlignment}"
                        OverlayCountVerticalAlignment="{CompiledBinding OverlayCountVerticalAlignment}"
                        OverlayCountMargin="{CompiledBinding OverlayCountMargin}"
                      Width="16"
                      Height="16"
                      IsVisible="{CompiledBinding HasCollapsedIcon}" />
            <TextBlock Text="{CompiledBinding Header}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       FontSize="11" />
            <PathIcon Data="{x:Static icons:FluentIconData.ChevronDown20Regular}"
                      Width="10"
                      Height="10"
                      HorizontalAlignment="Center"
                      Foreground="{DynamicResource RibbonOfficeMutedTextBrush}" />
          </StackPanel>
        </ToggleButton>

        <Popup IsOpen="{CompiledBinding IsDropDownOpen, Mode=TwoWay}"
               IsLightDismissEnabled="True"
               Placement="Bottom"
               PlacementTarget="{Binding #PART_OfficeCollapsedGroupToggle}">
          <Border Classes="office-ribbon-popup-surface office-ribbon-group-popup"
                  Background="{DynamicResource RibbonOfficeMenuSurfaceBrush}"
                  BorderBrush="{DynamicResource RibbonOfficePopupBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="3"
                  Padding="8"
                  MinWidth="260"
                  MaxWidth="640">
            <StackPanel Spacing="8">
              <ItemsControl IsVisible="{CompiledBinding IsItemsWrapLayout}"
                            ItemsSource="{CompiledBinding MergedItems}"
                            ItemTemplate="{StaticResource OfficeRibbonItemTemplate}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <WrapPanel />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
              </ItemsControl>
              <ItemsControl IsVisible="{CompiledBinding IsItemsHorizontalLayout}"
                            ItemsSource="{CompiledBinding MergedItems}"
                            ItemTemplate="{StaticResource OfficeRibbonItemTemplate}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
              </ItemsControl>
              <ItemsControl IsVisible="{CompiledBinding IsItemsVerticalLayout}"
                            ItemsSource="{CompiledBinding MergedItems}"
                            ItemTemplate="{StaticResource OfficeRibbonItemTemplate}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Vertical" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
              </ItemsControl>
              <ItemsControl IsVisible="{CompiledBinding IsItemsStackedLayout}"
                            ItemsSource="{CompiledBinding MergedItems}"
                            ItemTemplate="{StaticResource OfficeRibbonItemTemplate}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <controls:RibbonStackedWrapPanel MaxRows="{CompiledBinding StackedRows}"
                                                     HorizontalSpacing="2"
                                                     VerticalSpacing="2" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
              </ItemsControl>
              <DockPanel LastChildFill="True"
                         IsVisible="{CompiledBinding IsItemsDockedLayout}">
                <ItemsControl DockPanel.Dock="Top"
                              IsVisible="{CompiledBinding HasDockedTopItems}"
                              ItemsSource="{CompiledBinding DockedTopItems}"
                              ItemTemplate="{StaticResource OfficeRibbonItemTemplate}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                </ItemsControl>
                <ItemsControl DockPanel.Dock="Bottom"
                              IsVisible="{CompiledBinding HasDockedBottomItems}"
                              ItemsSource="{CompiledBinding DockedBottomItems}"
                              ItemTemplate="{StaticResource OfficeRibbonItemTemplate}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                </ItemsControl>
                <ItemsControl DockPanel.Dock="Left"
                              IsVisible="{CompiledBinding HasDockedLeftItems}"
                              ItemsSource="{CompiledBinding DockedLeftItems}"
                              ItemTemplate="{StaticResource OfficeRibbonItemTemplate}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <StackPanel Orientation="Vertical" />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                </ItemsControl>
                <ItemsControl DockPanel.Dock="Right"
                              IsVisible="{CompiledBinding HasDockedRightItems}"
                              ItemsSource="{CompiledBinding DockedRightItems}"
                              ItemTemplate="{StaticResource OfficeRibbonItemTemplate}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <StackPanel Orientation="Vertical" />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                </ItemsControl>
                <Grid IsVisible="{CompiledBinding HasDockedCenterItems}">
                  <ItemsControl IsVisible="{CompiledBinding IsDockedCenterWrapLayout}"
                                ItemsSource="{CompiledBinding DockedCenterItems}"
                                ItemTemplate="{StaticResource OfficeRibbonItemTemplate}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <WrapPanel />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                  </ItemsControl>
                  <ItemsControl IsVisible="{CompiledBinding IsDockedCenterHorizontalLayout}"
                                ItemsSource="{CompiledBinding DockedCenterItems}"
                                ItemTemplate="{StaticResource OfficeRibbonItemTemplate}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                  </ItemsControl>
                  <ItemsControl IsVisible="{CompiledBinding IsDockedCenterVerticalLayout}"
                                ItemsSource="{CompiledBinding DockedCenterItems}"
                                ItemTemplate="{StaticResource OfficeRibbonItemTemplate}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical" />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                  </ItemsControl>
                  <ItemsControl IsVisible="{CompiledBinding IsDockedCenterStackedLayout}"
                                ItemsSource="{CompiledBinding DockedCenterItems}"
                                ItemTemplate="{StaticResource OfficeRibbonItemTemplate}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <controls:RibbonStackedWrapPanel MaxRows="{CompiledBinding StackedRows}"
                                                         HorizontalSpacing="2"
                                                         VerticalSpacing="2" />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                  </ItemsControl>
                </Grid>
              </DockPanel>
              <TextBlock Text="{CompiledBinding Header}"
                         HorizontalAlignment="Center"
                         FontSize="11"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource RibbonOfficeMutedTextBrush}" />
            </StackPanel>
          </Border>
        </Popup>
      </Grid>
    </DataTemplate>

    <DataTemplate x:Key="OfficeRibbonTabContentTemplate" DataType="models:RibbonTab">
      <Border Background="{DynamicResource RibbonOfficeCommandSurfaceBrush}">
        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled">
          <ItemsControl ItemsSource="{CompiledBinding MergedGroups}"
                        ItemTemplate="{StaticResource OfficeRibbonGroupTemplate}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
          </ItemsControl>
        </ScrollViewer>
      </Border>
    </DataTemplate>

    <DataTemplate x:Key="OfficeRibbonCollapsedTabContentTemplate" DataType="models:RibbonTab">
      <Panel Width="0" Height="0" />
    </DataTemplate>

    <DataTemplate x:Key="OfficeRibbonContextGroupTemplate" DataType="models:RibbonContextualTabGroup">
      <Border Background="#E3EFFD"
              BorderBrush="{CompiledBinding AccentColor, TargetNullValue=#B6D2F7}"
              BorderThickness="1"
              CornerRadius="3"
              Margin="2,0"
              Padding="8,2">
        <TextBlock Text="{CompiledBinding Header}"
                   FontSize="11"
                   FontWeight="SemiBold"
                   Foreground="{CompiledBinding AccentColor, TargetNullValue=#0F6CBD}" />
      </Border>
    </DataTemplate>
</ResourceDictionary>
