      <ribbon:RibbonTab Id="picture-format" Header="Picture Format" Order="20" IsContextual="True" ContextGroupId="picture-tools" ContextGroupHeader="Picture Tools" ContextGroupAccentColor="#0F6CBD" ContextGroupOrder="30">
        <ribbon:RibbonGroup Id="picture-adjust" Header="Adjust" Order="0">
          <ribbon:RibbonItem Id="remove-background" Label="Remove Background" IconPathData="{x:Static ribbon:FluentIconData.Settings20Regular}" CommandId="remove-background" KeyTip="RB" ScreenTip="Remove image background" />
          <ribbon:RibbonItem Id="corrections" Label="Corrections" IconPathData="{x:Static ribbon:FluentIconData.Image20Regular}" CommandId="corrections" KeyTip="CR" ScreenTip="Adjust picture corrections" />
          <ribbon:RibbonItem Id="color" Label="Color" IconPathData="{x:Static ribbon:FluentIconData.ChartMultiple20Regular}" CommandId="color" KeyTip="CL" ScreenTip="Adjust picture color" />
        </ribbon:RibbonGroup>
        <ribbon:RibbonGroup Id="picture-styles" Header="Picture Styles" Order="1">
          <ribbon:RibbonItem Id="picture-border" Label="Picture Border" IconPathData="{x:Static ribbon:FluentIconData.Copy20Regular}" CommandId="picture-border" KeyTip="PB" ScreenTip="Add a picture border" />
          <ribbon:RibbonItem Id="picture-effects" Label="Picture Effects" IconPathData="{x:Static ribbon:FluentIconData.Wrench20Regular}" CommandId="picture-effects" KeyTip="PE" ScreenTip="Apply picture effects" />
        </ribbon:RibbonGroup>
        <ribbon:RibbonGroup Id="picture-arrange" Header="Arrange" Order="2">
          <ribbon:RibbonItem Id="bring-forward" Label="Bring Forward" IconPathData="{x:Static ribbon:FluentIconData.Share20Regular}" CommandId="bring-forward" KeyTip="BF" ScreenTip="Bring picture forward" />
          <ribbon:RibbonItem Id="send-backward" Label="Send Backward" IconPathData="{x:Static ribbon:FluentIconData.Share20Regular}" CommandId="send-backward" KeyTip="BA" ScreenTip="Send picture backward" />
        </ribbon:RibbonGroup>
      </ribbon:RibbonTab>
    </ribbon:Ribbon>

    <Grid RowDefinitions="*,Auto">
      <Grid ColumnDefinitions="220,*,320">
        <Border Grid.Column="0"
                Background="#F2F4F8"
                BorderBrush="#D5DBE6"
                BorderThickness="0,1,1,0"
                Padding="12">
          <StackPanel Spacing="10">
            <TextBlock Text="Navigation"
                       FontSize="13"
                       FontWeight="SemiBold" />
            <ListBox>
              <ListBoxItem>Document 1</ListBoxItem>
              <ListBoxItem>Outline</ListBoxItem>
              <ListBoxItem>Headings</ListBoxItem>
              <ListBoxItem>Pages</ListBoxItem>
            </ListBox>
          </StackPanel>
        </Border>

        <Border Grid.Column="1"
                Background="#ECEFF4"
                BorderBrush="#D5DBE6"
                BorderThickness="0,1,0,0"
                Padding="24">
          <Grid RowDefinitions="Auto,*">
            <Border Background="#F8FAFD"
                    BorderBrush="#D5DBE6"
                    BorderThickness="1"
                    CornerRadius="2"
                    Padding="8,4">
              <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                           Text="Word-like Document Surface"
                           FontSize="12"
                           FontWeight="SemiBold" />
                <TextBlock DockPanel.Dock="Right"
                           Text="Page 1 of 1"
                           FontSize="11"
                           Opacity="0.7" />
              </DockPanel>
            </Border>

            <Border Grid.Row="1"
                    Margin="0,12,0,0"
                    Background="White"
                    BorderBrush="#C9D2E2"
                    BorderThickness="1"
                    CornerRadius="2"
                    HorizontalAlignment="Center"
                    Width="800"
                    Padding="48">
              <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                            VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="12">
                  <TextBlock Text="RibbonControl Office Theme Preview"
                             FontSize="26"
                             FontWeight="SemiBold" />
                  <TextBlock Text="This central surface mimics a Word page so ribbon layout and command density can be evaluated in context."
                             TextWrapping="Wrap"
                             FontSize="13" />
                  <TextBlock Text="Use the ribbon controls and the panel on the right to toggle contextual tabs, minimized mode, key tips, and persistence behavior."
                             TextWrapping="Wrap"
                             FontSize="13" />
                </StackPanel>
              </ScrollViewer>
            </Border>
          </Grid>
        </Border>

        <Border Grid.Column="2"
                Background="#F7F8FA"
                BorderBrush="#D5DBE6"
                BorderThickness="1,1,0,0"
                Padding="14">
          <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="12">
              <TextBlock Text="Inspector / Actions"
                         FontSize="13"
                         FontWeight="SemiBold" />

              <WrapPanel ItemHeight="32" ItemWidth="150">
                <Button Content="Toggle Picture Tools" Command="{CompiledBinding TogglePictureToolsCommand}" />
                <Button Content="Toggle Minimized" Command="{CompiledBinding ToggleMinimizedCommand}" />
                <Button Content="Toggle KeyTip Mode" Command="{CompiledBinding ToggleKeyTipModeCommand}" />
                <Button Content="Toggle QAT Placement" Command="{CompiledBinding ToggleQuickAccessPlacementCommand}" />
              </WrapPanel>

              <WrapPanel ItemHeight="32" ItemWidth="150">
                <Button Content="Seed State Store" Command="{CompiledBinding SeedStateStoreCommand}" />
                <Button Content="Load State" Command="{CompiledBinding #MainRibbon.LoadStateCommand}" />
                <Button Content="Save State" Command="{CompiledBinding #MainRibbon.SaveStateCommand}" />
                <Button Content="Reset State" Command="{CompiledBinding #MainRibbon.ResetStateCommand}" />
                <Button Content="Reset Customization" Command="{CompiledBinding #MainRibbon.ResetCustomizationCommand}" />
              </WrapPanel>

              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Ownership" VerticalAlignment="Center" />
                <ComboBox Width="140"
                          ItemsSource="{CompiledBinding StateOwnershipModes}"
                          SelectedItem="{CompiledBinding StateOwnershipMode, Mode=TwoWay}" />
              </StackPanel>

              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="QAT Placement" VerticalAlignment="Center" />
                <ComboBox Width="120"
                          ItemsSource="{CompiledBinding QuickAccessPlacements}"
                          SelectedItem="{CompiledBinding QuickAccessPlacement, Mode=TwoWay}" />
              </StackPanel>

              <TextBlock Text="{CompiledBinding Status}"
                         FontSize="13"
                         FontWeight="SemiBold" />
              <TextBlock Text="{CompiledBinding SelectedTabId, StringFormat='Selected Tab: {0}'}" FontSize="12" Opacity="0.75" />
              <TextBlock Text="{CompiledBinding IsBackstageOpen, StringFormat='Backstage Open: {0}'}" FontSize="12" Opacity="0.75" />
              <TextBlock Text="{CompiledBinding IsMinimized, StringFormat='Is Minimized: {0}'}" FontSize="12" Opacity="0.75" />
              <TextBlock Text="{CompiledBinding IsKeyTipMode, StringFormat='Is KeyTip Mode: {0}'}" FontSize="12" Opacity="0.75" />
              <TextBlock Text="{CompiledBinding QuickAccessPlacement, StringFormat='QAT Placement: {0}'}" FontSize="12" Opacity="0.75" />
              <TextBlock Text="{CompiledBinding StateOwnershipMode, StringFormat='Ownership Mode: {0}'}" FontSize="12" Opacity="0.75" />
              <TextBlock Text="Press Alt to enter key-tip mode."
                         FontSize="12"
                         Opacity="0.65" />
            </StackPanel>
          </ScrollViewer>
        </Border>
      </Grid>

      <Border Grid.Row="1"
              Background="#EEF1F6"
              BorderBrush="#D5DBE6"
              BorderThickness="0,1,0,0"
              Padding="10,4">
        <DockPanel>
          <TextBlock DockPanel.Dock="Left"
                     Text="Page 1   Words: 315   English (United States)"
                     FontSize="11"
                     Opacity="0.8" />
          <TextBlock DockPanel.Dock="Right"
                     Text="Zoom 100%"
                     FontSize="11"
                     Opacity="0.8" />
        </DockPanel>
      </Border>
    </Grid>
  </DockPanel>
</Window>
