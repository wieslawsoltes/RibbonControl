        </ribbon:RibbonGroup>
        <ribbon:RibbonGroup Id="symbols" Header="Symbols" Order="5">
          <ribbon:RibbonItem Id="equation"
                             Label="Equation"
                             Primitive="SplitButton"
                             IconPathData="{x:Static ribbon:FluentIconData.Wrench20Regular}"
