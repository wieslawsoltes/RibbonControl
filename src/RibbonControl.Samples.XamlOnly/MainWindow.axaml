                  <Button Content="€" FontSize="30" />
                  <Button Content="£" FontSize="30" />
                  <Button Content="¥" FontSize="30" />
                  <Button Content="©" FontSize="30" />
                  <Button Content="®" FontSize="30" />
                  <Button Content="™" FontSize="30" />
                  <Button Content="±" FontSize="30" />
                  <Button Content="≠" FontSize="30" />
                  <Button Content="≤" FontSize="30" />
                  <Button Content="≥" FontSize="30" />
                  <Button Content="÷" FontSize="30" />
                  <Button Content="×" FontSize="30" />
                  <Button Content="∞" FontSize="30" />
                  <Button Content="µ" FontSize="30" />
                  <Button Content="α" FontSize="30" />
                  <Button Content="β" FontSize="30" />
                  <Button Content="π" FontSize="30" />
                  <Button Content="Ω" FontSize="30" />
                  <Button Content="Σ" FontSize="30" />
                  <Button Content="°" FontSize="30" />
                  <Button Content="Δ" FontSize="30" />
                  <Button Content="☺" FontSize="30" />
                  <Button Content="♥" FontSize="30" />
                  <Button Content="₹" FontSize="30" />
                </UniformGrid>
              </StackPanel>
