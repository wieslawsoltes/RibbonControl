            <Button Classes="ribbon-command ribbon-large ribbon-split-main ribbon-command-large"
                    MinWidth="82"
                    Padding="6,7"
                    IsVisible="{CompiledBinding IsSideBySideLargeSplitButtonPrimitive}"
