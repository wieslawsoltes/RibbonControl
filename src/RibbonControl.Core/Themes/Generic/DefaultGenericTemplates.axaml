                        IconMaxHeight="{CompiledBinding IconMaxHeight}"
                        Overlay="{CompiledBinding Overlay}"
                        OverlayResourceKey="{CompiledBinding OverlayResourceKey}"
                        OverlayPathData="{CompiledBinding OverlayPathData}"
                        OverlayEmoji="{CompiledBinding OverlayEmoji}"
                        OverlayCount="{CompiledBinding OverlayCount}"
                        OverlayCountText="{CompiledBinding OverlayCountText}"
                        ShowOverlayCountWhenZero="{CompiledBinding ShowOverlayCountWhenZero}"
                        OverlayHorizontalAlignment="{CompiledBinding OverlayHorizontalAlignment}"
                        OverlayVerticalAlignment="{CompiledBinding OverlayVerticalAlignment}"
                        OverlayMargin="{CompiledBinding OverlayMargin}"
                        OverlayCountHorizontalAlignment="{CompiledBinding OverlayCountHorizontalAlignment}"
                        OverlayCountVerticalAlignment="{CompiledBinding OverlayCountVerticalAlignment}"
                        OverlayCountMargin="{CompiledBinding OverlayCountMargin}"
                        Width="16"
                        Height="16" />
            </Button>
            <Button Classes="ribbon-command ribbon-icon-only-small ribbon-split-main-small ribbon-split-main-icon-only ribbon-command"
                    IsVisible="{CompiledBinding IsSideBySideSmallIconOnlySplitButtonPrimitive}"
                    Command="{CompiledBinding Command}"
                    CommandParameter="{CompiledBinding CommandParameter}"
                    Tag="{CompiledBinding Id, StringFormat='split-main-icononly-small:{0}'}"
                    ToolTip.Tip="{CompiledBinding ScreenTip}"
                    AutomationProperties.Name="{CompiledBinding Label}"
                    AutomationProperties.AutomationId="{CompiledBinding Id, StringFormat='Ribbon.Item.SplitMain.IconOnly.Small.{0}'}">
              <controls:RibbonIconPresenter Icon="{CompiledBinding Icon}"
                        IconResourceKey="{CompiledBinding IconResourceKey}"
                        IconPathData="{CompiledBinding IconPathData}"
                        IconEmoji="{CompiledBinding IconEmoji}"
                        IconStretch="{CompiledBinding IconStretch}"
                        IconStretchDirection="{CompiledBinding IconStretchDirection}"
                        IconWidth="{CompiledBinding IconWidth}"
                        IconHeight="{CompiledBinding IconHeight}"
                        IconMinWidth="{CompiledBinding IconMinWidth}"
                        IconMinHeight="{CompiledBinding IconMinHeight}"
                        IconMaxWidth="{CompiledBinding IconMaxWidth}"
                        IconMaxHeight="{CompiledBinding IconMaxHeight}"
                        Overlay="{CompiledBinding Overlay}"
                        OverlayResourceKey="{CompiledBinding OverlayResourceKey}"
                        OverlayPathData="{CompiledBinding OverlayPathData}"
                        OverlayEmoji="{CompiledBinding OverlayEmoji}"
                        OverlayCount="{CompiledBinding OverlayCount}"
                        OverlayCountText="{CompiledBinding OverlayCountText}"
                        ShowOverlayCountWhenZero="{CompiledBinding ShowOverlayCountWhenZero}"
                        OverlayHorizontalAlignment="{CompiledBinding OverlayHorizontalAlignment}"
                        OverlayVerticalAlignment="{CompiledBinding OverlayVerticalAlignment}"
                        OverlayMargin="{CompiledBinding OverlayMargin}"
                        OverlayCountHorizontalAlignment="{CompiledBinding OverlayCountHorizontalAlignment}"
                        OverlayCountVerticalAlignment="{CompiledBinding OverlayCountVerticalAlignment}"
                        OverlayCountMargin="{CompiledBinding OverlayCountMargin}"
                        Width="14"
                        Height="14" />
            </Button>
          </Grid>
          <Border Grid.Column="1"
                  Classes="ribbon-splitter-host ribbon-split-secondary-host">
            <Grid>
              <ToggleButton x:Name="PART_RibbonSplitDropDownToggle"
                            Classes="ribbon-command ribbon-split-secondary ribbon-dropdown-toggle"
                            MinWidth="24"
                            IsVisible="{CompiledBinding IsSplitDropDownToggleVisible}"
                            IsChecked="{CompiledBinding IsDropDownOpen, Mode=TwoWay}"
                            Tag="{CompiledBinding Id, StringFormat='split-secondary:{0}'}"
                            ToolTip.Tip="{CompiledBinding ScreenTip}"
                            AutomationProperties.Name="{CompiledBinding Label, StringFormat='{}{0} Options'}"
                            AutomationProperties.AutomationId="{CompiledBinding Id, StringFormat='Ribbon.Item.SplitSecondary.{0}'}">
                <PathIcon Data="{x:Static icons:FluentIconData.ChevronDown20Regular}"
                          Width="10"
                          Height="10" />
              </ToggleButton>
              <Button Classes="ribbon-command ribbon-split-secondary-action"
                      MinWidth="24"
                      IsVisible="{CompiledBinding IsSplitSecondaryCommandVisible}"
                      Command="{CompiledBinding SecondaryCommand}"
                      CommandParameter="{CompiledBinding SecondaryCommandParameter}"
                      Tag="{CompiledBinding Id, StringFormat='split-secondary-action:{0}'}"
                      ToolTip.Tip="{CompiledBinding ScreenTip}"
                      AutomationProperties.Name="{CompiledBinding Label, StringFormat='{}{0} Secondary Action'}"
                      AutomationProperties.AutomationId="{CompiledBinding Id, StringFormat='Ribbon.Item.SplitSecondaryAction.{0}'}">
                <PathIcon Data="{x:Static icons:FluentIconData.ChevronRight20Regular}"
                          Width="10"
                          Height="10" />
              </Button>
              <ToggleButton Classes="ribbon-command ribbon-split-secondary ribbon-dropdown-toggle"
                            MinWidth="24"
                            IsVisible="{CompiledBinding IsSplitFallbackToggleVisible}"
                            IsEnabled="False"
                            ToolTip.Tip="{CompiledBinding ScreenTip}"
                            AutomationProperties.Name="{CompiledBinding Label, StringFormat='{}{0} Options'}"
                            AutomationProperties.AutomationId="{CompiledBinding Id, StringFormat='Ribbon.Item.SplitSecondaryFallback.{0}'}">
                <PathIcon Data="{x:Static icons:FluentIconData.ChevronDown20Regular}"
                          Width="10"
                          Height="10" />
              </ToggleButton>
            </Grid>
          </Border>
          <Popup IsOpen="{CompiledBinding IsSideBySideSplitDropDownOpen, Mode=TwoWay}"
                 IsLightDismissEnabled="True"
                 Placement="Bottom"
                 PlacementTarget="{Binding #PART_RibbonSplitHost}">
            <Border Classes="ribbon-popup-surface ribbon-menu-popup ribbon-popup-menu-surface"
                    Background="{DynamicResource RibbonThemeMenuSurfaceBrush}"
                    BorderBrush="{DynamicResource RibbonThemePopupBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="3"
                    MinWidth="{CompiledBinding PopupMinWidth}">
              <StackPanel Spacing="4">
                <TextBlock Text="{CompiledBinding PopupTitle}"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource RibbonThemePrimaryTextBrush}"
                           IsVisible="{CompiledBinding HasPopupTitle}" />
                <ContentPresenter Content="{CompiledBinding PopupContent}"
                                  IsVisible="{CompiledBinding HasPopupContent}" />
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              MaxHeight="{CompiledBinding PopupMaxHeight}"
                              IsVisible="{CompiledBinding HasPopupMenuSections}">
                  <ItemsControl Grid.IsSharedSizeScope="True"
                                ItemsSource="{CompiledBinding PopupMenuSections}"
                                ItemTemplate="{StaticResource RibbonPopupMenuSectionTemplate}" />
                </ScrollViewer>
                <ContentPresenter Content="{CompiledBinding PopupFooterContent}"
                                  IsVisible="{CompiledBinding HasPopupFooterContent}" />
              </StackPanel>
            </Border>
          </Popup>
        </Grid>

        <Grid x:Name="PART_RibbonStackedSplitHost"
              Grid.Row="2"
              IsVisible="{CompiledBinding IsStackedSplitButtonPrimitive}"
              RowDefinitions="Auto,Auto"
              MinWidth="82">
          <Button Classes="ribbon-command ribbon-stacked-split-top ribbon-command-large"
