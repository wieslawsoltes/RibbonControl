                        OverlayPathData="{CompiledBinding OverlayPathData}"
                        OverlayEmoji="{CompiledBinding OverlayEmoji}"
                        OverlayCount="{CompiledBinding OverlayCount}"
                        OverlayCountText="{CompiledBinding OverlayCountText}"
                        ShowOverlayCountWhenZero="{CompiledBinding ShowOverlayCountWhenZero}"
                        OverlayHorizontalAlignment="{CompiledBinding OverlayHorizontalAlignment}"
                        OverlayVerticalAlignment="{CompiledBinding OverlayVerticalAlignment}"
                        OverlayMargin="{CompiledBinding OverlayMargin}"
                        OverlayCountHorizontalAlignment="{CompiledBinding OverlayCountHorizontalAlignment}"
                        OverlayCountVerticalAlignment="{CompiledBinding OverlayCountVerticalAlignment}"
                        OverlayCountMargin="{CompiledBinding OverlayCountMargin}"
                      Width="16"
                      Height="16"
                      IsVisible="{CompiledBinding HasIcon}" />
            <TextBlock Text="{CompiledBinding Label}"
                       VerticalAlignment="Center"
                       FontSize="11.5" />
          </StackPanel>
        </Grid>
      </RadioButton>
    </DataTemplate>

    <DataTemplate x:Key="RibbonToggleGroupSingleOptionSmallTemplate" DataType="models:RibbonMenuItem">
      <RadioButton Classes="ribbon-command ribbon-toggle-group-option-small ribbon-toggle-group-option-single ribbon-command"
                   MinWidth="98"
                   Margin="2"
                   Padding="7,4"
