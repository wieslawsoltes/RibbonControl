                          IsVisible="{CompiledBinding IsStackedSplitBottomDropDownOnlyVisible}"
                          IsChecked="{CompiledBinding IsDropDownOpen, Mode=TwoWay}"
                          Tag="{CompiledBinding Id, StringFormat='split-stacked-bottom-toggle:{0}'}"
                          ToolTip.Tip="{CompiledBinding ScreenTip}"
                          AutomationProperties.Name="{CompiledBinding Label, StringFormat='{}{0} Options'}"
                          AutomationProperties.AutomationId="{CompiledBinding Id, StringFormat='Ribbon.Item.StackedSplitBottomToggle.{0}'}">
              <DockPanel LastChildFill="False">
                <TextBlock Text="{CompiledBinding Label}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center" />
                <TextBlock Text="▼"
                           Margin="4,0,0,0"
                           FontSize="10"
                           VerticalAlignment="Center" />
