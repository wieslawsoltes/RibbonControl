<ResourceDictionary xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:RibbonControl.Core.Controls"
        xmlns:models="using:RibbonControl.Core.Models">
<DataTemplate x:Key="RibbonTabHeaderTemplate" DataType="models:RibbonTab">
      <StackPanel Spacing="2"
                  Margin="6,2">
        <Border Height="2"
                CornerRadius="1"
                IsVisible="{CompiledBinding IsContextual}"
                Background="{CompiledBinding ContextGroupAccentColor, TargetNullValue={DynamicResource RibbonGenericAccentBrush}}" />
        <TextBlock Text="{CompiledBinding Header}"
                   Tag="{CompiledBinding Id, StringFormat='tab:{0}'}"
                   AutomationProperties.Name="{CompiledBinding Header}"
                   AutomationProperties.AutomationId="{CompiledBinding Id, StringFormat='Ribbon.Tab.{0}'}"
                   Margin="2,0"
                   Foreground="{CompiledBinding ContextGroupAccentColor, TargetNullValue={DynamicResource RibbonGenericTextBrush}}" />
      </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="RibbonBackstageNavigationItemTemplate" DataType="models:RibbonBackstageItem">
      <Grid IsVisible="{CompiledBinding IsVisible}">
        <Separator Classes="ribbon-backstage-nav-separator"
                   IsVisible="{CompiledBinding IsSeparator}" />
        <Border Classes="ribbon-backstage-nav-item"
                IsVisible="{CompiledBinding IsActionItem}"
                IsEnabled="{CompiledBinding IsEnabled}"
                Padding="10,7">
          <Grid ColumnDefinitions="Auto,*,Auto,Auto"
                ColumnSpacing="10">
            <controls:RibbonIconPresenter Grid.Column="0"
                        Icon="{CompiledBinding Icon}"
                        IconResourceKey="{CompiledBinding IconResourceKey}"
                        IconPathData="{CompiledBinding IconPathData}"
                        IconEmoji="{CompiledBinding IconEmoji}"
                        IconStretch="{CompiledBinding IconStretch}"
                        IconStretchDirection="{CompiledBinding IconStretchDirection}"
                        IconWidth="{CompiledBinding IconWidth}"
                        IconHeight="{CompiledBinding IconHeight}"
                        IconMinWidth="{CompiledBinding IconMinWidth}"
                        IconMinHeight="{CompiledBinding IconMinHeight}"
                        IconMaxWidth="{CompiledBinding IconMaxWidth}"
                        IconMaxHeight="{CompiledBinding IconMaxHeight}"
                        Width="18"
                        Height="18"
                        IsVisible="{CompiledBinding HasIcon}" />
            <StackPanel Grid.Column="1"
                        Spacing="1"
                        VerticalAlignment="Center">
              <TextBlock Classes="ribbon-backstage-nav-label"
                         Text="{CompiledBinding Label}" />
              <TextBlock Classes="ribbon-backstage-nav-description"
                         Text="{CompiledBinding Description}"
                         IsVisible="{CompiledBinding HasDescription}" />
            </StackPanel>
            <TextBlock Grid.Column="2"
                       Classes="ribbon-backstage-nav-gesture"
                       Text="{CompiledBinding InputGestureText}"
                       VerticalAlignment="Center"
                       IsVisible="{CompiledBinding HasInputGestureText}" />
            <TextBlock Grid.Column="3"
                       Classes="ribbon-backstage-nav-chevron"
                       Text="›"
                       VerticalAlignment="Center"
                       IsVisible="{CompiledBinding ShowsChevronGlyph}" />
          </Grid>
        </Border>
      </Grid>
    </DataTemplate>

    <DataTemplate x:Key="RibbonMenuItemTemplate" DataType="models:RibbonMenuItem">
      <Grid Classes="ribbon-menu-item-host">
        <Separator Classes="ribbon-menu-separator"
                   IsVisible="{CompiledBinding IsSeparator}" />
        <Button Classes="ribbon-popup-command"
                HorizontalContentAlignment="Stretch"
                IsVisible="{CompiledBinding IsCommand}"
                Command="{CompiledBinding Command}"
                CommandParameter="{CompiledBinding CommandParameter}"
                Tag="{CompiledBinding Id}"
                ToolTip.Tip="{CompiledBinding ScreenTip}"
                AutomationProperties.Name="{CompiledBinding Label}"
                AutomationProperties.AutomationId="{CompiledBinding Id, StringFormat='Ribbon.MenuItem.{0}'}">
          <Grid>
            <ContentPresenter Content="{CompiledBinding Content}"
                              IsVisible="{CompiledBinding HasContent}" />
            <Grid Classes="ribbon-menu-item-layout"
                  ColumnDefinitions="22,*,Auto,Auto"
                  IsVisible="{CompiledBinding HasNoContent}">
              <controls:RibbonIconPresenter Grid.Column="0"
                        Classes="ribbon-menu-item-icon"
                        Icon="{CompiledBinding Icon}"
                        IconResourceKey="{CompiledBinding IconResourceKey}"
                        IconPathData="{CompiledBinding IconPathData}"
                        IconEmoji="{CompiledBinding IconEmoji}"
                        IconStretch="{CompiledBinding IconStretch}"
                        IconStretchDirection="{CompiledBinding IconStretchDirection}"
                        IconWidth="{CompiledBinding IconWidth}"
                        IconHeight="{CompiledBinding IconHeight}"
                        IconMinWidth="{CompiledBinding IconMinWidth}"
                        IconMinHeight="{CompiledBinding IconMinHeight}"
                        IconMaxWidth="{CompiledBinding IconMaxWidth}"
                        IconMaxHeight="{CompiledBinding IconMaxHeight}"
                        Overlay="{CompiledBinding Overlay}"
                        OverlayResourceKey="{CompiledBinding OverlayResourceKey}"
                        OverlayPathData="{CompiledBinding OverlayPathData}"
                        OverlayEmoji="{CompiledBinding OverlayEmoji}"
                        OverlayCount="{CompiledBinding OverlayCount}"
                        OverlayCountText="{CompiledBinding OverlayCountText}"
                        ShowOverlayCountWhenZero="{CompiledBinding ShowOverlayCountWhenZero}"
                        OverlayHorizontalAlignment="{CompiledBinding OverlayHorizontalAlignment}"
                        OverlayVerticalAlignment="{CompiledBinding OverlayVerticalAlignment}"
                        OverlayMargin="{CompiledBinding OverlayMargin}"
                        OverlayCountHorizontalAlignment="{CompiledBinding OverlayCountHorizontalAlignment}"
                        OverlayCountVerticalAlignment="{CompiledBinding OverlayCountVerticalAlignment}"
                        OverlayCountMargin="{CompiledBinding OverlayCountMargin}" />
              <StackPanel Grid.Column="1"
                          Classes="ribbon-menu-item-text">
                <TextBlock Classes="ribbon-menu-item-label"
                           Text="{CompiledBinding Label}" />
                <TextBlock Classes="ribbon-menu-item-description"
                           Text="{CompiledBinding Description}"
                           IsVisible="{CompiledBinding HasDescription}" />
              </StackPanel>
              <TextBlock Grid.Column="2"
                         Classes="ribbon-menu-item-gesture"
                         Text="{CompiledBinding InputGestureText}"
                         IsVisible="{CompiledBinding HasInputGestureText}" />
              <Border Grid.Column="3"
                      Classes="ribbon-menu-item-chevron-host"
                      IsVisible="{CompiledBinding ShowsChevronGlyph}">
                <TextBlock Classes="ribbon-menu-item-chevron"
                           Text="›"
                           VerticalAlignment="Center" />
              </Border>
            </Grid>
          </Grid>
        </Button>

        <ToggleButton x:Name="PART_SubMenuToggle"
                      Classes="ribbon-popup-command"
                      HorizontalContentAlignment="Stretch"
                      IsVisible="{CompiledBinding HasSubMenuItems}"
                      IsChecked="{CompiledBinding IsSubMenuOpen, Mode=TwoWay}"
                      Tag="{CompiledBinding Id, StringFormat='submenu:{0}'}"
                      ToolTip.Tip="{CompiledBinding ScreenTip}"
                      AutomationProperties.Name="{CompiledBinding Label}"
                      AutomationProperties.AutomationId="{CompiledBinding Id, StringFormat='Ribbon.MenuItem.SubMenu.{0}'}">
          <Grid>
            <ContentPresenter Content="{CompiledBinding Content}"
                              IsVisible="{CompiledBinding HasContent}" />
            <Grid Classes="ribbon-menu-item-layout"
                  ColumnDefinitions="22,*,Auto,Auto"
                  IsVisible="{CompiledBinding HasNoContent}">
              <controls:RibbonIconPresenter Grid.Column="0"
                        Classes="ribbon-menu-item-icon"
                        Icon="{CompiledBinding Icon}"
                        IconResourceKey="{CompiledBinding IconResourceKey}"
                        IconPathData="{CompiledBinding IconPathData}"
                        IconEmoji="{CompiledBinding IconEmoji}"
                        IconStretch="{CompiledBinding IconStretch}"
                        IconStretchDirection="{CompiledBinding IconStretchDirection}"
                        IconWidth="{CompiledBinding IconWidth}"
                        IconHeight="{CompiledBinding IconHeight}"
                        IconMinWidth="{CompiledBinding IconMinWidth}"
                        IconMinHeight="{CompiledBinding IconMinHeight}"
                        IconMaxWidth="{CompiledBinding IconMaxWidth}"
                        IconMaxHeight="{CompiledBinding IconMaxHeight}"
                        Overlay="{CompiledBinding Overlay}"
                        OverlayResourceKey="{CompiledBinding OverlayResourceKey}"
                        OverlayPathData="{CompiledBinding OverlayPathData}"
                        OverlayEmoji="{CompiledBinding OverlayEmoji}"
                        OverlayCount="{CompiledBinding OverlayCount}"
                        OverlayCountText="{CompiledBinding OverlayCountText}"
                        ShowOverlayCountWhenZero="{CompiledBinding ShowOverlayCountWhenZero}"
                        OverlayHorizontalAlignment="{CompiledBinding OverlayHorizontalAlignment}"
                        OverlayVerticalAlignment="{CompiledBinding OverlayVerticalAlignment}"
                        OverlayMargin="{CompiledBinding OverlayMargin}"
                        OverlayCountHorizontalAlignment="{CompiledBinding OverlayCountHorizontalAlignment}"
                        OverlayCountVerticalAlignment="{CompiledBinding OverlayCountVerticalAlignment}"
                        OverlayCountMargin="{CompiledBinding OverlayCountMargin}" />
              <StackPanel Grid.Column="1"
                          Classes="ribbon-menu-item-text">
                <TextBlock Classes="ribbon-menu-item-label"
                           Text="{CompiledBinding Label}" />
                <TextBlock Classes="ribbon-menu-item-description"
                           Text="{CompiledBinding Description}"
                           IsVisible="{CompiledBinding HasDescription}" />
              </StackPanel>
              <TextBlock Grid.Column="2"
                         Classes="ribbon-menu-item-gesture"
                         Text="{CompiledBinding InputGestureText}"
                         IsVisible="{CompiledBinding HasInputGestureText}" />
              <Border Grid.Column="3"
                      Classes="ribbon-menu-item-chevron-host">
                <TextBlock Classes="ribbon-menu-item-chevron"
                           Text="›"
                           VerticalAlignment="Center" />
              </Border>
            </Grid>
          </Grid>
        </ToggleButton>

        <Popup IsOpen="{CompiledBinding IsSubMenuOpen, Mode=TwoWay}"
               IsLightDismissEnabled="True"
               Placement="RightEdgeAlignedTop"
               PlacementTarget="{Binding #PART_SubMenuToggle}">
          <Border Classes="ribbon-popup-surface ribbon-popup-submenu-surface"
                  Background="{DynamicResource RibbonGenericSurfaceBrush}"
                  BorderBrush="{DynamicResource RibbonGenericPopupBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="2"
                  MaxHeight="460">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
              <ItemsControl ItemsSource="{CompiledBinding SubMenuItems}"
                            ItemTemplate="{StaticResource RibbonMenuItemTemplate}" />
            </ScrollViewer>
          </Border>
        </Popup>
      </Grid>
    </DataTemplate>

    <DataTemplate x:Key="RibbonGalleryItemTemplate" DataType="models:RibbonMenuItem">
      <ToggleButton Classes="ribbon-gallery-item"
                    MinWidth="92"
                    Margin="2"
                    Padding="6,4"
                    IsChecked="{CompiledBinding IsSelected, Mode=TwoWay}"
                    Command="{CompiledBinding Command}"
                    CommandParameter="{CompiledBinding CommandParameter}"
                    Tag="{CompiledBinding Id, StringFormat='gallery:{0}'}"
                    ToolTip.Tip="{CompiledBinding ScreenTip}"
                    AutomationProperties.Name="{CompiledBinding Label}"
                    AutomationProperties.AutomationId="{CompiledBinding Id, StringFormat='Ribbon.GalleryItem.{0}'}">
        <Grid>
          <ContentPresenter Content="{CompiledBinding Content}"
                            IsVisible="{CompiledBinding HasContent}" />
          <StackPanel Orientation="Vertical"
                      HorizontalAlignment="Center"
                      Spacing="4"
                      IsVisible="{CompiledBinding HasNoContent}">
            <controls:RibbonIconPresenter Icon="{CompiledBinding Icon}"
                        IconResourceKey="{CompiledBinding IconResourceKey}"
                        IconPathData="{CompiledBinding IconPathData}"
                        IconEmoji="{CompiledBinding IconEmoji}"
                        IconStretch="{CompiledBinding IconStretch}"
                        IconStretchDirection="{CompiledBinding IconStretchDirection}"
                        IconWidth="{CompiledBinding IconWidth}"
                        IconHeight="{CompiledBinding IconHeight}"
                        IconMinWidth="{CompiledBinding IconMinWidth}"
                        IconMinHeight="{CompiledBinding IconMinHeight}"
                        IconMaxWidth="{CompiledBinding IconMaxWidth}"
                        IconMaxHeight="{CompiledBinding IconMaxHeight}"
                        Overlay="{CompiledBinding Overlay}"
                        OverlayResourceKey="{CompiledBinding OverlayResourceKey}"
                        OverlayPathData="{CompiledBinding OverlayPathData}"
                        OverlayEmoji="{CompiledBinding OverlayEmoji}"
                        OverlayCount="{CompiledBinding OverlayCount}"
                        OverlayCountText="{CompiledBinding OverlayCountText}"
                        ShowOverlayCountWhenZero="{CompiledBinding ShowOverlayCountWhenZero}"
                        OverlayHorizontalAlignment="{CompiledBinding OverlayHorizontalAlignment}"
                        OverlayVerticalAlignment="{CompiledBinding OverlayVerticalAlignment}"
                        OverlayMargin="{CompiledBinding OverlayMargin}"
                        OverlayCountHorizontalAlignment="{CompiledBinding OverlayCountHorizontalAlignment}"
                        OverlayCountVerticalAlignment="{CompiledBinding OverlayCountVerticalAlignment}"
                        OverlayCountMargin="{CompiledBinding OverlayCountMargin}"
                      Width="16"
                      Height="16" />
            <TextBlock Text="{CompiledBinding Label}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       FontSize="11" />
          </StackPanel>
        </Grid>
      </ToggleButton>
    </DataTemplate>

    <DataTemplate x:Key="RibbonPopupMenuSectionTemplate" DataType="models:RibbonPopupMenuSection">
      <StackPanel Classes="ribbon-popup-section"
                  Spacing="4">
        <Separator Classes="ribbon-popup-section-separator"
                   IsVisible="{CompiledBinding ShowSeparator}" />
        <TextBlock Classes="ribbon-popup-section-header"
                   Text="{CompiledBinding Header}"
                   IsVisible="{CompiledBinding HasHeader}" />
        <ItemsControl Classes="ribbon-popup-section-gallery-items"
                      ItemsSource="{CompiledBinding Items}"
                      ItemTemplate="{StaticResource RibbonGalleryItemTemplate}"
                      IsVisible="{CompiledBinding IsGalleryLayout}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
        </ItemsControl>
        <ItemsControl Classes="ribbon-popup-section-command-items"
                      ItemsSource="{CompiledBinding Items}"
                      ItemTemplate="{StaticResource RibbonMenuItemTemplate}"
                      IsVisible="{CompiledBinding IsCommandListLayout}" />
      </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="RibbonToggleGroupOptionLargeTemplate" DataType="models:RibbonMenuItem">
      <ToggleButton Classes="ribbon-command ribbon-toggle-group-option ribbon-toggle-group-option-large"
                    MinWidth="108"
                    Margin="2"
                    Padding="8,5"
                    HorizontalContentAlignment="Left"
                    IsChecked="{CompiledBinding IsSelected, Mode=TwoWay}"
                    Command="{CompiledBinding Command}"
                    CommandParameter="{CompiledBinding CommandParameter}"
                    Tag="{CompiledBinding Id, StringFormat='toggle-group-option:{0}'}"
                    ToolTip.Tip="{CompiledBinding ScreenTip}"
                    AutomationProperties.Name="{CompiledBinding Label}"
                    AutomationProperties.AutomationId="{CompiledBinding Id, StringFormat='Ribbon.ToggleGroupOption.{0}'}">
        <Grid>
          <ContentPresenter Content="{CompiledBinding Content}"
                            IsVisible="{CompiledBinding HasContent}" />
          <StackPanel Orientation="Horizontal"
                      Spacing="7"
                      VerticalAlignment="Center"
                      IsVisible="{CompiledBinding HasNoContent}">
            <controls:RibbonIconPresenter Icon="{CompiledBinding Icon}"
                        IconResourceKey="{CompiledBinding IconResourceKey}"
                        IconPathData="{CompiledBinding IconPathData}"
                        IconEmoji="{CompiledBinding IconEmoji}"
                        IconStretch="{CompiledBinding IconStretch}"
                        IconStretchDirection="{CompiledBinding IconStretchDirection}"
                        IconWidth="{CompiledBinding IconWidth}"
                        IconHeight="{CompiledBinding IconHeight}"
                        IconMinWidth="{CompiledBinding IconMinWidth}"
                        IconMinHeight="{CompiledBinding IconMinHeight}"
                        IconMaxWidth="{CompiledBinding IconMaxWidth}"
                        IconMaxHeight="{CompiledBinding IconMaxHeight}"
                        Overlay="{CompiledBinding Overlay}"
                        OverlayResourceKey="{CompiledBinding OverlayResourceKey}"
                        OverlayPathData="{CompiledBinding OverlayPathData}"
                        OverlayEmoji="{CompiledBinding OverlayEmoji}"
                        OverlayCount="{CompiledBinding OverlayCount}"
                        OverlayCountText="{CompiledBinding OverlayCountText}"
                        ShowOverlayCountWhenZero="{CompiledBinding ShowOverlayCountWhenZero}"
                        OverlayHorizontalAlignment="{CompiledBinding OverlayHorizontalAlignment}"
                        OverlayVerticalAlignment="{CompiledBinding OverlayVerticalAlignment}"
                        OverlayMargin="{CompiledBinding OverlayMargin}"
                        OverlayCountHorizontalAlignment="{CompiledBinding OverlayCountHorizontalAlignment}"
                        OverlayCountVerticalAlignment="{CompiledBinding OverlayCountVerticalAlignment}"
                        OverlayCountMargin="{CompiledBinding OverlayCountMargin}"
                      Width="16"
                      Height="16"
                      IsVisible="{CompiledBinding HasIcon}" />
            <TextBlock Text="{CompiledBinding Label}"
                       VerticalAlignment="Center" />
          </StackPanel>
        </Grid>
      </ToggleButton>
    </DataTemplate>

    <DataTemplate x:Key="RibbonToggleGroupOptionSmallTemplate" DataType="models:RibbonMenuItem">
      <ToggleButton Classes="ribbon-command ribbon-toggle-group-option ribbon-toggle-group-option-small"
                    MinWidth="96"
                    Margin="2"
                    Padding="6,4"
                    HorizontalContentAlignment="Left"
                    IsChecked="{CompiledBinding IsSelected, Mode=TwoWay}"
                    Command="{CompiledBinding Command}"
                    CommandParameter="{CompiledBinding CommandParameter}"
                    Tag="{CompiledBinding Id, StringFormat='toggle-group-option-small:{0}'}"
                    ToolTip.Tip="{CompiledBinding ScreenTip}"
                    AutomationProperties.Name="{CompiledBinding Label}"
                    AutomationProperties.AutomationId="{CompiledBinding Id, StringFormat='Ribbon.ToggleGroupOption.Small.{0}'}">
        <Grid>
          <ContentPresenter Content="{CompiledBinding Content}"
                            IsVisible="{CompiledBinding HasContent}" />
          <StackPanel Orientation="Horizontal"
                      Spacing="6"
                      VerticalAlignment="Center"
                      IsVisible="{CompiledBinding HasNoContent}">
            <controls:RibbonIconPresenter Icon="{CompiledBinding Icon}"
                        IconResourceKey="{CompiledBinding IconResourceKey}"
                        IconPathData="{CompiledBinding IconPathData}"
                        IconEmoji="{CompiledBinding IconEmoji}"
                        IconStretch="{CompiledBinding IconStretch}"
                        IconStretchDirection="{CompiledBinding IconStretchDirection}"
                        IconWidth="{CompiledBinding IconWidth}"
                        IconHeight="{CompiledBinding IconHeight}"
                        IconMinWidth="{CompiledBinding IconMinWidth}"
                        IconMinHeight="{CompiledBinding IconMinHeight}"
                        IconMaxWidth="{CompiledBinding IconMaxWidth}"
                        IconMaxHeight="{CompiledBinding IconMaxHeight}"
                        Overlay="{CompiledBinding Overlay}"
                        OverlayResourceKey="{CompiledBinding OverlayResourceKey}"
                        OverlayPathData="{CompiledBinding OverlayPathData}"
                        OverlayEmoji="{CompiledBinding OverlayEmoji}"
                        OverlayCount="{CompiledBinding OverlayCount}"
                        OverlayCountText="{CompiledBinding OverlayCountText}"
                        ShowOverlayCountWhenZero="{CompiledBinding ShowOverlayCountWhenZero}"
                        OverlayHorizontalAlignment="{CompiledBinding OverlayHorizontalAlignment}"
                        OverlayVerticalAlignment="{CompiledBinding OverlayVerticalAlignment}"
                        OverlayMargin="{CompiledBinding OverlayMargin}"
                        OverlayCountHorizontalAlignment="{CompiledBinding OverlayCountHorizontalAlignment}"
                        OverlayCountVerticalAlignment="{CompiledBinding OverlayCountVerticalAlignment}"
                        OverlayCountMargin="{CompiledBinding OverlayCountMargin}"
                      Width="14"
                      Height="14"
                      IsVisible="{CompiledBinding HasIcon}" />
            <TextBlock Text="{CompiledBinding Label}"
                       FontSize="11"
                       VerticalAlignment="Center" />
          </StackPanel>
        </Grid>
      </ToggleButton>
    </DataTemplate>

    <DataTemplate x:Key="RibbonToggleGroupSingleOptionLargeTemplate" DataType="models:RibbonMenuItem">
      <RadioButton Classes="ribbon-command ribbon-toggle-group-option ribbon-toggle-group-option-large ribbon-toggle-group-option-single"
                   MinWidth="108"
                   Margin="2"
                   Padding="8,5"
                   HorizontalContentAlignment="Left"
                   GroupName="{Binding Tag, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                   IsChecked="{CompiledBinding IsSelected, Mode=TwoWay}"
                   Command="{CompiledBinding Command}"
                   CommandParameter="{CompiledBinding CommandParameter}"
                   Tag="{CompiledBinding Id, StringFormat='toggle-group-radio-option:{0}'}"
                   ToolTip.Tip="{CompiledBinding ScreenTip}"
                   AutomationProperties.Name="{CompiledBinding Label}"
                   AutomationProperties.AutomationId="{CompiledBinding Id, StringFormat='Ribbon.ToggleGroupSingleOption.{0}'}">
        <Grid>
          <ContentPresenter Content="{CompiledBinding Content}"
                            IsVisible="{CompiledBinding HasContent}" />
          <StackPanel Orientation="Horizontal"
                      Spacing="7"
                      VerticalAlignment="Center"
                      IsVisible="{CompiledBinding HasNoContent}">
            <controls:RibbonIconPresenter Icon="{CompiledBinding Icon}"
                        IconResourceKey="{CompiledBinding IconResourceKey}"
                        IconPathData="{CompiledBinding IconPathData}"
                        IconEmoji="{CompiledBinding IconEmoji}"
                        IconStretch="{CompiledBinding IconStretch}"
                        IconStretchDirection="{CompiledBinding IconStretchDirection}"
                        IconWidth="{CompiledBinding IconWidth}"
                        IconHeight="{CompiledBinding IconHeight}"
                        IconMinWidth="{CompiledBinding IconMinWidth}"
                        IconMinHeight="{CompiledBinding IconMinHeight}"
                        IconMaxWidth="{CompiledBinding IconMaxWidth}"
                        IconMaxHeight="{CompiledBinding IconMaxHeight}"
                        Overlay="{CompiledBinding Overlay}"
                        OverlayResourceKey="{CompiledBinding OverlayResourceKey}"
                        OverlayPathData="{CompiledBinding OverlayPathData}"
                        OverlayEmoji="{CompiledBinding OverlayEmoji}"
                        OverlayCount="{CompiledBinding OverlayCount}"
                        OverlayCountText="{CompiledBinding OverlayCountText}"
                        ShowOverlayCountWhenZero="{CompiledBinding ShowOverlayCountWhenZero}"
                        OverlayHorizontalAlignment="{CompiledBinding OverlayHorizontalAlignment}"
                        OverlayVerticalAlignment="{CompiledBinding OverlayVerticalAlignment}"
                        OverlayMargin="{CompiledBinding OverlayMargin}"
                        OverlayCountHorizontalAlignment="{CompiledBinding OverlayCountHorizontalAlignment}"
                        OverlayCountVerticalAlignment="{CompiledBinding OverlayCountVerticalAlignment}"
                        OverlayCountMargin="{CompiledBinding OverlayCountMargin}"
                      Width="16"
                      Height="16"
                      IsVisible="{CompiledBinding HasIcon}" />
            <TextBlock Text="{CompiledBinding Label}"
                       VerticalAlignment="Center" />
          </StackPanel>
        </Grid>
      </RadioButton>
    </DataTemplate>

    <DataTemplate x:Key="RibbonToggleGroupSingleOptionSmallTemplate" DataType="models:RibbonMenuItem">
      <RadioButton Classes="ribbon-command ribbon-toggle-group-option ribbon-toggle-group-option-small ribbon-toggle-group-option-single"
                   MinWidth="96"
                   Margin="2"
                   Padding="6,4"
                   HorizontalContentAlignment="Left"
                   GroupName="{Binding Tag, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                   IsChecked="{CompiledBinding IsSelected, Mode=TwoWay}"
                   Command="{CompiledBinding Command}"
                   CommandParameter="{CompiledBinding CommandParameter}"
                   Tag="{CompiledBinding Id, StringFormat='toggle-group-radio-option-small:{0}'}"
