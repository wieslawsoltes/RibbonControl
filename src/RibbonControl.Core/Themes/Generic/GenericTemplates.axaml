                        IconStretch="{CompiledBinding IconStretch}"
                        IconStretchDirection="{CompiledBinding IconStretchDirection}"
                        IconWidth="{CompiledBinding IconWidth}"
                        IconHeight="{CompiledBinding IconHeight}"
                        IconMinWidth="{CompiledBinding IconMinWidth}"
                        IconMinHeight="{CompiledBinding IconMinHeight}"
                        IconMaxWidth="{CompiledBinding IconMaxWidth}"
                        IconMaxHeight="{CompiledBinding IconMaxHeight}"
                        Overlay="{CompiledBinding Overlay}"
                        OverlayResourceKey="{CompiledBinding OverlayResourceKey}"
                        OverlayPathData="{CompiledBinding OverlayPathData}"
                        OverlayEmoji="{CompiledBinding OverlayEmoji}"
                        OverlayCount="{CompiledBinding OverlayCount}"
                        OverlayCountText="{CompiledBinding OverlayCountText}"
                        ShowOverlayCountWhenZero="{CompiledBinding ShowOverlayCountWhenZero}"
                        OverlayHorizontalAlignment="{CompiledBinding OverlayHorizontalAlignment}"
                        OverlayVerticalAlignment="{CompiledBinding OverlayVerticalAlignment}"
                        OverlayMargin="{CompiledBinding OverlayMargin}"
                        OverlayCountHorizontalAlignment="{CompiledBinding OverlayCountHorizontalAlignment}"
                        OverlayCountVerticalAlignment="{CompiledBinding OverlayCountVerticalAlignment}"
                        OverlayCountMargin="{CompiledBinding OverlayCountMargin}"
                        Width="16"
                        Height="16" />
              <DockPanel LastChildFill="False">
                <TextBlock Text="{CompiledBinding Label}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center" />
                <TextBlock Text="▾"
                           Margin="4,0,0,0"
                           VerticalAlignment="Center"
                           FontSize="10"
                           Opacity="0.75" />
              </DockPanel>
            </StackPanel>
          </ToggleButton>
          <Popup IsOpen="{CompiledBinding IsMenuDropDownOpen, Mode=TwoWay}"
                 IsLightDismissEnabled="True"
                 Placement="Bottom"
                 PlacementTarget="{Binding #PART_MenuDropDownToggle}">
            <Border Classes="ribbon-popup-surface ribbon-popup-menu-surface"
                    Background="{DynamicResource RibbonGenericSurfaceBrush}"
                    BorderBrush="{DynamicResource RibbonGenericPopupBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="2"
                    MinWidth="{CompiledBinding PopupMinWidth}">
              <StackPanel Spacing="4">
                <TextBlock Text="{CompiledBinding PopupTitle}"
                           FontWeight="SemiBold"
                           FontSize="14"
                           IsVisible="{CompiledBinding HasPopupTitle}" />
                <ContentPresenter Content="{CompiledBinding PopupContent}"
                                  IsVisible="{CompiledBinding HasPopupContent}" />
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              MaxHeight="{CompiledBinding PopupMaxHeight}"
                              IsVisible="{CompiledBinding HasPopupMenuSections}">
                  <ItemsControl ItemsSource="{CompiledBinding PopupMenuSections}"
                                ItemTemplate="{StaticResource RibbonPopupMenuSectionTemplate}" />
                </ScrollViewer>
                <ContentPresenter Content="{CompiledBinding PopupFooterContent}"
                                  IsVisible="{CompiledBinding HasPopupFooterContent}" />
              </StackPanel>
            </Border>
          </Popup>
        </Grid>

        <Border Grid.Row="4"
                IsVisible="{CompiledBinding IsGalleryPrimitive}"
                Padding="4"
                BorderThickness="1"
                BorderBrush="{DynamicResource RibbonGenericPopupBorderBrush}"
                CornerRadius="2"
                Tag="{CompiledBinding Id}"
                ToolTip.Tip="{CompiledBinding ScreenTip}"
                AutomationProperties.Name="{CompiledBinding Label}"
                AutomationProperties.AutomationId="{CompiledBinding Id, StringFormat='Ribbon.Item.Gallery.{0}'}">
          <Grid RowDefinitions="Auto,Auto">
            <DockPanel Grid.Row="0"
                       LastChildFill="False">
              <TextBlock Text="{CompiledBinding Label}"
                         FontSize="11"
                         FontWeight="SemiBold"
                         HorizontalAlignment="Left" />
              <ToggleButton x:Name="PART_GalleryDropDownToggle"
                            MinWidth="20"
                            MinHeight="20"
                            Margin="6,0,0,0"
                            Padding="2"
                            Content="▾"
                            IsChecked="{CompiledBinding IsDropDownOpen, Mode=TwoWay}" />
            </DockPanel>
            <ItemsControl Grid.Row="1"
                          Margin="0,4,0,0"
                          ItemsSource="{CompiledBinding RibbonPreviewMenuItems}"
                          ItemTemplate="{StaticResource RibbonGalleryItemTemplate}"
                          IsVisible="{CompiledBinding HasRibbonPreviewMenuItems}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
            </ItemsControl>
            <Popup IsOpen="{CompiledBinding IsGalleryDropDownOpen, Mode=TwoWay}"
                   IsLightDismissEnabled="True"
                   Placement="Bottom"
                   PlacementTarget="{Binding #PART_GalleryDropDownToggle}">
              <Border Classes="ribbon-popup-surface"
                      Background="{DynamicResource RibbonGenericSurfaceBrush}"
                      BorderBrush="{DynamicResource RibbonGenericPopupBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="2"
                      Padding="4"
                      MinWidth="{CompiledBinding PopupMinWidth}">
                <StackPanel Spacing="4">
                  <TextBlock Text="{CompiledBinding PopupTitle}"
                             FontWeight="SemiBold"
                             FontSize="14"
                             IsVisible="{CompiledBinding HasPopupTitle}" />
                  <TextBlock Text="{CompiledBinding Description}"
                             FontSize="10"
                             Opacity="0.7"
                             IsVisible="{CompiledBinding HasDescription}" />
                  <ContentPresenter Content="{CompiledBinding PopupContent}"
                                    IsVisible="{CompiledBinding HasPopupContent}" />
                  <ScrollViewer VerticalScrollBarVisibility="Auto"
                                MaxHeight="{CompiledBinding PopupMaxHeight}"
                                IsVisible="{CompiledBinding ShowStructuredPopupMenuSections}">
                    <ItemsControl ItemsSource="{CompiledBinding PopupMenuSections}"
                                  ItemTemplate="{StaticResource RibbonPopupMenuSectionTemplate}" />
                  </ScrollViewer>
                  <ScrollViewer VerticalScrollBarVisibility="Auto"
                                MaxHeight="{CompiledBinding PopupMaxHeight}"
                                IsVisible="{CompiledBinding ShowPopupMenuCategories}">
                    <ItemsControl ItemsSource="{CompiledBinding PopupMenuCategories}"
                                  ItemTemplate="{StaticResource RibbonGalleryCategoryTemplate}" />
                  </ScrollViewer>
                  <ScrollViewer VerticalScrollBarVisibility="Auto"
                                MaxHeight="{CompiledBinding PopupMaxHeight}"
                                IsVisible="{CompiledBinding ShowFlatCategorizedPopupMenuItems}">
                    <ItemsControl ItemsSource="{CompiledBinding CategorizedPopupMenuItems}"
                                  ItemTemplate="{StaticResource RibbonGalleryItemTemplate}">
                      <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                          <WrapPanel />
                        </ItemsPanelTemplate>
                      </ItemsControl.ItemsPanel>
                    </ItemsControl>
                  </ScrollViewer>
                  <Separator IsVisible="{CompiledBinding ShowUncategorizedPopupMenuItems}" />
                  <ScrollViewer VerticalScrollBarVisibility="Auto"
                                MaxHeight="{CompiledBinding PopupMaxHeight}"
                                IsVisible="{CompiledBinding ShowUncategorizedPopupMenuItems}">
                    <ItemsControl ItemsSource="{CompiledBinding UncategorizedPopupMenuItems}"
                                  ItemTemplate="{StaticResource RibbonMenuItemTemplate}" />
                  </ScrollViewer>
                  <ScrollViewer VerticalScrollBarVisibility="Auto"
                                MaxHeight="{CompiledBinding PopupMaxHeight}"
                                IsVisible="{CompiledBinding ShowLegacyPopupMenuItems}">
                    <ItemsControl ItemsSource="{CompiledBinding PopupMenuItems}"
                                  ItemTemplate="{StaticResource RibbonMenuItemTemplate}" />
                  </ScrollViewer>
                  <ContentPresenter Content="{CompiledBinding PopupFooterContent}"
                                    IsVisible="{CompiledBinding HasPopupFooterContent}" />
                </StackPanel>
              </Border>
            </Popup>
          </Grid>
        </Border>

        <ToggleButton Classes="ribbon-command ribbon-toggle ribbon-toggle-large"
                      Grid.Row="5"
                      MinWidth="76"
                      MinHeight="60"
                      Padding="6"
                      IsVisible="{CompiledBinding IsEffectiveLargeToggleButtonPrimitive}"
                      IsChecked="{CompiledBinding IsChecked, Mode=TwoWay}"
                      Command="{CompiledBinding Command}"
                      CommandParameter="{CompiledBinding CommandParameter}"
                      Tag="{CompiledBinding Id, StringFormat='toggle:{0}'}"
                      ToolTip.Tip="{CompiledBinding ScreenTip}"
                      AutomationProperties.Name="{CompiledBinding Label}"
                      AutomationProperties.AutomationId="{CompiledBinding Id, StringFormat='Ribbon.Item.Toggle.{0}'}">
          <StackPanel Orientation="Vertical"
                      HorizontalAlignment="Center"
                      Spacing="4">
            <controls:RibbonIconPresenter Icon="{CompiledBinding Icon}"
                        IconResourceKey="{CompiledBinding IconResourceKey}"
                        IconPathData="{CompiledBinding IconPathData}"
                        IconEmoji="{CompiledBinding IconEmoji}"
                        IconStretch="{CompiledBinding IconStretch}"
                        IconStretchDirection="{CompiledBinding IconStretchDirection}"
                        IconWidth="{CompiledBinding IconWidth}"
                        IconHeight="{CompiledBinding IconHeight}"
                        IconMinWidth="{CompiledBinding IconMinWidth}"
                        IconMinHeight="{CompiledBinding IconMinHeight}"
                        IconMaxWidth="{CompiledBinding IconMaxWidth}"
                        IconMaxHeight="{CompiledBinding IconMaxHeight}"
                        Overlay="{CompiledBinding Overlay}"
                        OverlayResourceKey="{CompiledBinding OverlayResourceKey}"
                        OverlayPathData="{CompiledBinding OverlayPathData}"
                        OverlayEmoji="{CompiledBinding OverlayEmoji}"
                        OverlayCount="{CompiledBinding OverlayCount}"
                        OverlayCountText="{CompiledBinding OverlayCountText}"
                        ShowOverlayCountWhenZero="{CompiledBinding ShowOverlayCountWhenZero}"
                        OverlayHorizontalAlignment="{CompiledBinding OverlayHorizontalAlignment}"
                        OverlayVerticalAlignment="{CompiledBinding OverlayVerticalAlignment}"
                        OverlayMargin="{CompiledBinding OverlayMargin}"
                        OverlayCountHorizontalAlignment="{CompiledBinding OverlayCountHorizontalAlignment}"
                        OverlayCountVerticalAlignment="{CompiledBinding OverlayCountVerticalAlignment}"
                        OverlayCountMargin="{CompiledBinding OverlayCountMargin}"
                      Width="16"
                      Height="16"
                      IsVisible="{CompiledBinding HasIcon}" />
            <TextBlock Text="{CompiledBinding Label}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center" />
          </StackPanel>
        </ToggleButton>

        <ToggleButton Classes="ribbon-command ribbon-toggle ribbon-toggle-small"
                      Grid.Row="6"
                      MinWidth="38"
                      MinHeight="28"
                      Padding="6,4"
                      IsVisible="{CompiledBinding IsEffectiveSmallToggleButtonPrimitive}"
                      IsChecked="{CompiledBinding IsChecked, Mode=TwoWay}"
                      Command="{CompiledBinding Command}"
                      CommandParameter="{CompiledBinding CommandParameter}"
                      Tag="{CompiledBinding Id, StringFormat='toggle-small:{0}'}"
                      ToolTip.Tip="{CompiledBinding ScreenTip}"
                      AutomationProperties.Name="{CompiledBinding Label}"
                      AutomationProperties.AutomationId="{CompiledBinding Id, StringFormat='Ribbon.Item.Toggle.Small.{0}'}">
          <StackPanel Orientation="Horizontal"
                      HorizontalAlignment="Center"
                      Spacing="5"
                      VerticalAlignment="Center">
            <controls:RibbonIconPresenter Icon="{CompiledBinding Icon}"
                        IconResourceKey="{CompiledBinding IconResourceKey}"
                        IconPathData="{CompiledBinding IconPathData}"
                        IconEmoji="{CompiledBinding IconEmoji}"
                        IconStretch="{CompiledBinding IconStretch}"
                        IconStretchDirection="{CompiledBinding IconStretchDirection}"
                        IconWidth="{CompiledBinding IconWidth}"
                        IconHeight="{CompiledBinding IconHeight}"
                        IconMinWidth="{CompiledBinding IconMinWidth}"
                        IconMinHeight="{CompiledBinding IconMinHeight}"
                        IconMaxWidth="{CompiledBinding IconMaxWidth}"
                        IconMaxHeight="{CompiledBinding IconMaxHeight}"
                        Overlay="{CompiledBinding Overlay}"
                        OverlayResourceKey="{CompiledBinding OverlayResourceKey}"
                        OverlayPathData="{CompiledBinding OverlayPathData}"
                        OverlayEmoji="{CompiledBinding OverlayEmoji}"
                        OverlayCount="{CompiledBinding OverlayCount}"
                        OverlayCountText="{CompiledBinding OverlayCountText}"
                        ShowOverlayCountWhenZero="{CompiledBinding ShowOverlayCountWhenZero}"
                        OverlayHorizontalAlignment="{CompiledBinding OverlayHorizontalAlignment}"
                        OverlayVerticalAlignment="{CompiledBinding OverlayVerticalAlignment}"
                        OverlayMargin="{CompiledBinding OverlayMargin}"
                        OverlayCountHorizontalAlignment="{CompiledBinding OverlayCountHorizontalAlignment}"
                        OverlayCountVerticalAlignment="{CompiledBinding OverlayCountVerticalAlignment}"
                        OverlayCountMargin="{CompiledBinding OverlayCountMargin}"
                      Width="14"
                      Height="14"
                      IsVisible="{CompiledBinding HasIcon}" />
            <TextBlock Text="{CompiledBinding Label}" />
          </StackPanel>
        </ToggleButton>

        <ToggleButton Classes="ribbon-command ribbon-toggle ribbon-toggle-icon-only"
                      Grid.Row="12"
                      MinWidth="36"
                      MinHeight="36"
                      Padding="0"
                      IsVisible="{CompiledBinding IsEffectiveLargeIconOnlyToggleButtonPrimitive}"
                      IsChecked="{CompiledBinding IsChecked, Mode=TwoWay}"
                      Command="{CompiledBinding Command}"
                      CommandParameter="{CompiledBinding CommandParameter}"
                      Tag="{CompiledBinding Id, StringFormat='toggle-icononly:{0}'}"
                      ToolTip.Tip="{CompiledBinding ScreenTip}"
                      AutomationProperties.Name="{CompiledBinding Label}"
                      AutomationProperties.AutomationId="{CompiledBinding Id, StringFormat='Ribbon.Item.Toggle.IconOnly.{0}'}">
          <controls:RibbonIconPresenter Icon="{CompiledBinding Icon}"
                        IconResourceKey="{CompiledBinding IconResourceKey}"
                        IconPathData="{CompiledBinding IconPathData}"
                        IconEmoji="{CompiledBinding IconEmoji}"
                        IconStretch="{CompiledBinding IconStretch}"
                        IconStretchDirection="{CompiledBinding IconStretchDirection}"
                        IconWidth="{CompiledBinding IconWidth}"
                        IconHeight="{CompiledBinding IconHeight}"
                        IconMinWidth="{CompiledBinding IconMinWidth}"
                        IconMinHeight="{CompiledBinding IconMinHeight}"
                        IconMaxWidth="{CompiledBinding IconMaxWidth}"
                        IconMaxHeight="{CompiledBinding IconMaxHeight}"
                        Overlay="{CompiledBinding Overlay}"
                        OverlayResourceKey="{CompiledBinding OverlayResourceKey}"
                        OverlayPathData="{CompiledBinding OverlayPathData}"
                        OverlayEmoji="{CompiledBinding OverlayEmoji}"
                        OverlayCount="{CompiledBinding OverlayCount}"
                        OverlayCountText="{CompiledBinding OverlayCountText}"
                        ShowOverlayCountWhenZero="{CompiledBinding ShowOverlayCountWhenZero}"
                        OverlayHorizontalAlignment="{CompiledBinding OverlayHorizontalAlignment}"
                        OverlayVerticalAlignment="{CompiledBinding OverlayVerticalAlignment}"
                        OverlayMargin="{CompiledBinding OverlayMargin}"
                        OverlayCountHorizontalAlignment="{CompiledBinding OverlayCountHorizontalAlignment}"
                        OverlayCountVerticalAlignment="{CompiledBinding OverlayCountVerticalAlignment}"
                        OverlayCountMargin="{CompiledBinding OverlayCountMargin}"
                    Width="16"
                    Height="16"
                    IsVisible="{CompiledBinding HasIcon}" />
        </ToggleButton>

        <ToggleButton Classes="ribbon-command ribbon-toggle ribbon-toggle-icon-only ribbon-toggle-icon-only-small"
                      Grid.Row="13"
                      MinWidth="30"
                      MinHeight="30"
                      Padding="0"
                      IsVisible="{CompiledBinding IsEffectiveSmallIconOnlyToggleButtonPrimitive}"
                      IsChecked="{CompiledBinding IsChecked, Mode=TwoWay}"
                      Command="{CompiledBinding Command}"
                      CommandParameter="{CompiledBinding CommandParameter}"
                      Tag="{CompiledBinding Id, StringFormat='toggle-icononly-small:{0}'}"
                      ToolTip.Tip="{CompiledBinding ScreenTip}"
                      AutomationProperties.Name="{CompiledBinding Label}"
                      AutomationProperties.AutomationId="{CompiledBinding Id, StringFormat='Ribbon.Item.Toggle.IconOnly.Small.{0}'}">
          <controls:RibbonIconPresenter Icon="{CompiledBinding Icon}"
                        IconResourceKey="{CompiledBinding IconResourceKey}"
                        IconPathData="{CompiledBinding IconPathData}"
                        IconEmoji="{CompiledBinding IconEmoji}"
                        IconStretch="{CompiledBinding IconStretch}"
                        IconStretchDirection="{CompiledBinding IconStretchDirection}"
                        IconWidth="{CompiledBinding IconWidth}"
                        IconHeight="{CompiledBinding IconHeight}"
                        IconMinWidth="{CompiledBinding IconMinWidth}"
                        IconMinHeight="{CompiledBinding IconMinHeight}"
                        IconMaxWidth="{CompiledBinding IconMaxWidth}"
                        IconMaxHeight="{CompiledBinding IconMaxHeight}"
                        Overlay="{CompiledBinding Overlay}"
                        OverlayResourceKey="{CompiledBinding OverlayResourceKey}"
                        OverlayPathData="{CompiledBinding OverlayPathData}"
                        OverlayEmoji="{CompiledBinding OverlayEmoji}"
                        OverlayCount="{CompiledBinding OverlayCount}"
                        OverlayCountText="{CompiledBinding OverlayCountText}"
                        ShowOverlayCountWhenZero="{CompiledBinding ShowOverlayCountWhenZero}"
                        OverlayHorizontalAlignment="{CompiledBinding OverlayHorizontalAlignment}"
                        OverlayVerticalAlignment="{CompiledBinding OverlayVerticalAlignment}"
                        OverlayMargin="{CompiledBinding OverlayMargin}"
                        OverlayCountHorizontalAlignment="{CompiledBinding OverlayCountHorizontalAlignment}"
                        OverlayCountVerticalAlignment="{CompiledBinding OverlayCountVerticalAlignment}"
                        OverlayCountMargin="{CompiledBinding OverlayCountMargin}"
                    Width="14"
                    Height="14"
                    IsVisible="{CompiledBinding HasIcon}" />
        </ToggleButton>

        <ComboBox Classes="ribbon-combo ribbon-combo-large"
                  Grid.Row="7"
                  MinWidth="168"
                  IsVisible="{CompiledBinding IsEffectiveLargeComboBoxPrimitive}"
                  ItemsSource="{CompiledBinding ComboBoxMenuItems}"
                  ItemTemplate="{StaticResource RibbonComboBoxMenuItemTemplate}"
                  SelectedItem="{CompiledBinding SelectedComboBoxMenuItem, Mode=TwoWay}"
                  Tag="{CompiledBinding Id, StringFormat='combo:{0}'}"
                  ToolTip.Tip="{CompiledBinding ScreenTip}"
                  AutomationProperties.Name="{CompiledBinding Label}"
                  AutomationProperties.AutomationId="{CompiledBinding Id, StringFormat='Ribbon.Item.ComboBox.{0}'}" />

        <ComboBox Classes="ribbon-combo ribbon-combo-small"
                  Grid.Row="8"
                  MinWidth="84"
                  IsVisible="{CompiledBinding IsEffectiveSmallComboBoxPrimitive}"
                  ItemsSource="{CompiledBinding ComboBoxMenuItems}"
                  ItemTemplate="{StaticResource RibbonComboBoxMenuItemTemplate}"
                  SelectedItem="{CompiledBinding SelectedComboBoxMenuItem, Mode=TwoWay}"
                  Tag="{CompiledBinding Id, StringFormat='combo-small:{0}'}"
                  ToolTip.Tip="{CompiledBinding ScreenTip}"
                  AutomationProperties.Name="{CompiledBinding Label}"
                  AutomationProperties.AutomationId="{CompiledBinding Id, StringFormat='Ribbon.Item.ComboBox.Small.{0}'}" />

        <Border Grid.Row="14"
                Padding="2"
                IsVisible="{CompiledBinding IsEffectiveLargeToggleGroupPrimitive}"
                Tag="{CompiledBinding Id, StringFormat='toggle-group-large:{0}'}"
                ToolTip.Tip="{CompiledBinding ScreenTip}"
                AutomationProperties.Name="{CompiledBinding Label}"
                AutomationProperties.AutomationId="{CompiledBinding Id, StringFormat='Ribbon.Item.ToggleGroup.{0}'}">
          <Grid>
            <ItemsControl ItemsSource="{CompiledBinding ToggleGroupMenuItems}"
                          ItemTemplate="{StaticResource RibbonToggleGroupOptionLargeTemplate}"
                          Tag="{CompiledBinding Id, StringFormat='group:{0}'}"
                          IsVisible="{CompiledBinding IsToggleGroupMultipleSelectionMode}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <UniformGrid Columns="{Binding $parent[ItemsControl].DataContext.ToggleGroupColumns}" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
            </ItemsControl>
            <ItemsControl ItemsSource="{CompiledBinding ToggleGroupMenuItems}"
                          ItemTemplate="{StaticResource RibbonToggleGroupSingleOptionLargeTemplate}"
                          Tag="{CompiledBinding Id, StringFormat='group-single:{0}'}"
                          IsVisible="{CompiledBinding IsToggleGroupSingleSelectionMode}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <UniformGrid Columns="{Binding $parent[ItemsControl].DataContext.ToggleGroupColumns}" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
            </ItemsControl>
          </Grid>
        </Border>

        <Border Grid.Row="15"
                Padding="2"
                IsVisible="{CompiledBinding IsEffectiveSmallToggleGroupPrimitive}"
                Tag="{CompiledBinding Id, StringFormat='toggle-group-small:{0}'}"
                ToolTip.Tip="{CompiledBinding ScreenTip}"
                AutomationProperties.Name="{CompiledBinding Label}"
                AutomationProperties.AutomationId="{CompiledBinding Id, StringFormat='Ribbon.Item.ToggleGroup.Small.{0}'}">
          <Grid>
            <ItemsControl ItemsSource="{CompiledBinding ToggleGroupMenuItems}"
                          ItemTemplate="{StaticResource RibbonToggleGroupOptionSmallTemplate}"
                          Tag="{CompiledBinding Id, StringFormat='group:{0}'}"
                          IsVisible="{CompiledBinding IsToggleGroupMultipleSelectionMode}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <UniformGrid Columns="{Binding $parent[ItemsControl].DataContext.ToggleGroupColumns}" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
            </ItemsControl>
            <ItemsControl ItemsSource="{CompiledBinding ToggleGroupMenuItems}"
                          ItemTemplate="{StaticResource RibbonToggleGroupSingleOptionSmallTemplate}"
                          Tag="{CompiledBinding Id, StringFormat='group-single:{0}'}"
                          IsVisible="{CompiledBinding IsToggleGroupSingleSelectionMode}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <UniformGrid Columns="{Binding $parent[ItemsControl].DataContext.ToggleGroupColumns}" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
            </ItemsControl>
          </Grid>
        </Border>

        <Border Grid.Row="9"
                IsVisible="{CompiledBinding IsCustomPrimitive}"
                Padding="2"
                Tag="{CompiledBinding Id, StringFormat='custom:{0}'}"
                AutomationProperties.Name="{CompiledBinding Label}"
                AutomationProperties.AutomationId="{CompiledBinding Id, StringFormat='Ribbon.Item.Custom.{0}'}">
          <ContentPresenter Content="{CompiledBinding Content}" />
        </Border>
      </Grid>
    </DataTemplate>

    <DataTemplate x:Key="RibbonQuickAccessItemTemplate" DataType="models:RibbonItem">
      <Button MinWidth="28"
              MinHeight="28"
              Padding="4"
              Margin="2"
              Command="{CompiledBinding Command}"
              CommandParameter="{CompiledBinding CommandParameter}"
              Tag="{CompiledBinding Id, StringFormat='qat:{0}'}"
              ToolTip.Tip="{CompiledBinding ScreenTip}"
              AutomationProperties.Name="{CompiledBinding Label}"
              AutomationProperties.AutomationId="{CompiledBinding Id, StringFormat='Ribbon.QatItem.{0}'}">
        <controls:RibbonIconPresenter Icon="{CompiledBinding Icon}"
                        IconResourceKey="{CompiledBinding IconResourceKey}"
                        IconPathData="{CompiledBinding IconPathData}"
                        IconEmoji="{CompiledBinding IconEmoji}"
                        IconStretch="{CompiledBinding IconStretch}"
                        IconStretchDirection="{CompiledBinding IconStretchDirection}"
                        IconWidth="{CompiledBinding IconWidth}"
                        IconHeight="{CompiledBinding IconHeight}"
                        IconMinWidth="{CompiledBinding IconMinWidth}"
                        IconMinHeight="{CompiledBinding IconMinHeight}"
                        IconMaxWidth="{CompiledBinding IconMaxWidth}"
                        IconMaxHeight="{CompiledBinding IconMaxHeight}"
                        Overlay="{CompiledBinding Overlay}"
                        OverlayResourceKey="{CompiledBinding OverlayResourceKey}"
                        OverlayPathData="{CompiledBinding OverlayPathData}"
                        OverlayEmoji="{CompiledBinding OverlayEmoji}"
                        OverlayCount="{CompiledBinding OverlayCount}"
                        OverlayCountText="{CompiledBinding OverlayCountText}"
                        ShowOverlayCountWhenZero="{CompiledBinding ShowOverlayCountWhenZero}"
                        OverlayHorizontalAlignment="{CompiledBinding OverlayHorizontalAlignment}"
                        OverlayVerticalAlignment="{CompiledBinding OverlayVerticalAlignment}"
                        OverlayMargin="{CompiledBinding OverlayMargin}"
                        OverlayCountHorizontalAlignment="{CompiledBinding OverlayCountHorizontalAlignment}"
                        OverlayCountVerticalAlignment="{CompiledBinding OverlayCountVerticalAlignment}"
                        OverlayCountMargin="{CompiledBinding OverlayCountMargin}"
                  Width="14"
                  Height="14" />
      </Button>
    </DataTemplate>

    <DataTemplate x:Key="RibbonGroupTemplate" DataType="models:RibbonGroup">
      <Grid Margin="4">
        <Border Padding="8"
                IsVisible="{CompiledBinding IsInlineMode}">
          <Grid RowDefinitions="Auto,*,Auto"
                ColumnDefinitions="Auto,*,Auto"
                RowSpacing="6"
                ColumnSpacing="6">
            <TextBlock Grid.Row="0"
                       Grid.Column="1"
                       Text="{CompiledBinding Header}"
                       HorizontalAlignment="Center"
                       FontSize="12"
                       IsVisible="{CompiledBinding IsHeaderTop}" />
            <TextBlock Grid.Row="2"
                       Grid.Column="1"
                       Text="{CompiledBinding Header}"
                       HorizontalAlignment="Center"
                       FontSize="12"
                       IsVisible="{CompiledBinding IsHeaderBottom}" />
            <LayoutTransformControl Grid.Row="1"
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    IsVisible="{CompiledBinding IsHeaderLeft}">
              <LayoutTransformControl.LayoutTransform>
                <RotateTransform Angle="-90" />
              </LayoutTransformControl.LayoutTransform>
              <TextBlock Text="{CompiledBinding Header}"
                         FontSize="12"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center" />
            </LayoutTransformControl>
            <LayoutTransformControl Grid.Row="1"
                                    Grid.Column="2"
                                    VerticalAlignment="Center"
                                    IsVisible="{CompiledBinding IsHeaderRight}">
              <LayoutTransformControl.LayoutTransform>
                <RotateTransform Angle="90" />
              </LayoutTransformControl.LayoutTransform>
              <TextBlock Text="{CompiledBinding Header}"
                         FontSize="12"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center" />
            </LayoutTransformControl>
            <ItemsControl Grid.Row="1"
                          Grid.Column="1"
                          IsVisible="{CompiledBinding IsItemsWrapLayout}"
                          ItemsSource="{CompiledBinding MergedItems}"
                          ItemTemplate="{StaticResource RibbonItemTemplate}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
            </ItemsControl>
            <ItemsControl Grid.Row="1"
                          Grid.Column="1"
                          IsVisible="{CompiledBinding IsItemsHorizontalLayout}"
                          ItemsSource="{CompiledBinding MergedItems}"
                          ItemTemplate="{StaticResource RibbonItemTemplate}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
            </ItemsControl>
            <ItemsControl Grid.Row="1"
                          Grid.Column="1"
                          IsVisible="{CompiledBinding IsItemsVerticalLayout}"
                          ItemsSource="{CompiledBinding MergedItems}"
                          ItemTemplate="{StaticResource RibbonItemTemplate}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Orientation="Vertical" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
            </ItemsControl>
            <ItemsControl Grid.Row="1"
                          Grid.Column="1"
                          IsVisible="{CompiledBinding IsItemsStackedLayout}"
                          ItemsSource="{CompiledBinding MergedItems}"
                          ItemTemplate="{StaticResource RibbonItemTemplate}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <controls:RibbonStackedWrapPanel MaxRows="{CompiledBinding StackedRows}"
                                                   HorizontalSpacing="4"
                                                   VerticalSpacing="4" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
            </ItemsControl>
            <DockPanel Grid.Row="1"
                       Grid.Column="1"
                       LastChildFill="True"
                       IsVisible="{CompiledBinding IsItemsDockedLayout}">
              <ItemsControl DockPanel.Dock="Top"
                            IsVisible="{CompiledBinding HasDockedTopItems}"
                            ItemsSource="{CompiledBinding DockedTopItems}"
                            ItemTemplate="{StaticResource RibbonItemTemplate}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
              </ItemsControl>
              <ItemsControl DockPanel.Dock="Bottom"
                            IsVisible="{CompiledBinding HasDockedBottomItems}"
                            ItemsSource="{CompiledBinding DockedBottomItems}"
                            ItemTemplate="{StaticResource RibbonItemTemplate}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
              </ItemsControl>
              <ItemsControl DockPanel.Dock="Left"
                            IsVisible="{CompiledBinding HasDockedLeftItems}"
                            ItemsSource="{CompiledBinding DockedLeftItems}"
                            ItemTemplate="{StaticResource RibbonItemTemplate}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Vertical" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
              </ItemsControl>
              <ItemsControl DockPanel.Dock="Right"
                            IsVisible="{CompiledBinding HasDockedRightItems}"
                            ItemsSource="{CompiledBinding DockedRightItems}"
                            ItemTemplate="{StaticResource RibbonItemTemplate}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Vertical" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
              </ItemsControl>
              <Grid IsVisible="{CompiledBinding HasDockedCenterItems}">
                <ItemsControl IsVisible="{CompiledBinding IsDockedCenterWrapLayout}"
                              ItemsSource="{CompiledBinding DockedCenterItems}"
                              ItemTemplate="{StaticResource RibbonItemTemplate}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <WrapPanel />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                </ItemsControl>
                <ItemsControl IsVisible="{CompiledBinding IsDockedCenterHorizontalLayout}"
                              ItemsSource="{CompiledBinding DockedCenterItems}"
                              ItemTemplate="{StaticResource RibbonItemTemplate}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                </ItemsControl>
                <ItemsControl IsVisible="{CompiledBinding IsDockedCenterVerticalLayout}"
                              ItemsSource="{CompiledBinding DockedCenterItems}"
                              ItemTemplate="{StaticResource RibbonItemTemplate}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <StackPanel Orientation="Vertical" />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                </ItemsControl>
                <ItemsControl IsVisible="{CompiledBinding IsDockedCenterStackedLayout}"
                              ItemsSource="{CompiledBinding DockedCenterItems}"
                              ItemTemplate="{StaticResource RibbonItemTemplate}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <controls:RibbonStackedWrapPanel MaxRows="{CompiledBinding StackedRows}"
                                                       HorizontalSpacing="4"
                                                       VerticalSpacing="4" />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                </ItemsControl>
              </Grid>
            </DockPanel>
          </Grid>
        </Border>

        <ToggleButton x:Name="PART_CollapsedGroupToggle"
                      Classes="ribbon-group-collapsed-toggle"
                      IsVisible="{CompiledBinding IsCollapsedMode}"
                      IsChecked="{CompiledBinding IsDropDownOpen, Mode=TwoWay}"
                      MinWidth="68"
                      MinHeight="72"
                      Padding="6"
                      Tag="{CompiledBinding Id, StringFormat='group:{0}'}"
                      ToolTip.Tip="{CompiledBinding Header}"
                      AutomationProperties.Name="{CompiledBinding Header}"
                      AutomationProperties.AutomationId="{CompiledBinding Id, StringFormat='Ribbon.Group.Collapsed.{0}'}">
          <StackPanel Spacing="4"
                      HorizontalAlignment="Center">
            <controls:RibbonIconPresenter Icon="{CompiledBinding CollapsedIcon}"
                        IconResourceKey="{CompiledBinding CollapsedIconResourceKey}"
                        IconPathData="{CompiledBinding CollapsedIconPathData}"
                        IconEmoji="{CompiledBinding CollapsedIconEmoji}"
                        IconStretch="{CompiledBinding IconStretch}"
                        IconStretchDirection="{CompiledBinding IconStretchDirection}"
                        IconWidth="{CompiledBinding IconWidth}"
                        IconHeight="{CompiledBinding IconHeight}"
                        IconMinWidth="{CompiledBinding IconMinWidth}"
                        IconMinHeight="{CompiledBinding IconMinHeight}"
                        IconMaxWidth="{CompiledBinding IconMaxWidth}"
                        IconMaxHeight="{CompiledBinding IconMaxHeight}"
                        Overlay="{CompiledBinding Overlay}"
                        OverlayResourceKey="{CompiledBinding OverlayResourceKey}"
                        OverlayPathData="{CompiledBinding OverlayPathData}"
                        OverlayEmoji="{CompiledBinding OverlayEmoji}"
                        OverlayCount="{CompiledBinding OverlayCount}"
                        OverlayCountText="{CompiledBinding OverlayCountText}"
                        ShowOverlayCountWhenZero="{CompiledBinding ShowOverlayCountWhenZero}"
                        OverlayHorizontalAlignment="{CompiledBinding OverlayHorizontalAlignment}"
                        OverlayVerticalAlignment="{CompiledBinding OverlayVerticalAlignment}"
                        OverlayMargin="{CompiledBinding OverlayMargin}"
                        OverlayCountHorizontalAlignment="{CompiledBinding OverlayCountHorizontalAlignment}"
                        OverlayCountVerticalAlignment="{CompiledBinding OverlayCountVerticalAlignment}"
                        OverlayCountMargin="{CompiledBinding OverlayCountMargin}"
                      Width="16"
                      Height="16"
                      IsVisible="{CompiledBinding HasCollapsedIcon}" />
            <TextBlock Text="{CompiledBinding Header}"
                       FontSize="11"
                       HorizontalAlignment="Center"
                       TextAlignment="Center" />
            <TextBlock Text="▾"
                       FontSize="10"
                       HorizontalAlignment="Center" />
          </StackPanel>
        </ToggleButton>

        <Popup IsOpen="{CompiledBinding IsDropDownOpen, Mode=TwoWay}"
               IsLightDismissEnabled="True"
               Placement="Bottom"
               PlacementTarget="{Binding #PART_CollapsedGroupToggle}">
          <Border Classes="ribbon-popup-surface"
                  Background="{DynamicResource RibbonGenericSurfaceBrush}"
                  BorderBrush="{DynamicResource RibbonGenericPopupBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="2"
                  Padding="8"
                  MinWidth="220">
            <StackPanel Spacing="8">
              <ItemsControl IsVisible="{CompiledBinding IsItemsWrapLayout}"
                            ItemsSource="{CompiledBinding MergedItems}"
                            ItemTemplate="{StaticResource RibbonItemTemplate}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <WrapPanel />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
              </ItemsControl>
              <ItemsControl IsVisible="{CompiledBinding IsItemsHorizontalLayout}"
                            ItemsSource="{CompiledBinding MergedItems}"
                            ItemTemplate="{StaticResource RibbonItemTemplate}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
              </ItemsControl>
              <ItemsControl IsVisible="{CompiledBinding IsItemsVerticalLayout}"
                            ItemsSource="{CompiledBinding MergedItems}"
                            ItemTemplate="{StaticResource RibbonItemTemplate}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Vertical" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
              </ItemsControl>
              <ItemsControl IsVisible="{CompiledBinding IsItemsStackedLayout}"
                            ItemsSource="{CompiledBinding MergedItems}"
                            ItemTemplate="{StaticResource RibbonItemTemplate}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <controls:RibbonStackedWrapPanel MaxRows="{CompiledBinding StackedRows}"
                                                     HorizontalSpacing="4"
                                                     VerticalSpacing="4" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
              </ItemsControl>
              <DockPanel LastChildFill="True"
                         IsVisible="{CompiledBinding IsItemsDockedLayout}">
                <ItemsControl DockPanel.Dock="Top"
                              IsVisible="{CompiledBinding HasDockedTopItems}"
                              ItemsSource="{CompiledBinding DockedTopItems}"
                              ItemTemplate="{StaticResource RibbonItemTemplate}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                </ItemsControl>
                <ItemsControl DockPanel.Dock="Bottom"
                              IsVisible="{CompiledBinding HasDockedBottomItems}"
                              ItemsSource="{CompiledBinding DockedBottomItems}"
                              ItemTemplate="{StaticResource RibbonItemTemplate}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                </ItemsControl>
                <ItemsControl DockPanel.Dock="Left"
                              IsVisible="{CompiledBinding HasDockedLeftItems}"
                              ItemsSource="{CompiledBinding DockedLeftItems}"
                              ItemTemplate="{StaticResource RibbonItemTemplate}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <StackPanel Orientation="Vertical" />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                </ItemsControl>
                <ItemsControl DockPanel.Dock="Right"
                              IsVisible="{CompiledBinding HasDockedRightItems}"
                              ItemsSource="{CompiledBinding DockedRightItems}"
                              ItemTemplate="{StaticResource RibbonItemTemplate}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <StackPanel Orientation="Vertical" />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                </ItemsControl>
                <Grid IsVisible="{CompiledBinding HasDockedCenterItems}">
                  <ItemsControl IsVisible="{CompiledBinding IsDockedCenterWrapLayout}"
                                ItemsSource="{CompiledBinding DockedCenterItems}"
                                ItemTemplate="{StaticResource RibbonItemTemplate}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <WrapPanel />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                  </ItemsControl>
                  <ItemsControl IsVisible="{CompiledBinding IsDockedCenterHorizontalLayout}"
                                ItemsSource="{CompiledBinding DockedCenterItems}"
                                ItemTemplate="{StaticResource RibbonItemTemplate}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                  </ItemsControl>
                  <ItemsControl IsVisible="{CompiledBinding IsDockedCenterVerticalLayout}"
                                ItemsSource="{CompiledBinding DockedCenterItems}"
                                ItemTemplate="{StaticResource RibbonItemTemplate}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical" />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                  </ItemsControl>
                  <ItemsControl IsVisible="{CompiledBinding IsDockedCenterStackedLayout}"
                                ItemsSource="{CompiledBinding DockedCenterItems}"
                                ItemTemplate="{StaticResource RibbonItemTemplate}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <controls:RibbonStackedWrapPanel MaxRows="{CompiledBinding StackedRows}"
                                                         HorizontalSpacing="4"
                                                         VerticalSpacing="4" />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                  </ItemsControl>
                </Grid>
              </DockPanel>
              <TextBlock Text="{CompiledBinding Header}"
                         HorizontalAlignment="Center"
                         FontSize="12"
                         FontWeight="SemiBold" />
            </StackPanel>
          </Border>
        </Popup>
      </Grid>
    </DataTemplate>

    <DataTemplate x:Key="RibbonTabContentTemplate" DataType="models:RibbonTab">
      <ScrollViewer HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Disabled">
        <ItemsControl ItemsSource="{CompiledBinding MergedGroups}"
                      ItemTemplate="{StaticResource RibbonGroupTemplate}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Orientation="Horizontal" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
        </ItemsControl>
      </ScrollViewer>
    </DataTemplate>

    <DataTemplate x:Key="RibbonCollapsedTabContentTemplate" DataType="models:RibbonTab">
      <Panel Width="0" Height="0" />
    </DataTemplate>

    <DataTemplate x:Key="RibbonContextGroupTemplate" DataType="models:RibbonContextualTabGroup">
      <Border Background="{DynamicResource RibbonGenericContextBandBrush}"
              BorderBrush="{CompiledBinding AccentColor, TargetNullValue={DynamicResource RibbonGenericContextBandBorderBrush}}"
              BorderThickness="1"
              CornerRadius="3"
              Margin="2"
              Padding="8,2">
        <TextBlock Text="{CompiledBinding Header}"
                   FontSize="11"
                   FontWeight="SemiBold"
                   Foreground="{CompiledBinding AccentColor, TargetNullValue={DynamicResource RibbonGenericTextBrush}}" />
      </Border>
    </DataTemplate>
</ResourceDictionary>
